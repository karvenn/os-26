---
interface Props {
  heading: string;
  buttonText: string;
  buttonHref: string;
}

const { heading, buttonText, buttonHref } = Astro.props;
---

<section class="band">
  <div class="band-inner">
    <p class="band-heading">{heading}</p>
    <a href={buttonHref} class="band-btn">{buttonText}</a>
  </div>
</section>

<style>
  .band {
    background-color: var(--color-surface-dark, #1C1917);
    padding: 4rem 1.5rem;
  }

  .band-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .band-heading {
    font-size: 1.5rem;
    font-weight: 600;
    color: white;
    letter-spacing: -0.02em;
  }

  .band-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background-color: var(--color-brand);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .band-btn:hover {
    background-color: var(--color-brand-dark, #C45E0A);
  }

  @media (max-width: 768px) {
    .band-inner {
      flex-direction: column;
      text-align: center;
    }
    .band-heading {
      font-size: 1.25rem;
    }
    .band-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
