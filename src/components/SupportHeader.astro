---
interface Props {
  active?: 'services' | 'pricing' | 'work' | 'faq' | 'about' | 'contact';
}

const { active } = Astro.props;
---

<header class="sh">
  <div class="sh-inner">
    <a href="/support" class="sh-logo">Orangesoft<span class="sh-dot">.</span></a>
    <nav class="sh-nav">
      <a href="/support/services" class:list={['sh-link', { 'sh-link--active': active === 'services' }]}>Services</a>
      <a href="/support/pricing" class:list={['sh-link', { 'sh-link--active': active === 'pricing' }]}>Pricing</a>
      <a href="/support/work" class:list={['sh-link', { 'sh-link--active': active === 'work' }]}>Clients</a>
      <a href="/support/faq" class:list={['sh-link', { 'sh-link--active': active === 'faq' }]}>FAQ</a>
      <a href="/support/about" class:list={['sh-link', { 'sh-link--active': active === 'about' }]}>About</a>
      <a href="/support/contact" class:list={['sh-link sh-cta', { 'sh-link--active': active === 'contact' }]}>Contact</a>
    </nav>
    <button class="sh-burger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="sh-mobile" aria-hidden="true">
    <a href="/support/services" class="sh-mobile-link">Services</a>
    <a href="/support/pricing" class="sh-mobile-link">Pricing</a>
    <a href="/support/work" class="sh-mobile-link">Clients</a>
    <a href="/support/faq" class="sh-mobile-link">FAQ</a>
    <a href="/support/about" class="sh-mobile-link">About</a>
    <a href="/support/contact" class="sh-mobile-cta">Contact</a>
  </div>
</header>

<style>
  .sh { padding: 1.5rem; position: relative; z-index: 100; opacity: 0; animation: shIn 0.8s ease 0.8s forwards; }
  .sh-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .sh-logo { font-size: 1.25rem; font-weight: 600; color: var(--color-foreground); text-decoration: none; letter-spacing: -0.02em; flex-shrink: 0; }
  .sh-dot { color: var(--color-brand); }
  .sh-nav { display: flex; gap: 1.5rem; align-items: center; }
  .sh-link { font-size: 0.8125rem; font-weight: 500; color: var(--color-muted); text-decoration: none; transition: color 0.2s ease; }
  .sh-link:hover, .sh-link--active { color: var(--color-foreground); }
  .sh-link--active { font-weight: 600; }
  .sh-cta { padding: 0.5rem 1rem; background: var(--color-foreground); color: white !important; border-radius: 0.375rem; transition: background-color 0.3s ease; }
  .sh-cta:hover { background: var(--color-brand); }
  .sh-cta.sh-link--active { background: var(--color-brand); }
  .sh-burger { display: none; flex-direction: column; gap: 4px; padding: 0.5rem; background: none; border: none; cursor: pointer; }
  .sh-burger span { display: block; width: 18px; height: 2px; background: var(--color-foreground); border-radius: 1px; transition: transform 0.3s ease, opacity 0.3s ease; }
  .sh-burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .sh-burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .sh-burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  .sh-mobile { display: none; padding: 1rem 1.5rem 2rem; max-width: 1200px; margin: 0 auto; }
  .sh-mobile[aria-hidden="false"] { display: block; }
  .sh-mobile-link { display: block; padding: 1rem 0; font-size: 0.9375rem; font-weight: 600; color: var(--color-foreground); text-decoration: none; border-bottom: 1px solid var(--color-divider); }
  .sh-mobile-cta { display: block; margin-top: 1rem; padding: 0.875rem; text-align: center; background: var(--color-brand); color: white; font-size: 0.875rem; font-weight: 600; text-decoration: none; border-radius: 0.375rem; }
  @keyframes shIn { from { opacity: 0; } to { opacity: 1; } }
  @media (prefers-reduced-motion: reduce) { .sh { animation: none; opacity: 1; } }
  @media (max-width: 768px) { .sh-nav { display: none; } .sh-burger { display: flex; } }
  @media (min-width: 769px) { .sh-mobile { display: none !important; } }
</style>

<script>
  const burger = document.querySelector('.sh-burger');
  const mobile = document.querySelector('.sh-mobile');
  if (burger && mobile) {
    burger.addEventListener('click', () => {
      const expanded = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!expanded));
      mobile.setAttribute('aria-hidden', String(expanded));
    });
  }
</script>
