<div class="cf-wrapper">
  <h2 class="cf-heading">Let's Build Something Exceptional</h2>
  <p class="cf-sub">Share your project details and we'll respond within 24 hours. No commitment required.</p>

  <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="cf-form">
    <input type="hidden" name="bot-field" />
    <input type="hidden" name="form-name" value="contact" />

    <div class="cf-grid">
      <div class="cf-field">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" required placeholder="Your name" />
      </div>
      <div class="cf-field">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" required placeholder="you@company.com" />
      </div>
      <div class="cf-field">
        <label for="company">Company</label>
        <input type="text" id="company" name="company" placeholder="Your company name" />
      </div>
      <div class="cf-field">
        <label for="service">Service Interest</label>
        <select id="service" name="service" required>
          <option value="" disabled selected>Select a service</option>
          <option value="custom-website">Custom Website</option>
          <option value="web-application">Web Application</option>
          <option value="headless-cms">Headless CMS</option>
          <option value="api-integration">API & Integration</option>
          <option value="not-sure">Not Sure Yet</option>
        </select>
      </div>
    </div>

    <button type="submit" class="cf-submit">Send Message</button>
  </form>
</div>

<style>
