<div class="cf-wrapper">
  <h2 class="cf-heading">Get Your Custom Quote</h2>
  <p class="cf-sub">Tell us about your project and we will respond with a transparent proposal within 24 hours. No commitment, no surprises.</p>

  <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="cf-form">
    <input type="hidden" name="bot-field" />
    <input type="hidden" name="form-name" value="contact" />

    <div class="cf-grid">
      <div class="cf-field">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" required placeholder="Your name" />
      </div>
      <div class="cf-field">
        <label for="email">Work Email</label>
        <input type="email" id="email" name="email" required placeholder="you@company.com" />
      </div>
      <div class="cf-field">
        <label for="company">Company</label>
        <input type="text" id="company" name="company" placeholder="Your company name" />
      </div>
      <div class="cf-field">
        <label for="role">Your Role</label>
        <select id="role" name="role">
          <option value="" disabled selected>Select your role</option>
          <option value="marketing">Marketing / Brand</option>
          <option value="it">IT / Technology</option>
          <option value="operations">Operations</option>
          <option value="c-level">C-Level / Director</option>
          <option value="procurement">Procurement</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="cf-field">
        <label for="service">What Do You Need?</label>
        <select id="service" name="service" required>
          <option value="" disabled selected>Select a service</option>
          <option value="custom-website">Custom Website</option>
          <option value="web-application">Web Application</option>
          <option value="headless-cms">Headless CMS</option>
          <option value="ecommerce">E-Commerce Platform</option>
          <option value="maintenance">Maintenance & Support</option>
          <option value="not-sure">Not Sure Yet</option>
        </select>
      </div>
      <div class="cf-field">
        <label for="budget">Budget Range</label>
        <select id="budget" name="budget">
          <option value="" disabled selected>Approximate budget</option>
          <option value="under-30k">Under MYR 30,000</option>
          <option value="30k-80k">MYR 30,000 – 80,000</option>
          <option value="80k-150k">MYR 80,000 – 150,000</option>
          <option value="150k-250k">MYR 150,000 – 250,000</option>
          <option value="over-250k">Over MYR 250,000</option>
          <option value="not-sure">Not sure yet</option>
        </select>
      </div>
      <div class="cf-field cf-field--full">
        <label for="timeline">Timeline</label>
        <select id="timeline" name="timeline">
          <option value="" disabled selected>When do you need this?</option>
          <option value="asap">As soon as possible</option>
          <option value="1-3-months">Within 1–3 months</option>
          <option value="3-6-months">3–6 months</option>
          <option value="planning">Just planning / exploring</option>
        </select>
      </div>
      <div class="cf-field cf-field--full">
        <label for="message">Project Brief (optional)</label>
        <textarea id="message" name="message" rows="3" placeholder="Tell us briefly about your project, goals, or any specific requirements"></textarea>
      </div>
    </div>

    <button type="submit" class="cf-submit">Send My Project Details</button>
    <p class="cf-note">We respond to every enquiry within 24 hours. Your data is never shared.</p>
  </form>
</div>

