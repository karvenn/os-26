---
import type { PortfolioProject } from '../data/portfolio';

interface Props {
  project: PortfolioProject;
  variant?: 'full' | 'half';
}

const { project, variant = 'half' } = Astro.props;
---

<div
  class:list={['pcard', `pcard--${variant}`]}
>
  <div class="pcard-image">
    <div class="pcard-placeholder">
      <span class="pcard-placeholder-label">{project.projectType}</span>
      <span class="pcard-placeholder-icon">{project.clientName.charAt(0)}</span>
    </div>
  </div>
  <div class="pcard-content">
    <span class="pcard-type">{project.projectType} &middot; {project.year}</span>
    <h3 class="pcard-name">{project.clientName}</h3>
    <p class="pcard-headline">{project.headline}</p>
    <div class="pcard-tech">
      {project.technologies.map((tech) => (
        <span class="tech-tag">{tech}</span>
      ))}
    </div>
  </div>
</div>

<style>
  .pcard {
    display: block;
    text-decoration: none;
    border-radius: 0.5rem;
    overflow: hidden;
    background: white;
    border: 1px solid var(--color-divider);
    transition: border-color 0.3s ease, transform 0.3s ease;
  }

  .pcard:hover {
    border-color: var(--color-brand);
    transform: translateY(-4px);
  }

  .pcard-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .pcard--full .pcard-image {
    aspect-ratio: 21 / 9;
  }

  .pcard-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-brand-light) 0%, #FDE8D8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pcard-placeholder {
    flex-direction: column;
    gap: 0.5rem;
  }

  .pcard-placeholder-label {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    opacity: 0.4;
  }

  .pcard-placeholder-icon {
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-brand);
    opacity: 0.15;
  }

  .pcard--full .pcard-placeholder-icon {
    font-size: 4rem;
  }

  .pcard-content {
    padding: 1.5rem;
  }

  .pcard-type {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    display: block;
    margin-bottom: 0.5rem;
  }

  .pcard-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .pcard-headline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .pcard-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tech-tag {
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    background: var(--color-surface);
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
  }
</style>
