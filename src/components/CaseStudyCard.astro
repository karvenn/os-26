---
import type { CaseStudy } from '../data/case-studies';

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props;
---

<div class="cs">
  <div class="cs-header">
    <span class="cs-label">Case Study</span>
    <h3 class="cs-name">{caseStudy.clientName}</h3>
    <p class="cs-project">{caseStudy.projectTitle}</p>
  </div>

  <div class="cs-body">
    <div class="cs-section">
      <h4 class="cs-subhead">The Challenge</h4>
      <p>{caseStudy.challenge}</p>
    </div>
    <div class="cs-section">
      <h4 class="cs-subhead">Our Solution</h4>
      <p>{caseStudy.solution}</p>
    </div>
  </div>

  <div class="cs-metrics">
    {caseStudy.metrics.map((metric) => (
      <div class="metric">
        <span
          class="metric-value"
          data-target={metric.value}
          data-decimals={metric.decimals || 0}
          data-suffix={metric.suffix}
        >
          0{metric.suffix}
        </span>
        <span class="metric-label">{metric.label}</span>
      </div>
    ))}
  </div>

  <blockquote class="cs-quote">
    <p>&ldquo;{caseStudy.testimonial.quote}&rdquo;</p>
    <footer>
      <strong>{caseStudy.testimonial.authorName}</strong>
      <span>{caseStudy.testimonial.authorTitle}, {caseStudy.testimonial.company}</span>
    </footer>
  </blockquote>
</div>

<style>
  .cs {
    background: white;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .cs:last-child {
    margin-bottom: 0;
  }

  .cs-header {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid var(--color-divider);
  }

  .cs-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brand);
    display: block;
    margin-bottom: 0.5rem;
  }

  .cs-name {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.01em;
  }

  .cs-project {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-top: 0.25rem;
  }

  .cs-body {
    padding: 2rem;
    display: grid;
    gap: 2rem;
  }

  .cs-subhead {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .cs-section p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .cs-metrics {
    padding: 2rem;
    background: var(--color-surface);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .metric {
    text-align: center;
  }

  .metric-value {
    display: block;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-brand);
    letter-spacing: -0.02em;
  }

  .metric-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-top: 0.25rem;
  }

  .cs-quote {
    padding: 2rem;
    border-top: 1px solid var(--color-divider);
  }

  .cs-quote p {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-foreground);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .cs-quote footer {
    display: flex;
    flex-direction: column;
  }

  .cs-quote strong {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .cs-quote footer span {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  @media (min-width: 768px) {
    .cs-body {
      grid-template-columns: 1fr 1fr;
    }
    .cs-metrics {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
