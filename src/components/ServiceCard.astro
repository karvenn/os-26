---
interface Props {
  icon: string;
  title: string;
  description: string;
  techNote: string;
}

const { icon, title, description, techNote } = Astro.props;

const iconPaths: Record<string, string> = {
  performance: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  application: 'M4 5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V5zm4 0v6h8V5H8zm0 8v6h8v-6H8z',
  cms: 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  integration: 'M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71',
};
---

<div class="card">
  <div class="card-icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d={iconPaths[icon] || iconPaths.performance} />
    </svg>
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  <span class="card-tech">{techNote}</span>
</div>

<style>
  .card {
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: background-color 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
  }

  .card:hover {
    background-color: var(--color-brand-light);
    border-color: transparent;
    transform: translateY(-2px);
  }

  .card-icon {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-brand);
    margin-bottom: 1.25rem;
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
  }

  .card-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .card-tech {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    opacity: 0.7;
  }
</style>
