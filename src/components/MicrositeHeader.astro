---
interface Props {
  active?: 'services' | 'solutions' | 'industries' | 'how-we-work' | 'work' | 'insights' | 'about' | 'contact';
}

const { active } = Astro.props;

const dropdowns = [
  {
    id: 'services',
    label: 'Services',
    href: '/custom/services',
    items: [
      { label: 'All Services', href: '/custom/services' },
      { label: 'Discovery & Strategy', href: '/custom/services/discovery' },
      { label: 'Custom Design', href: '/custom/services/design' },
      { label: 'Custom Development', href: '/custom/services/development' },
      { label: 'Migration & Deployment', href: '/custom/services/deployment' },
      { label: 'Maintenance & Support', href: '/custom/services/maintenance' },
      { label: 'Growth & Optimisation', href: '/custom/services/growth' },
    ],
  },
  {
    id: 'solutions',
    label: 'Solutions',
    href: '/custom/solutions',
    items: [
      { label: 'All Solutions', href: '/custom/solutions' },
      { label: 'Custom Website', href: '/custom/solutions/website' },
      { label: 'Custom CMS', href: '/custom/solutions/cms' },
      { label: 'Custom CRM', href: '/custom/solutions/crm' },
      { label: 'Custom eCommerce', href: '/custom/solutions/ecommerce' },
      { label: 'Contest Management', href: '/custom/solutions/contest-management' },
      { label: 'Survey & Reporting', href: '/custom/solutions/survey-dashboard' },
      { label: 'Booking System', href: '/custom/solutions/booking-system' },
      { label: 'Kiosk Sales Kit', href: '/custom/solutions/kiosk-sales-kit' },
    ],
  },
  {
    id: 'industries',
    label: 'Industries',
    href: '/custom/industries',
    items: [
      { label: 'All Industries', href: '/custom/industries' },
      { label: 'Property & Real Estate', href: '/custom/industries/property' },
      { label: 'Financial Services', href: '/custom/industries/financial-services' },
      { label: 'Manufacturing', href: '/custom/industries/manufacturing' },
      { label: 'Healthcare', href: '/custom/industries/healthcare' },
      { label: 'Education', href: '/custom/industries/education' },
      { label: 'Government', href: '/custom/industries/government' },
      { label: 'Retail & E-Commerce', href: '/custom/industries/retail-ecommerce' },
      { label: 'Hospitality', href: '/custom/industries/hospitality' },
    ],
  },
  {
    id: 'how-we-work',
    label: 'How We Work',
    href: '/custom/how-we-work',
    items: [
      { label: 'Overview', href: '/custom/how-we-work' },
      { label: 'Technologies', href: '/custom/technologies' },
      { label: 'Platforms', href: '/custom/platforms' },
      { label: 'Project Lifecycle', href: '/custom/process' },
    ],
  },
];
---

<header class="mh">
  <div class="mh-inner">
    <a href="/custom" class="mh-logo">Orangesoft<span class="mh-dot">.</span></a>

    <nav class="mh-nav" aria-label="Main navigation">
      {dropdowns.map((dd) => (
        <div class="mh-dropdown">
          <a
            href={dd.href}
            class:list={['mh-link', { 'mh-link--active': active === dd.id }]}
          >
            {dd.label}
            <svg class="mh-chevron" width="10" height="10" viewBox="0 0 10 10" fill="none">
              <path d="M2.5 3.75L5 6.25L7.5 3.75" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <div class="mh-panel">
            {dd.items.map((item, i) => (
              <a href={item.href} class:list={['mh-panel-link', { 'mh-panel-link--overview': i === 0 }]}>
                {item.label}
              </a>
            ))}
          </div>
        </div>
      ))}

      <a href="/custom/work" class:list={['mh-link', { 'mh-link--active': active === 'work' }]}>Work</a>
      <a href="/custom/insights" class:list={['mh-link', { 'mh-link--active': active === 'insights' }]}>Insights</a>
      <a href="/custom/about" class:list={['mh-link', { 'mh-link--active': active === 'about' }]}>About</a>
      <a href="/custom/contact" class:list={['mh-link mh-cta', { 'mh-link--active': active === 'contact' }]}>Contact</a>
    </nav>

    <button class="mh-burger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mh-mobile" aria-hidden="true">
    {dropdowns.map((dd) => (
      <details class="mh-mobile-group">
        <summary class="mh-mobile-label">{dd.label}</summary>
        <div class="mh-mobile-items">
          {dd.items.map((item) => (
            <a href={item.href} class="mh-mobile-link">{item.label}</a>
          ))}
        </div>
      </details>
    ))}
    <a href="/custom/work" class="mh-mobile-direct">Work</a>
    <a href="/custom/insights" class="mh-mobile-direct">Insights</a>
    <a href="/custom/about" class="mh-mobile-direct">About</a>
    <a href="/custom/pricing" class="mh-mobile-direct">Pricing</a>
    <a href="/custom/faq" class="mh-mobile-direct">FAQ</a>
    <a href="/custom/contact" class="mh-mobile-cta">Contact</a>
  </div>
</header>

<style>
  .mh {
    padding: 1.5rem;
    position: relative;
    z-index: 100;
    opacity: 0;
    animation: mhIn 0.8s ease 0.8s forwards;
  }

  .mh-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .mh-logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
    text-decoration: none;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }

  .mh-dot { color: var(--color-brand); }

  /* ── Desktop Nav ── */

  .mh-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .mh-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    padding: 0.5rem 0.625rem;
    border-radius: 0.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .mh-link:hover,
  .mh-link--active {
    color: var(--color-foreground);
  }

  .mh-link--active {
    font-weight: 600;
  }

  .mh-chevron {
    transition: transform 0.2s ease;
    opacity: 0.5;
  }

  .mh-cta {
    padding: 0.5rem 1rem;
    background: var(--color-foreground);
    color: white !important;
    border-radius: 0.375rem;
    margin-left: 0.25rem;
  }

  .mh-cta:hover { background: var(--color-brand); }
  .mh-cta.mh-link--active { background: var(--color-brand); }

  /* ── Dropdown ── */

  .mh-dropdown {
    position: relative;
  }

  .mh-panel {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    background: white;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    padding: 0.5rem 0;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 200;
  }

  .mh-dropdown:hover .mh-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mh-dropdown:hover .mh-chevron {
    transform: rotate(180deg);
  }

  .mh-panel-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .mh-panel-link:hover {
    color: var(--color-foreground);
    background: var(--color-surface);
  }

  .mh-panel-link--overview {
    font-weight: 600;
    color: var(--color-foreground);
    border-bottom: 1px solid var(--color-divider);
    margin-bottom: 0.25rem;
    padding-bottom: 0.625rem;
  }

  /* ── Hamburger ── */

  .mh-burger {
    display: none;
    flex-direction: column;
    gap: 4px;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
  }

  .mh-burger span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-foreground);
    border-radius: 1px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .mh-burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .mh-burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }
  .mh-burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ── Mobile Menu ── */

  .mh-mobile {
    display: none;
    padding: 1rem 1.5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .mh-mobile[aria-hidden="false"] {
    display: block;
  }

  .mh-mobile-group {
    border-bottom: 1px solid var(--color-divider);
  }

  .mh-mobile-label {
    display: block;
    padding: 1rem 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-foreground);
    cursor: pointer;
    list-style: none;
  }

  .mh-mobile-label::-webkit-details-marker { display: none; }

  .mh-mobile-items {
    padding-bottom: 1rem;
  }

  .mh-mobile-link {
    display: block;
    padding: 0.375rem 0 0.375rem 1rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
    text-decoration: none;
  }

  .mh-mobile-link:hover { color: var(--color-brand); }

  .mh-mobile-direct {
    display: block;
    padding: 1rem 0;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-foreground);
    text-decoration: none;
    border-bottom: 1px solid var(--color-divider);
  }

  .mh-mobile-cta {
    display: block;
    margin-top: 1rem;
    padding: 0.875rem;
    text-align: center;
    background: var(--color-brand);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.375rem;
  }

  @keyframes mhIn { from { opacity: 0; } to { opacity: 1; } }

  @media (prefers-reduced-motion: reduce) {
    .mh { animation: none; opacity: 1; }
    .mh-panel { transition: none; }
  }

  @media (max-width: 960px) {
    .mh-nav { display: none; }
    .mh-burger { display: flex; }
  }

  @media (min-width: 961px) {
    .mh-mobile { display: none !important; }
  }
</style>

<script>
  const burger = document.querySelector('.mh-burger');
  const mobile = document.querySelector('.mh-mobile');
  if (burger && mobile) {
    burger.addEventListener('click', () => {
      const expanded = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!expanded));
      mobile.setAttribute('aria-hidden', String(expanded));
    });
  }
</script>
