---
/**
 * Persistent CTA bar that appears after scrolling past the hero.
 * Sits at the bottom of the viewport on all pages.
 */
---

<div class="sticky-bar" id="sticky-bar" aria-hidden="true">
  <div class="sticky-bar__inner">
    <span class="sticky-bar__text">Your competitors are not waiting. Neither should you.</span>
    <a href="/custom/contact" class="sticky-bar__btn">Get Your Free Quote</a>
  </div>
</div>

<style>
  .sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 90;
    background: white;
    border-top: 1px solid var(--color-divider);
    padding: 0.75rem 1.5rem;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.sticky-bar.visible) {
    transform: translateY(0);
  }

  .sticky-bar__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .sticky-bar__text {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-foreground);
  }

  .sticky-bar__btn {
    display: inline-flex;
    padding: 0.625rem 1.5rem;
    background: var(--color-brand);
    color: white;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .sticky-bar__btn:hover {
    background: var(--color-brand-dark, #C45E0A);
  }

  @media (max-width: 768px) {
    .sticky-bar__text { display: none; }
    .sticky-bar__btn { width: 100%; justify-content: center; }
  }
</style>

<script>
  const bar = document.getElementById('sticky-bar');
  if (bar) {
    let shown = false;
    const observer = new IntersectionObserver(
      ([entry]) => {
        // Show after scrolling past the first section
        if (!entry.isIntersecting && !shown) {
          bar.classList.add('visible');
          shown = true;
        }
      },
      { threshold: 0 }
    );
    // Observe the first section on the page
    const hero = document.querySelector('section');
    if (hero) observer.observe(hero);

    // Hide when footer is visible
    const footer = document.querySelector('footer');
    if (footer) {
      const footerObs = new IntersectionObserver(
        ([entry]) => {
          bar.classList.toggle('visible', !entry.isIntersecting && shown);
        },
        { threshold: 0 }
      );
      footerObs.observe(footer);
    }
  }
</script>
