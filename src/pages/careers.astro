---
import Layout from '../layouts/Layout.astro';
import Animations from '../components/Animations.astro';

const openings = [
  {
    title: 'Senior Frontend Developer',
    type: 'Full-time',
    location: 'Kuala Lumpur / Remote',
    description: 'Build high-performance frontends with NuxtJS and Vue.js for corporate clients. 3+ years experience required.',
  },
  {
    title: 'Laravel Backend Developer',
    type: 'Full-time',
    location: 'Kuala Lumpur / Remote',
    description: 'Architect and build robust backend systems, APIs, and integrations with Laravel. 2+ years experience required.',
  },
  {
    title: 'UI/UX Designer',
    type: 'Full-time',
    location: 'Kuala Lumpur',
    description: 'Design conversion-focused interfaces for corporate websites and web applications. Figma proficiency required.',
  },
  {
    title: 'Project Manager',
    type: 'Full-time',
    location: 'Kuala Lumpur',
    description: 'Manage client relationships and project delivery for our custom development division. Agency experience preferred.',
  },
];

const perks = [
  { title: 'Remote flexibility', desc: 'Work from our KL office or remotely — we trust you to deliver great work wherever you are.' },
  { title: 'Meaningful projects', desc: 'Build real products for real businesses. No throwaway marketing sites — every project matters.' },
  { title: 'Modern stack', desc: 'NuxtJS, Laravel, Strapi, Tailwind CSS, GitHub, Vercel. We invest in tools that make your work better.' },
  { title: 'Growth budget', desc: 'Annual learning budget for conferences, courses, and certifications. Your growth is our growth.' },
  { title: 'Small team, big impact', desc: 'Your work ships to production, your voice shapes decisions, and your contributions are visible.' },
  { title: 'No overtime culture', desc: 'We plan projects realistically. Sustainable pace delivers better work than heroic sprints.' },
];
---

<Layout
  title="Careers at Orangesoft — Join Our Team"
  description="Join Orangesoft. We are looking for designers, developers, and project managers who want to build meaningful digital products for corporate clients."
>
  <header class="co-header">
    <div class="co-header-inner">
      <a href="/" class="logo">Orangesoft<span class="dot">.</span></a>
      <nav class="co-nav">
        <a href="/about" class="co-nav-link">About</a>
        <a href="/careers" class="co-nav-link co-nav-link--active">Careers</a>
        <a href="/contact" class="co-nav-link">Contact</a>
      </nav>
    </div>
  </header>

  <section class="hero">
    <div class="inner">
      <h1 class="hero-title">Build Things<br />That Matter</h1>
      <p class="hero-lead">
        We are a small, focused team that builds custom digital solutions for corporate clients across Southeast Asia. If you care about craft, ownership, and working on projects that make a real difference, we would like to hear from you.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="inner">
      <h2 class="section-title">Why Orangesoft</h2>
      <div class="perks" data-animate="stagger">
        {perks.map(perk => (
          <div class="perk">
            <h3>{perk.title}</h3>
            <p>{perk.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="inner">
      <h2 class="section-title">Open Positions</h2>
      <p class="section-sub">Current opportunities at Orangesoft. Do not see your role? Send us your CV anyway — we are always open to exceptional people.</p>
      <div class="openings" data-animate="fade-up">
        {openings.map(job => (
          <a href={`mailto:careers@orangesoft.com.my?subject=Application: ${job.title}`} class="job">
            <div class="job-main">
              <h3 class="job-title">{job.title}</h3>
              <p class="job-desc">{job.description}</p>
            </div>
            <div class="job-meta">
              <span class="job-type">{job.type}</span>
              <span class="job-location">{job.location}</span>
            </div>
            <span class="job-apply">Apply &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="inner" data-animate="fade-up">
      <div class="general">
        <h2>Do Not See Your Role?</h2>
        <p>We are always interested in meeting talented people. Send your CV and a brief note about what you would like to work on to <a href="mailto:careers@orangesoft.com.my">careers@orangesoft.com.my</a>.</p>
      </div>
    </div>
  </section>

  <footer class="co-footer">
    <div class="co-footer-inner">
      <a href="/" class="footer-logo">Orangesoft<span class="dot">.</span></a>
      <nav class="footer-nav">
        <a href="/about">About</a>
        <a href="/careers">Careers</a>
        <a href="/contact">Contact</a>
      </nav>
      <p class="footer-copy">&copy; 2026 Orangesoft. All rights reserved.</p>
    </div>
  </footer>

  <Animations />
</Layout>

<style>
  .co-header { padding: 2rem 1.5rem; }
  .co-header-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
  .logo { font-size: 1.25rem; font-weight: 600; color: var(--color-foreground); text-decoration: none; letter-spacing: -0.02em; }
  .dot { color: var(--color-brand); }
  .co-nav { display: flex; gap: 1.5rem; }
  .co-nav-link { font-size: 0.8125rem; font-weight: 500; color: var(--color-muted); text-decoration: none; transition: color 0.3s ease; }
  .co-nav-link:hover, .co-nav-link--active { color: var(--color-foreground); }
  .co-nav-link--active { font-weight: 600; }

  .section { padding: 5rem 1.5rem; }
  .inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  .hero { padding: 4rem 1.5rem 3rem; }
  .hero-title { font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; color: var(--color-foreground); margin-bottom: 1.25rem; }
  .hero-lead { font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px; }

  .section-title { font-size: 2rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
  .section-sub { font-size: 1rem; color: var(--color-muted); margin-bottom: 2.5rem; max-width: 640px; }

  .perks { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .perk { padding: 1.75rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .perk h3 { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; }
  .perk p { font-size: 0.8125rem; line-height: 1.65; color: var(--color-muted); }

  .openings { display: flex; flex-direction: column; gap: 1rem; }
  .job { display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 2rem; padding: 1.5rem 2rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; text-decoration: none; transition: border-color 0.3s ease, transform 0.3s ease; }
  .job:hover { border-color: var(--color-brand); transform: translateY(-2px); }
  .job-title { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.25rem; }
  .job-desc { font-size: 0.8125rem; color: var(--color-muted); line-height: 1.5; }
  .job-meta { display: flex; flex-direction: column; gap: 0.25rem; text-align: right; }
  .job-type { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); }
  .job-location { font-size: 0.75rem; color: var(--color-muted); }
  .job-apply { font-size: 0.8125rem; font-weight: 600; color: var(--color-brand); white-space: nowrap; }

  .general { text-align: center; max-width: 560px; margin: 0 auto; }
  .general h2 { font-size: 1.75rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 1rem; letter-spacing: -0.02em; }
  .general p { font-size: 1rem; line-height: 1.7; color: var(--color-muted); }
  .general a { color: var(--color-brand); text-decoration: underline; text-underline-offset: 2px; }

  .co-footer { padding: 3rem 1.5rem; border-top: 1px solid var(--color-divider); }
  .co-footer-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; }
  .footer-logo { font-size: 1rem; font-weight: 600; color: var(--color-foreground); text-decoration: none; }
  .footer-nav { display: flex; gap: 1.5rem; }
  .footer-nav a { font-size: 0.8125rem; color: var(--color-muted); text-decoration: none; transition: color 0.3s ease; }
  .footer-nav a:hover { color: var(--color-foreground); }
  .footer-copy { font-size: 0.75rem; color: var(--color-muted); }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .perks { grid-template-columns: 1fr; }
    .job { grid-template-columns: 1fr; gap: 1rem; }
    .job-meta { text-align: left; flex-direction: row; gap: 0.75rem; }
    .co-footer-inner { flex-direction: column; text-align: center; }
  }
</style>
