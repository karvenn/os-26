---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../../components/MicrositeFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import FaqItem from '../../../components/FaqItem.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import TrustStrip from '../../../components/TrustStrip.astro';
import RelatedWork from '../../../components/RelatedWork.astro';
import PricingTeaser from '../../../components/PricingTeaser.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://orangesoft.com.my/custom/services' },
    { '@type': 'ListItem', position: 3, name: 'Custom Development', item: 'https://orangesoft.com.my/custom/services/development' },
  ],
};
---

<Layout
  title="Custom Development | Orangesoft Custom"
  description="Frontend engineering with NuxtJS, backend systems in Laravel, API development, and third-party integrations. High-performance custom web applications built by a Malaysian agency with 19+ years of experience."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="services" />
  <Breadcrumb items={[
    { label: 'Home', href: '/custom' },
    { label: 'Services', href: '/custom/services' },
    { label: 'Custom Development' }
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <span class="hero-label">Custom Development</span>
      <h1 class="hero-title">Engineering That<br />Scales With You</h1>
      <p class="hero-lead">
        We build web applications that perform under pressure, scale as you grow, and remain maintainable years after launch. Every architecture decision, every line of code, and every deployment pipeline is designed for longevity.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- What We Deliver -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="What We Deliver"
        subtitle="Full-stack development capabilities covering every layer of your application."
      />
      <div class="deliverables-grid" data-animate="stagger">
        <div class="deliverable">
          <span class="deliverable-num">01</span>
          <h3 class="deliverable-title">Frontend Development</h3>
          <p class="deliverable-desc">Server-rendered, statically generated, or hybrid applications built with NuxtJS. Pixel-perfect implementation of your designs with exceptional Core Web Vitals scores and full accessibility compliance.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">02</span>
          <h3 class="deliverable-title">Backend Development</h3>
          <p class="deliverable-desc">Robust application logic, authentication, authorisation, and business rules built with Laravel. Clean architecture that separates concerns and makes complex systems comprehensible.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">03</span>
          <h3 class="deliverable-title">API Development</h3>
          <p class="deliverable-desc">RESTful and GraphQL APIs with comprehensive documentation, versioning, and rate limiting. Built to serve your frontend, mobile apps, and third-party consumers from a single source of truth.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">04</span>
          <h3 class="deliverable-title">Database Architecture</h3>
          <p class="deliverable-desc">Schema design, query optimisation, migration strategies, and data integrity constraints. We structure your data for performance at scale and design migration paths for zero-downtime deployments.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">05</span>
          <h3 class="deliverable-title">CMS Integration</h3>
          <p class="deliverable-desc">Headless content management with Strapi, giving your marketing team full control over content while preserving the performance and flexibility of a custom frontend.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">06</span>
          <h3 class="deliverable-title">Third-Party Integrations</h3>
          <p class="deliverable-desc">Payment gateways, CRM systems, marketing platforms, analytics tools, and enterprise software. We connect your application to the tools your business already depends on.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Our Development Approach"
        subtitle="Four engineering practices that ensure every project ships on time and stays maintainable."
      />
      <div class="approach-grid" data-animate="stagger">
        <div class="approach-card">
          <div class="approach-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z" />
            </svg>
          </div>
          <h3 class="approach-title">Iterative Sprints</h3>
          <p class="approach-desc">We work in two-week sprints with clear deliverables and demo sessions at the end of each cycle. You see progress continuously, provide feedback early, and steer the project with confidence rather than waiting months for a big reveal.</p>
        </div>
        <div class="approach-card">
          <div class="approach-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 11 12 14 22 4" />
              <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
            </svg>
          </div>
          <h3 class="approach-title">Test-Driven</h3>
          <p class="approach-desc">Automated tests are written alongside feature code, not as an afterthought. Unit tests, integration tests, and end-to-end tests ensure your application works reliably today and continues to work as new features are added.</p>
        </div>
        <div class="approach-card">
          <div class="approach-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
              <circle cx="8.5" cy="7" r="4" />
              <line x1="20" y1="8" x2="20" y2="14" />
              <line x1="23" y1="11" x2="17" y2="11" />
            </svg>
          </div>
          <h3 class="approach-title">Code Reviews</h3>
          <p class="approach-desc">Every pull request is reviewed by a senior engineer before merging. This catches bugs early, enforces coding standards, and ensures knowledge is shared across the team so no single person becomes a bottleneck.</p>
        </div>
        <div class="approach-card">
          <div class="approach-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
          </div>
          <h3 class="approach-title">CI/CD Pipeline</h3>
          <p class="approach-desc">Continuous integration and deployment means code is automatically tested, built, and deployed to staging with every commit. Production releases are one-click operations with automatic rollback capability.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Technology -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Technology Highlights"
        subtitle="We build with proven, open-source technologies trusted by enterprises worldwide."
      />
      <div class="tech-grid">
        <div class="tech-card">
          <h3 class="tech-title">NuxtJS</h3>
          <span class="tech-role">Frontend Framework</span>
          <p class="tech-desc">Vue.js-based framework with server-side rendering, static generation, and hybrid capabilities. Delivers exceptional Core Web Vitals scores, SEO performance, and developer experience. The foundation of every frontend we build.</p>
        </div>
        <div class="tech-card">
          <h3 class="tech-title">Laravel</h3>
          <span class="tech-role">Backend Framework</span>
          <p class="tech-desc">The most popular PHP framework, trusted by enterprises for its elegant syntax, robust ecosystem, and comprehensive tooling. Powers our APIs, business logic, authentication, and background job processing.</p>
        </div>
        <div class="tech-card">
          <h3 class="tech-title">Strapi</h3>
          <span class="tech-role">Headless CMS</span>
          <p class="tech-desc">Open-source headless CMS that gives your content team an intuitive editing interface while preserving the performance and flexibility of a decoupled frontend. Fully customisable to your content model.</p>
        </div>
      </div>
      <div class="tech-cta">
        <a href="/custom/technologies" class="tech-link">
          Explore our full technology stack
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Who This Is For"
        subtitle="Our development service is the right fit if any of these situations sound familiar."
      />
      <div class="audience-grid">
        <div class="audience-card">
          <h3 class="audience-title">Outgrowing Templates</h3>
          <p class="audience-desc">Your WordPress, Wix, or Squarespace site was fine when you started, but now you're fighting the platform more than using it. You need custom functionality, better performance, and a codebase that does not limit your growth.</p>
        </div>
        <div class="audience-card">
          <h3 class="audience-title">Replacing Legacy Systems</h3>
          <p class="audience-desc">You have an ageing web application built on outdated technology. It works but it is slow, difficult to maintain, and increasingly expensive to host. You need a modern rebuild that preserves your business logic while dramatically improving performance and maintainability.</p>
        </div>
        <div class="audience-card">
          <h3 class="audience-title">Building New Applications</h3>
          <p class="audience-desc">You have a new product, internal tool, or customer-facing platform that doesn't fit any off-the-shelf solution. You need a development partner who can translate complex business requirements into clean, scalable software.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions Link -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <div class="solutions-cta">
        <h2 class="solutions-cta-title">Explore Our Proven Solutions</h2>
        <p class="solutions-cta-desc">
          For common business challenges like contest platforms, e-commerce, CRM systems, and booking engines, we offer proven solutions refined over dozens of implementations. Same technology, same quality, faster delivery, and lower cost.
        </p>
        <a href="/custom/solutions" class="solutions-cta-link">
          Explore our proven solutions
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Frequently Asked Questions"
        subtitle="Common questions about our development service."
      />
      <div class="faq-list" data-animate="fade-up">
        <FaqItem
          question="What does your development process look like?"
          answer="We begin with a technical discovery phase where we define the architecture, agree on technology choices, and create a detailed sprint plan. Development proceeds in two-week sprints, each ending with a demo of completed features on a staging environment. You have visibility into the codebase, task board, and progress dashboard throughout the project. After development, we conduct thorough QA testing, performance optimisation, and a structured handover before launch."
        />
        <FaqItem
          question="Why NuxtJS and Laravel instead of other technologies?"
          answer="We chose this stack after years of evaluating alternatives across dozens of projects. NuxtJS delivers the best combination of performance, SEO, and developer experience for frontend applications. Laravel provides a mature, well-documented backend framework with an extensive ecosystem of packages. Together, they allow us to build faster, maintain code more efficiently, and onboard new developers quickly. That said, if your project has specific constraints that require different technologies, we are transparent about whether we are the right fit."
        />
        <FaqItem
          question="Who owns the code after the project is complete?"
          answer="You do. Completely. We transfer the entire codebase, documentation, deployment configurations, and all associated assets to your organisation. There are no licensing fees, no vendor lock-in, and no proprietary dependencies. You can hire your own team or another agency to maintain and extend the project at any time. We build specifically to make that transition seamless."
        />
        <FaqItem
          question="Do you provide ongoing maintenance and support?"
          answer="Yes. We offer optional maintenance retainers that include security updates, performance monitoring, bug fixes, and minor feature additions. Most clients start with a retainer for the first 6 to 12 months after launch while they build internal familiarity with the codebase. We also provide comprehensive documentation and knowledge transfer sessions to ensure your team can operate independently whenever they are ready."
        />
      </div>
    </div>
  </section>

  <RelatedWork />
  <PricingTeaser />
  <CtaBand heading="Ready to build something that lasts?" buttonText="Start a Development Project" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-label {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1.25rem;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.3s forwards;
  }

  /* Deliverables */
  .deliverables-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .deliverable {
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }

  .deliverable:hover {
    border-color: var(--color-brand);
  }

  .deliverable-num {
    font-size: 0.6875rem;
    font-weight: 300;
    color: var(--color-brand);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.75rem;
  }

  .deliverable-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.625rem;
  }

  .deliverable-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* Approach */
  .approach-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .approach-card {
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }

  .approach-card:hover {
    border-color: var(--color-brand);
  }

  .approach-icon {
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brand-light);
    border-radius: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .approach-icon svg {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-brand);
  }

  .approach-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.625rem;
  }

  .approach-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* Technology */
  .tech-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .tech-card {
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }

  .tech-card:hover {
    border-color: var(--color-brand);
  }

  .tech-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.25rem;
  }

  .tech-role {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-brand);
    margin-bottom: 0.75rem;
  }

  .tech-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  .tech-cta {
    text-align: center;
    padding-top: 1rem;
  }

  .tech-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-brand);
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .tech-link:hover {
    gap: 0.75rem;
  }

  .tech-link svg {
    width: 1rem;
    height: 1rem;
  }

  /* Audience */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .audience-card {
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }

  .audience-card:hover {
    border-color: var(--color-brand);
  }

  .audience-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.625rem;
  }

  .audience-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* Solutions CTA */
  .solutions-cta {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  .solutions-cta-title {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .solutions-cta-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .solutions-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-brand);
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .solutions-cta-link:hover {
    gap: 0.75rem;
  }

  .solutions-cta-link svg {
    width: 1rem;
    height: 1rem;
  }

  /* FAQ */
  .faq-list {
    max-width: 720px;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-label, .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .deliverables-grid { grid-template-columns: 1fr; }
    .approach-grid { grid-template-columns: 1fr; }
    .tech-grid { grid-template-columns: 1fr; }
    .audience-grid { grid-template-columns: 1fr; }
    .solutions-cta { padding: 2rem; }
    .solutions-cta-title { font-size: 1.5rem; }
  }
</style>
