---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../../components/MicrositeFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import FaqItem from '../../../components/FaqItem.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import TrustStrip from '../../../components/TrustStrip.astro';
import RelatedWork from '../../../components/RelatedWork.astro';
import PricingTeaser from '../../../components/PricingTeaser.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://orangesoft.com.my/custom/services' },
    { '@type': 'ListItem', position: 3, name: 'Maintenance & Support', item: 'https://orangesoft.com.my/custom/services/maintenance' },
  ],
};
---

<Layout
  title="Maintenance & Support | Orangesoft Custom"
  description="Ongoing security updates, performance monitoring, content changes, and priority support. Keep your platform healthy with maintenance packages from a Malaysian web agency."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="services" />
  <Breadcrumb items={[
    { label: 'Home', href: '/custom' },
    { label: 'Services', href: '/custom/services' },
    { label: 'Maintenance & Support' }
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <span class="hero-label">Maintenance & Support</span>
      <h1 class="hero-title">Peace of Mind,<br />Month After Month</h1>
      <p class="hero-lead">
        Ongoing security updates, performance monitoring, content changes, and priority support. Your platform stays healthy, your team stays confident, and you never worry about what is happening behind the scenes.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- What We Deliver -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="What We Deliver"
        subtitle="Comprehensive ongoing care that keeps your platform secure, fast, and up to date."
      />
      <div class="deliverables-grid" data-animate="stagger">
        <div class="deliverable">
          <span class="deliverable-num">01</span>
          <h3 class="deliverable-title">Security Patches & Updates</h3>
          <p class="deliverable-desc">Proactive application of security patches, framework updates, and dependency upgrades. We test every update in a staging environment before deploying to production, ensuring your site stays secure without unexpected breakage.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">02</span>
          <h3 class="deliverable-title">Performance Monitoring & Alerts</h3>
          <p class="deliverable-desc">24/7 uptime monitoring, server health tracking, and Core Web Vitals measurement. Automated alerts notify our team of anomalies before they affect your users, and we respond to critical issues within one hour.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">03</span>
          <h3 class="deliverable-title">Content Updates & Changes</h3>
          <p class="deliverable-desc">Minor content updates, page edits, image replacements, and layout adjustments handled by our team. Up to 4 hours of content work per month is included in standard packages, with additional hours available on demand.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">04</span>
          <h3 class="deliverable-title">Priority Support Channel</h3>
          <p class="deliverable-desc">Direct access to the engineering team that built your platform via a dedicated support channel. No ticket queues, no handoffs to junior staff. Your questions are answered by people who know your codebase intimately.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">05</span>
          <h3 class="deliverable-title">Monthly Health Reports</h3>
          <p class="deliverable-desc">Clear, jargon-free reports covering uptime, performance metrics, security status, completed updates, and recommendations. You always know the state of your platform without needing to ask.</p>
        </div>
        <div class="deliverable">
          <span class="deliverable-num">06</span>
          <h3 class="deliverable-title">Quarterly Strategic Reviews</h3>
          <p class="deliverable-desc">Scheduled sessions to review platform performance, discuss upcoming business needs, and plan improvements. We align maintenance work with your growth strategy so your platform evolves alongside your business.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Our Maintenance Approach"
        subtitle="Three principles that guide how we care for your platform."
      />
      <div class="approach-grid" data-animate="stagger">
        <div class="approach-card">
          <div class="approach-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
          </div>
          <h3 class="approach-title">Prevent, Don't React</h3>
          <p class="approach-desc">Proactive monitoring catches issues before your users do. We apply security patches promptly, monitor performance trends, and address degradation early. Reactive maintenance costs more, takes longer, and damages trust.</p>
        </div>
        <div class="approach-card">
          <div class="approach-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </svg>
          </div>
          <h3 class="approach-title">Transparent Reporting</h3>
          <p class="approach-desc">Monthly reports in plain language tell you exactly what was done, what the metrics look like, and what we recommend next. No technical jargon, no vague status updates. You always know the health of your platform.</p>
        </div>
        <div class="approach-card">
          <div class="approach-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="2" x2="12" y2="22" />
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg>
          </div>
          <h3 class="approach-title">Scale With You</h3>
          <p class="approach-desc">Packages grow or shrink as your needs change. Launching a major campaign? Scale up support. Quiet quarter? Scale down. Month-to-month flexibility after the initial commitment means you only pay for what you need.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Who This Is For"
        subtitle="Our maintenance service is the right fit if you recognise any of these situations."
      />
      <div class="audience-grid">
        <div class="audience-card">
          <h3 class="audience-title">Running a Custom Website That Needs Ongoing Care</h3>
          <p class="audience-desc">Your custom-built platform requires regular security updates, performance tuning, and occasional content changes. Without dedicated attention, small issues accumulate into expensive problems.</p>
        </div>
        <div class="audience-card">
          <h3 class="audience-title">Teams Without In-House Technical Resources</h3>
          <p class="audience-desc">Your organisation does not have a dedicated web development team, and hiring one is neither practical nor cost-effective. You need reliable external expertise available when you need it, without the overhead of full-time staff.</p>
        </div>
        <div class="audience-card">
          <h3 class="audience-title">Organisations Requiring Compliance and Uptime Guarantees</h3>
          <p class="audience-desc">Your industry demands strict uptime requirements, regular security audits, or compliance with data protection regulations. Our maintenance packages include the monitoring, documentation, and response times your compliance team requires.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Adjacent Services -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Where This Fits"
        subtitle="Maintenance and support follows deployment and precedes growth optimisation in our service lifecycle."
      />
      <div class="adjacent-grid">
        <a href="/custom/services/deployment" class="adjacent-card adjacent-card--prev">
          <span class="adjacent-phase">Previous Phase</span>
          <h3 class="adjacent-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Migration & Deployment
          </h3>
          <p class="adjacent-desc">Data migration, URL redirects, team training, and zero-downtime deployment for a seamless platform transition.</p>
        </a>
        <a href="/custom/services/growth" class="adjacent-card adjacent-card--next">
          <span class="adjacent-phase">Next Phase</span>
          <h3 class="adjacent-title">Growth & Optimisation
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </h3>
          <p class="adjacent-desc">SEO refinement, conversion rate optimisation, A/B testing, and strategic guidance to maximise your platform's ROI.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="Frequently Asked Questions"
        subtitle="Common questions about our maintenance service."
      />
      <div class="faq-list" data-animate="fade-up">
        <FaqItem
          question="What do monthly packages cost?"
          answer="Maintenance packages start from MYR 1,500 per month for standard websites. Complex applications with multiple integrations typically range from MYR 3,000 to MYR 5,000 per month. We tailor the package to your specific platform and requirements during an initial assessment."
        />
        <FaqItem
          question="What is included?"
          answer="Security patches, performance monitoring, uptime alerts, minor content updates (up to 4 hours per month), priority email support, and a monthly health report. Quarterly strategic reviews are included in all packages. Additional development hours and emergency support are available on demand at agreed rates."
        />
        <FaqItem
          question="Can we scale up or down?"
          answer="Yes. Packages are month-to-month after an initial 3-month commitment. You can increase or decrease scope as your needs change with 30 days notice. Many clients scale up during product launches or marketing campaigns and return to their standard package afterwards."
        />
        <FaqItem
          question="Do you maintain sites you didn't build?"
          answer="Yes, provided the site is built on technologies we support: NuxtJS, Laravel, Strapi, and WordPress. We begin with a technical audit to assess the current state of the codebase, infrastructure, and security posture. The audit findings inform the maintenance package scope and identify any immediate issues that need resolution."
        />
      </div>
    </div>
  </section>

  <RelatedWork />
  <PricingTeaser />
  <CtaBand heading="Ready for worry-free platform care?" buttonText="Start a Maintenance Plan" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-label {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1.25rem;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.3s forwards;
  }

  /* Deliverables */
  .deliverables-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .deliverable {
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }

  .deliverable:hover {
    border-color: var(--color-brand);
  }

  .deliverable-num {
    font-size: 0.6875rem;
    font-weight: 300;
    color: var(--color-brand);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.75rem;
  }

  .deliverable-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.625rem;
  }

  .deliverable-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* Approach */
  .approach-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .approach-card {
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }

  .approach-card:hover {
    border-color: var(--color-brand);
  }

  .approach-icon {
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brand-light);
    border-radius: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .approach-icon svg {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-brand);
  }

  .approach-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.625rem;
  }

  .approach-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* Audience */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .audience-card {
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }

  .audience-card:hover {
    border-color: var(--color-brand);
  }

  .audience-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.625rem;
  }

  .audience-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* Adjacent Services */
  .adjacent-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .adjacent-card {
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
    text-decoration: none;
    display: block;
  }

  .adjacent-card:hover {
    border-color: var(--color-brand);
  }

  .adjacent-phase {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    margin-bottom: 0.75rem;
  }

  .adjacent-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.625rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .adjacent-title svg {
    width: 1rem;
    height: 1rem;
    color: var(--color-brand);
  }

  .adjacent-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* FAQ */
  .faq-list {
    max-width: 720px;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-label, .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .deliverables-grid { grid-template-columns: 1fr; }
    .approach-grid { grid-template-columns: 1fr; }
    .audience-grid { grid-template-columns: 1fr; }
    .adjacent-grid { grid-template-columns: 1fr; }
  }
</style>
