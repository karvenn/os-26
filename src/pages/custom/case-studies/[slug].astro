---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../../components/MicrositeFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Animations from '../../../components/Animations.astro';
import { caseStudies, type CaseStudy } from '../../../data/case-studies';

export function getStaticPaths() {
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: { caseStudy: cs },
  }));
}

interface Props {
  caseStudy: CaseStudy;
}

const { caseStudy } = Astro.props;
const otherStudies = caseStudies.filter((cs) => cs.slug !== caseStudy.slug);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Work', item: 'https://orangesoft.com.my/custom/work' },
    { '@type': 'ListItem', position: 3, name: caseStudy.clientName, item: `https://orangesoft.com.my/custom/case-studies/${caseStudy.slug}` },
  ],
};
---

<Layout
  title={`${caseStudy.clientName} \u2014 Case Study | Orangesoft`}
  description={caseStudy.challenge.slice(0, 155)}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="work" />
  <Breadcrumb items={[
    { label: 'Home', href: '/custom' },
    { label: 'Work', href: '/custom/work' },
    { label: caseStudy.clientName },
  ]} />

  <!-- Hero -->
  <section class="cs-hero">
    <div class="section-inner">
      <span class="cs-label">Case Study</span>
      <h1 class="cs-title">{caseStudy.clientName}</h1>
      <p class="cs-project">{caseStudy.projectTitle}</p>
      <div class="cs-tags">
        {caseStudy.technologies.map((t) => <span class="tag">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- Metrics Bar -->
  <section class="metrics-bar">
    <div class="metrics-inner">
      {caseStudy.metrics.map((m) => (
        <div class="metric">
          <span class="metric-val" data-target={m.value} data-decimals={m.decimals || 0} data-suffix={m.suffix}>0{m.suffix}</span>
          <span class="metric-label">{m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Challenge & Solution -->
  <section class="section">
    <div class="section-inner cs-body">
      <div class="cs-col" data-animate="fade-up">
        <h2>The Challenge</h2>
        <p>{caseStudy.challenge}</p>
      </div>
      <div class="cs-col" data-animate="fade-up">
        <h2>Our Solution</h2>
        <p>{caseStudy.solution}</p>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <blockquote class="testimonial">
        <p>&ldquo;{caseStudy.testimonial.quote}&rdquo;</p>
        <footer>
          <strong>{caseStudy.testimonial.authorName}</strong>
          <span>{caseStudy.testimonial.authorTitle}, {caseStudy.testimonial.company}</span>
        </footer>
      </blockquote>
    </div>
  </section>

  <CtaBand heading="Want results like these?" buttonText="Start Your Project" buttonHref="/custom/contact" />

  <!-- Related Case Studies -->
  {otherStudies.length > 0 && (
    <section class="section">
      <div class="section-inner">
        <h2 class="related-heading">More Case Studies</h2>
        <div class="related-grid" data-animate="stagger">
          {otherStudies.map((cs) => (
            <a href={`/custom/case-studies/${cs.slug}`} class="related-card">
              <span class="related-label">{cs.projectTitle}</span>
              <h3>{cs.clientName}</h3>
              <p>{cs.metrics[0].value}{cs.metrics[0].suffix} {cs.metrics[0].label}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  .cs-hero { padding: 3rem 1.5rem 4rem; border-bottom: 1px solid var(--color-divider); }
  .cs-label { display: inline-block; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); margin-bottom: 1rem; opacity: 0; animation: slideUp 0.6s ease 1s forwards; }
  .cs-title { font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; color: var(--color-foreground); margin-bottom: 0.5rem; opacity: 0; animation: slideUp 0.7s ease 1.1s forwards; }
  .cs-project { font-size: 1.125rem; color: var(--color-muted); margin-bottom: 1.5rem; opacity: 0; animation: slideUp 0.7s ease 1.2s forwards; }
  .cs-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; opacity: 0; animation: fadeIn 0.6s ease 1.4s forwards; }
  .tag { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); background: var(--color-surface); border: 1px solid var(--color-divider); padding: 0.3rem 0.75rem; border-radius: 2rem; }

  .metrics-bar { padding: 3rem 1.5rem; background: var(--color-brand-light); }
  .metrics-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; text-align: center; }
  .metric-val { display: block; font-size: 2.5rem; font-weight: 700; color: var(--color-brand); letter-spacing: -0.02em; }
  .metric-label { display: block; font-size: 0.75rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted); margin-top: 0.25rem; }

  .cs-body { display: grid; gap: 3rem; }
  .cs-col h2 { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-foreground); margin-bottom: 1rem; }
  .cs-col p { font-size: 1rem; line-height: 1.8; color: var(--color-muted); }

  .testimonial { max-width: 720px; margin: 0 auto; text-align: center; }
  .testimonial p { font-size: 1.25rem; line-height: 1.7; color: var(--color-foreground); font-style: italic; margin-bottom: 1.5rem; }
  .testimonial footer { display: flex; flex-direction: column; align-items: center; }
  .testimonial strong { font-size: 0.9375rem; font-weight: 600; color: var(--color-foreground); font-style: normal; }
  .testimonial footer span { font-size: 0.8125rem; color: var(--color-muted); font-style: normal; }

  .related-heading { font-size: 1.5rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 2rem; }
  .related-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .related-card { display: block; padding: 1.5rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; text-decoration: none; transition: border-color 0.3s ease, transform 0.3s ease; }
  .related-card:hover { border-color: var(--color-brand); transform: translateY(-2px); }
  .related-label { display: block; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); margin-bottom: 0.375rem; }
  .related-card h3 { font-size: 1.125rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.375rem; }
  .related-card p { font-size: 0.8125rem; color: var(--color-muted); }

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .cs-label, .cs-title, .cs-project, .cs-tags { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .cs-title { font-size: 2rem; }
    .metrics-inner { grid-template-columns: repeat(2, 1fr); }
    .cs-body { grid-template-columns: 1fr; }
    .testimonial p { font-size: 1.0625rem; }
    .related-grid { grid-template-columns: 1fr; }
  }
  @media (min-width: 768px) {
    .metrics-inner { grid-template-columns: repeat(4, 1fr); }
    .cs-body { grid-template-columns: 1fr 1fr; }
  }
</style>
