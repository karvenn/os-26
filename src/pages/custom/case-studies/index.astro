---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../../components/MicrositeFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CaseStudyCard from '../../../components/CaseStudyCard.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import { caseStudies } from '../../../data/case-studies';
---

<Layout
  title="Case Studies | Orangesoft Custom"
  description="In-depth case studies showcasing how Orangesoft builds custom websites and web applications that deliver measurable business results."
>
  <EntranceOverlay />
  <MicrositeHeader active="work" />
  <Breadcrumb items={[{ label: 'Home', href: '/custom' }, { label: 'Work', href: '/custom/work' }, { label: 'Case Studies' }]} />

  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Case Studies</h1>
      <p class="hero-lead">
        In-depth stories behind selected projects. We share the challenge, our approach, and the measurable results our clients achieved.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      {caseStudies.map((cs) => (
        <div class="cs-item" data-animate="fade-up">
          <a href={`/custom/case-studies/${cs.slug}`} class="cs-link-wrap">
            <CaseStudyCard caseStudy={cs} />
          </a>
        </div>
      ))}
    </div>
  </section>

  <CtaBand heading="Want results like these?" buttonText="Start Your Project" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  .cs-item { margin-bottom: 2rem; }
  .cs-item:last-child { margin-bottom: 0; }

  .cs-link-wrap {
    display: block;
    text-decoration: none;
    transition: transform 0.3s ease;
  }
  .cs-link-wrap:hover { transform: translateY(-2px); }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
  }
</style>
