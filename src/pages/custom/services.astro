---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../components/MicrositeFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
---

<Layout
  title="Our Services | Orangesoft Custom"
  description="Custom design and custom development services for organisations that demand more than templates. UX research, visual design, frontend and backend engineering from a Malaysian web agency with 19+ years of experience."
>
  <EntranceOverlay />
  <MicrositeHeader active="services" />
  <Breadcrumb items={[{ label: 'Home', href: '/custom' }, { label: 'Services' }]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Two Services.<br />One Seamless Result.</h1>
      <p class="hero-lead">
        Every project we deliver starts with thoughtful design and ends with robust engineering. We offer two distinct services that work independently or together, depending on what your organisation needs.
      </p>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="services-grid" data-animate="stagger">

        <!-- Custom Design -->
        <a href="/custom/services/design" class="service-card">
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 19l7-7 3 3-7 7-3-3z" />
              <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z" />
              <path d="M2 2l7.586 7.586" />
              <circle cx="11" cy="11" r="2" />
            </svg>
          </div>
          <span class="service-label">Service 01</span>
          <h2 class="service-title">Custom Design</h2>
          <p class="service-desc">
            UX research, wireframing, visual design, design systems, and interactive prototyping. We craft every pixel to serve your brand and your users.
          </p>
          <div class="service-details">
            <div class="service-for">
              <h3>For</h3>
              <p>Brands that need a premium digital presence that stands apart from template-based competitors.</p>
            </div>
            <div class="service-outcome">
              <h3>Outcome</h3>
              <p>Cohesive brand experience across every touchpoint, improved conversion rates, and design systems that scale with your organisation.</p>
            </div>
          </div>
          <ul class="service-includes">
            <li>UX Research</li>
            <li>Wireframing</li>
            <li>Visual Design</li>
            <li>Design Systems</li>
            <li>Prototyping</li>
          </ul>
          <span class="service-link">
            Learn more about our design service
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

        <!-- Custom Development -->
        <a href="/custom/services/development" class="service-card">
          <div class="service-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6" />
              <polyline points="8 6 2 12 8 18" />
            </svg>
          </div>
          <span class="service-label">Service 02</span>
          <h2 class="service-title">Custom Development</h2>
          <p class="service-desc">
            Frontend engineering with NuxtJS, backend systems in Laravel, API development, third-party integrations, and database architecture. Code built to perform and built to last.
          </p>
          <div class="service-details">
            <div class="service-for">
              <h3>For</h3>
              <p>Businesses with unique technical requirements that off-the-shelf platforms and page builders cannot satisfy.</p>
            </div>
            <div class="service-outcome">
              <h3>Outcome</h3>
              <p>High-performance applications, scalable architecture, and clean maintainable code your team can confidently extend.</p>
            </div>
          </div>
          <ul class="service-includes">
            <li>Frontend (NuxtJS)</li>
            <li>Backend (Laravel)</li>
            <li>API Development</li>
            <li>Integrations</li>
            <li>Database Architecture</li>
          </ul>
          <span class="service-link">
            Learn more about our development service
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>

      </div>
    </div>
  </section>

  <!-- Not Sure -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <div class="decide">
        <span class="decide-label">Not sure which you need?</span>
        <h2 class="decide-title">Most Clients Need Both</h2>
        <p class="decide-lead">
          Design without development is a static mockup. Development without design is a functional product nobody wants to use. The strongest digital experiences happen when both disciplines work in concert from day one.
        </p>
        <p class="decide-lead">
          Most of our engagements combine both services into a single, integrated project. We begin with research and design to define the right solution, then our engineering team brings it to life with pixel-perfect accuracy. You get one team, one timeline, and one point of accountability.
        </p>
        <p class="decide-lead">
          That said, if you already have designs from another agency or an in-house team and just need expert development, or if you need a design system refresh without a full rebuild, we are happy to take on either service independently.
        </p>
        <a href="/custom/contact" class="decide-cta">
          Let's discuss your project
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- How We Work -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="How Every Project Starts"
        subtitle="Regardless of which service you choose, every engagement begins with the same structured discovery process."
      />
      <div class="steps-grid" data-animate="stagger">
        <div class="step">
          <span class="step-num">01</span>
          <h3 class="step-title">Discovery Call</h3>
          <p class="step-desc">A 30-minute conversation to understand your goals, constraints, and timeline. No commitment required.</p>
        </div>
        <div class="step">
          <span class="step-num">02</span>
          <h3 class="step-title">Proposal & Scope</h3>
          <p class="step-desc">A detailed proposal with clear deliverables, milestones, and fixed pricing. No surprises.</p>
        </div>
        <div class="step">
          <span class="step-num">03</span>
          <h3 class="step-title">Kickoff & Sprint Planning</h3>
          <p class="step-desc">We align on priorities, set up communication channels, and begin the first sprint within the week.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to talk about your project?" buttonText="Get a Custom Quote" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Service Cards Grid */
  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .service-card:hover {
    border-color: var(--color-brand);
    box-shadow: 0 8px 32px rgba(232, 114, 12, 0.08);
  }

  .service-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brand-light);
    border-radius: 0.625rem;
    margin-bottom: 1.5rem;
  }

  .service-icon svg {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--color-brand);
  }

  .service-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    margin-bottom: 0.75rem;
  }

  .service-title {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .service-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .service-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
    padding: 1.25rem;
    background: white;
    border-radius: 0.5rem;
  }

  .service-details h3 {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .service-details p {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-muted);
  }

  .service-includes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin-bottom: 1.75rem;
  }

  .service-includes li {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-foreground);
    padding: 0.375rem 0.875rem;
    background: white;
    border: 1px solid var(--color-divider);
    border-radius: 2rem;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-brand);
    margin-top: auto;
    transition: gap 0.3s ease;
  }

  .service-card:hover .service-link {
    gap: 0.75rem;
  }

  .service-link svg {
    width: 1rem;
    height: 1rem;
  }

  /* Decide Section */
  .decide {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .decide-label {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    margin-bottom: 1rem;
  }

  .decide-title {
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .decide-lead {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .decide-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-brand);
    text-decoration: none;
    transition: gap 0.3s ease;
  }

  .decide-cta:hover {
    gap: 0.75rem;
  }

  .decide-cta svg {
    width: 1rem;
    height: 1rem;
  }

  /* Steps */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .step {
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }

  .step:hover {
    border-color: var(--color-brand);
  }

  .step-num {
    font-size: 0.6875rem;
    font-weight: 300;
    color: var(--color-brand);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.75rem;
  }

  .step-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .step-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .services-grid { grid-template-columns: 1fr; }
    .service-card { padding: 1.75rem; }
    .service-details { grid-template-columns: 1fr; }
    .decide-title { font-size: 1.5rem; }
    .steps-grid { grid-template-columns: 1fr; }
  }
</style>
