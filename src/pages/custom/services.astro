---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../components/MicrositeFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import RelatedWork from '../../components/RelatedWork.astro';
import PricingTeaser from '../../components/PricingTeaser.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://orangesoft.com.my/custom/services' },
  ],
};

const services = [
  {
    number: '01',
    title: 'Discovery & Strategy',
    tagline: 'Clarity before commitment',
    description: 'We immerse ourselves in your business, audience, and competitive landscape before a single pixel is designed. The result is a strategic foundation that ensures every decision downstream is grounded in evidence.',
    deliverables: ['Research & Audits', 'Strategic Planning', 'Competitive Analysis', 'Project Roadmap'],
    href: '/custom/services/discovery',
    duration: '1\u20133 weeks',
  },
  {
    number: '02',
    title: 'Custom Design',
    tagline: 'Where strategy meets craft',
    description: 'From wireframes to high-fidelity prototypes, every interface is crafted to serve your brand and your users. We design systems that scale, not just pages that look good on launch day.',
    deliverables: ['UX Research', 'Wireframes', 'Visual Design', 'Prototyping'],
    href: '/custom/services/design',
    duration: '3\u20136 weeks',
  },
  {
    number: '03',
    title: 'Custom Development',
    tagline: 'Engineering that scales',
    description: 'Clean, maintainable code built on modern frameworks. Frontend, backend, APIs, and third-party integrations engineered to perform under load and evolve with your business.',
    deliverables: ['Frontend Engineering', 'Backend Systems', 'API Development', 'Integrations'],
    href: '/custom/services/development',
    duration: '4\u201312 weeks',
  },
  {
    number: '04',
    title: 'Migration & Deployment',
    tagline: 'Launch with confidence',
    description: 'Data migration, team training, and zero-downtime deployment executed with precision. We rehearse every launch so the real thing is uneventful \u2014 exactly the way it should be.',
    deliverables: ['Data Migration', 'Team Training', 'QA & Testing', 'Go-Live'],
    href: '/custom/services/deployment',
    duration: '1\u20132 weeks',
  },
  {
    number: '05',
    title: 'Maintenance & Support',
    tagline: 'Peace of mind',
    description: 'Security patches, performance monitoring, and proactive updates keep your platform healthy long after launch. We handle the infrastructure so your team can focus on growth.',
    deliverables: ['Security Monitoring', 'Performance Tuning', 'Regular Updates', 'Priority Support'],
    href: '/custom/services/maintenance',
    duration: 'Ongoing',
  },
  {
    number: '06',
    title: 'Growth & Optimisation',
    tagline: 'Compound your ROI',
    description: 'SEO, conversion rate optimisation, and analytics-driven improvements turn your platform into a compounding asset. Data reveals opportunities; we execute on them.',
    deliverables: ['SEO Strategy', 'CRO & A/B Testing', 'Analytics', 'Growth Roadmap'],
    href: '/custom/services/growth',
    duration: 'Ongoing',
  },
];

const lifecycleSteps = [
  { number: '01', name: 'Discovery', duration: '1\u20133 weeks', href: '/custom/services/discovery' },
  { number: '02', name: 'Design', duration: '3\u20136 weeks', href: '/custom/services/design' },
  { number: '03', name: 'Development', duration: '4\u201312 weeks', href: '/custom/services/development' },
  { number: '04', name: 'Deployment', duration: '1\u20132 weeks', href: '/custom/services/deployment' },
  { number: '05', name: 'Maintenance', duration: 'Ongoing', href: '/custom/services/maintenance' },
  { number: '06', name: 'Growth', duration: 'Ongoing', href: '/custom/services/growth' },
];
---

<Layout
  title="Our Services | Orangesoft Custom"
  description="Six services covering the full project lifecycle \u2014 from discovery and strategy through design, development, deployment, maintenance, and growth. One team, every phase."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="services" />
  <Breadcrumb items={[{ label: 'Home', href: '/custom' }, { label: 'Services' }]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Six Services.<br />One Complete Journey.</h1>
      <p class="hero-lead">
        We cover every phase from first conversation to ongoing growth, so you never need to coordinate between multiple vendors. One team, one relationship, one point of accountability across your entire project lifecycle.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Service Cards -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="services-grid" data-animate="stagger">
        {services.map((service) => (
          <a href={service.href} class="service-card">
            <span class="service-number">{service.number}</span>
            <h2 class="service-title">{service.title}</h2>
            <p class="service-tagline">{service.tagline}</p>
            <p class="service-desc">{service.description}</p>
            <ul class="service-tags">
              {service.deliverables.map((tag) => (
                <li>{tag}</li>
              ))}
            </ul>
            <span class="service-link">
              Learn more
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- The Full Lifecycle -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <div class="lifecycle-narrative">
        <SectionHeading
          title="The Full Lifecycle"
          subtitle="Most clients engage us across multiple phases, but each service can be purchased independently."
          align="center"
        />
        <p class="lifecycle-text">
          The strongest results come from continuity. When the same team that researched your audience also designs the interface, writes the code, deploys the platform, and optimises it for growth, nothing gets lost in translation. Context compounds at every phase.
        </p>
        <p class="lifecycle-text">
          That said, we understand that not every organisation needs every phase. Perhaps you already have designs from another agency and need expert development. Perhaps you have a live platform that needs ongoing maintenance and growth optimisation. We are happy to engage at whichever stage makes sense for you.
        </p>
        <p class="lifecycle-highlight">
          Start with discovery and stay through growth, or hire us for just the phase you need.
        </p>
      </div>
    </div>
  </section>

  <!-- Lifecycle Flow -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="The Journey at a Glance"
        subtitle="Six phases, one seamless flow. Each step builds on the last."
        align="center"
      />
      <div class="lifecycle-flow" data-animate="stagger">
        {lifecycleSteps.map((step, i) => (
          <a href={step.href} class="flow-step">
            <span class="flow-number">{step.number}</span>
            <span class="flow-name">{step.name}</span>
            <span class="flow-duration">{step.duration}</span>
            {i < lifecycleSteps.length - 1 && (
              <span class="flow-arrow">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            )}
          </a>
        ))}
      </div>
      <div class="flow-timeline-note" data-animate="fade-up">
        <p><strong>Typical corporate website:</strong> 12\u201316 weeks end-to-end</p>
        <p><strong>Complex web application:</strong> 20\u201328 weeks end-to-end</p>
        <p><strong>Ongoing maintenance & growth:</strong> continuous engagement</p>
      </div>
    </div>
  </section>

  <RelatedWork />
  <PricingTeaser />
  <CtaBand heading="Ready to talk about your project?" buttonText="Get Your Custom Quote" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Service Cards Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .service-card:hover {
    border-color: var(--color-brand);
    box-shadow: 0 8px 32px rgba(232, 114, 12, 0.08);
  }

  .service-number {
    font-size: 0.75rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    margin-bottom: 1rem;
  }

  .service-title {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 0.375rem;
  }

  .service-tagline {
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--color-brand);
    margin-bottom: 1rem;
  }

  .service-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }

  .service-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }

  .service-tags li {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--color-foreground);
    padding: 0.3125rem 0.75rem;
    background: white;
    border: 1px solid var(--color-divider);
    border-radius: 2rem;
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand);
    margin-top: auto;
    transition: gap 0.3s ease;
  }

  .service-card:hover .service-link {
    gap: 0.75rem;
  }

  .service-link svg {
    width: 0.875rem;
    height: 0.875rem;
  }

  /* Lifecycle Narrative */
  .lifecycle-narrative {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .lifecycle-text {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .lifecycle-highlight {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-top: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-brand-light);
    border-radius: 0.5rem;
    border-left: 3px solid var(--color-brand);
    text-align: left;
  }

  /* Lifecycle Flow */
  .lifecycle-flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .flow-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    padding: 1.25rem 1rem;
    border-radius: 0.5rem;
    transition: background 0.2s ease;
    position: relative;
  }

  .flow-step:hover {
    background: var(--color-brand-light);
  }

  .flow-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: var(--color-brand);
    color: white;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 0.625rem;
  }

  .flow-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.25rem;
  }

  .flow-duration {
    font-size: 0.6875rem;
    color: var(--color-brand);
    font-weight: 500;
  }

  .flow-arrow {
    position: absolute;
    right: -0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-divider);
    display: flex;
    align-items: center;
    pointer-events: none;
  }

  .flow-arrow svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .flow-timeline-note {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 0.5rem;
    border: 1px solid var(--color-divider);
  }

  .flow-timeline-note p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-bottom: 0.375rem;
  }

  .flow-timeline-note p:last-child {
    margin-bottom: 0;
  }

  .flow-timeline-note strong {
    color: var(--color-foreground);
    font-weight: 600;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .services-grid { grid-template-columns: 1fr; }
    .service-card { padding: 1.75rem; }

    .lifecycle-flow {
      flex-direction: column;
      gap: 0.25rem;
    }

    .flow-step {
      flex-direction: row;
      gap: 1rem;
      padding: 0.875rem 1rem;
      width: 100%;
      max-width: 320px;
    }

    .flow-number {
      margin-bottom: 0;
      width: 2.25rem;
      height: 2.25rem;
      font-size: 0.75rem;
      flex-shrink: 0;
    }

    .flow-name {
      margin-bottom: 0;
      flex: 1;
      text-align: left;
    }

    .flow-duration {
      text-align: right;
    }

    .flow-arrow {
      right: auto;
      left: 1.875rem;
      top: auto;
      bottom: -0.5rem;
      transform: rotate(90deg);
    }
  }
</style>
