---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../components/MicrositeFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import { technologies } from '../../data/technologies';

const categoryLabels: Record<string, string> = {
  frontend: 'Frontend Framework',
  backend: 'Backend Framework',
  cms: 'Content Management',
};
---

<Layout
  title="Our Technology Stack | Orangesoft Custom"
  description="NuxtJS, Laravel, and Strapi — the three technologies we have mastered to build high-performance websites and web applications for corporate clients."
>
  <EntranceOverlay />
  <MicrositeHeader active="how-we-work" />
  <Breadcrumb items={[
    { label: 'Home', href: '/custom' },
    { label: 'How We Work', href: '/custom/how-we-work' },
    { label: 'Technologies' },
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Our Technology Stack</h1>
      <p class="hero-lead">
        We do not collect technologies — we master them. Three frameworks, chosen deliberately, refined over hundreds of projects. Each one solves a specific problem better than the alternatives.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Technology Deep Dives -->
  {technologies.map((tech, i) => (
    <section class:list={['section', { 'section-alt': i % 2 === 0 }]} id={tech.slug}>
      <div class="section-inner">
        <div class="tech-header" data-animate="fade-up">
          <span class="tech-category">{categoryLabels[tech.category]}</span>
          <h2 class="tech-name">{tech.name}</h2>
          <p class="tech-tagline">{tech.tagline}</p>
        </div>

        <div class="tech-body" data-animate="fade-up">
          <p class="tech-description">{tech.description}</p>

          <div class="tech-grid">
            <div class="tech-col">
              <h3 class="tech-col-title">Why We Use {tech.name}</h3>
              <ul class="tech-list">
                {tech.whyWeUse.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
            <div class="tech-col">
              <h3 class="tech-col-title">Key Strengths</h3>
              <ul class="tech-list">
                {tech.strengths.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>

          <div class="tech-meta">
            <div class="tech-best-for">
              <h3 class="tech-col-title">Best For</h3>
              <div class="tag-row">
                {tech.bestFor.map((item) => (
                  <span class="tag">{item}</span>
                ))}
              </div>
            </div>
            <div class="tech-when">
              <h3 class="tech-col-title">When We Use It</h3>
              <p class="tech-when-text">{tech.whenWeUseIt}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Comparison Summary -->
  <section class="section">
    <div class="section-inner">
      <h2 class="comparison-title" data-animate="fade-up">Choosing the Right Technology</h2>
      <p class="comparison-intro" data-animate="fade-up">
        Most projects use two or all three of these technologies together. Here is how we decide what goes where.
      </p>
      <div class="comparison-wrap" data-animate="fade-up">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Scenario</th>
              <th>Technology</th>
              <th>Why</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="scenario">Corporate website with CMS</td>
              <td class="stack-choice">NuxtJS + Strapi</td>
              <td class="reasoning">Static generation delivers exceptional speed; Strapi gives marketing teams full editorial control without developer involvement.</td>
            </tr>
            <tr>
              <td class="scenario">Web application with user accounts</td>
              <td class="stack-choice">NuxtJS + Laravel</td>
              <td class="reasoning">Laravel handles authentication, business logic, and API layer; NuxtJS delivers a responsive, app-like frontend experience.</td>
            </tr>
            <tr>
              <td class="scenario">Content platform with custom workflows</td>
              <td class="stack-choice">NuxtJS + Laravel + Strapi</td>
              <td class="reasoning">Full stack for complex projects — Strapi manages content, Laravel handles custom business logic, NuxtJS serves the frontend.</td>
            </tr>
            <tr>
              <td class="scenario">Customer portal or dashboard</td>
              <td class="stack-choice">NuxtJS + Laravel</td>
              <td class="reasoning">Laravel provides robust API authentication and role-based access; NuxtJS delivers a fast, interactive dashboard experience.</td>
            </tr>
            <tr>
              <td class="scenario">Multi-language marketing site</td>
              <td class="stack-choice">NuxtJS + Strapi</td>
              <td class="reasoning">Strapi's built-in internationalisation paired with NuxtJS hreflang support covers SEO and content in every market.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Stack Philosophy -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <div class="stack-philosophy">
        <h2 class="sp-title">Why Three Technologies, Not Thirty</h2>
        <p class="sp-text">
          Agencies that list twenty frameworks on their website are telling you something: they are generalists. They will figure out your stack as they go. We took a different approach. We identified the three technologies that cover the full spectrum of corporate web development and built deep, production-tested expertise in each one.
        </p>
        <p class="sp-text">
          The result is faster delivery, fewer bugs, and more predictable outcomes. Our engineers are not learning on your project — they are applying patterns they have refined across hundreds of deployments.
        </p>
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to discuss the right technology for your project?" buttonText="Talk to Our Team" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1.25rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Technology Header */
  .tech-header { margin-bottom: 2.5rem; }
  .tech-category {
    display: inline-block;
    font-size: 0.6875rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--color-brand);
    margin-bottom: 0.75rem;
  }
  .tech-name {
    font-size: 2.25rem; font-weight: 700; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 0.625rem;
  }
  .tech-tagline {
    font-size: 1.125rem; line-height: 1.6; color: var(--color-muted);
    max-width: 600px;
  }

  /* Technology Body */
  .tech-description {
    font-size: 1rem; line-height: 1.8; color: var(--color-muted);
    max-width: 720px; margin-bottom: 2.5rem;
  }

  .tech-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .tech-col-title {
    font-size: 0.875rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--color-foreground);
    margin-bottom: 1rem;
  }

  .tech-list {
    list-style: none; padding: 0; margin: 0;
  }
  .tech-list li {
    position: relative;
    padding: 0.5rem 0 0.5rem 1.25rem;
    font-size: 0.875rem; line-height: 1.6; color: var(--color-muted);
    border-bottom: 1px solid var(--color-divider);
  }
  .tech-list li:last-child { border-bottom: none; }
  .tech-list li::before {
    content: '';
    position: absolute;
    left: 0; top: 0.875rem;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-brand);
  }

  /* Tags */
  .tech-meta {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-divider);
  }
  .tag-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    font-size: 0.75rem; font-weight: 500;
    color: var(--color-brand);
    background: var(--color-brand-light);
    border-radius: 2rem;
  }
  .tech-when-text {
    font-size: 0.875rem; line-height: 1.7; color: var(--color-muted);
  }

  /* Comparison */
  .comparison-title {
    font-size: 2rem; font-weight: 600; color: var(--color-foreground);
    letter-spacing: -0.02em; margin-bottom: 0.75rem;
  }
  .comparison-intro {
    font-size: 1rem; line-height: 1.7; color: var(--color-muted);
    max-width: 560px; margin-bottom: 2.5rem;
  }
  .comparison-wrap {
    overflow-x: auto; -webkit-overflow-scrolling: touch;
    border: 1px solid var(--color-divider); border-radius: 0.5rem;
  }
  .comparison-table {
    width: 100%; min-width: 700px; border-collapse: collapse; font-size: 0.875rem;
  }
  .comparison-table thead { background: var(--color-surface); }
  .comparison-table th {
    text-align: left; padding: 1rem 1.25rem;
    font-size: 0.6875rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.1em; color: var(--color-muted);
    border-bottom: 1px solid var(--color-divider);
  }
  .comparison-table td {
    padding: 1rem 1.25rem; color: var(--color-muted);
    border-bottom: 1px solid var(--color-divider); vertical-align: top;
  }
  .comparison-table tbody tr:last-child td { border-bottom: none; }
  .scenario { font-weight: 600; color: var(--color-foreground); white-space: nowrap; }
  .stack-choice { font-weight: 500; color: var(--color-brand); white-space: nowrap; }
  .reasoning { line-height: 1.6; }

  /* Philosophy */
  .stack-philosophy { max-width: 720px; margin: 0 auto; text-align: center; }
  .sp-title {
    font-size: 1.75rem; font-weight: 600; color: var(--color-foreground);
    margin-bottom: 1.5rem; letter-spacing: -0.02em;
  }
  .sp-text {
    font-size: 1rem; line-height: 1.8; color: var(--color-muted); margin-bottom: 1.25rem;
  }
  .sp-text:last-child { margin-bottom: 0; }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .tech-name { font-size: 1.75rem; }
    .tech-grid { grid-template-columns: 1fr; gap: 2rem; }
    .tech-meta { grid-template-columns: 1fr; gap: 2rem; }
    .comparison-title { font-size: 1.5rem; }
    .sp-title { font-size: 1.5rem; }
  }
</style>
