---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../components/MicrositeFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import PortfolioCard from '../../components/PortfolioCard.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import { portfolioProjects } from '../../data/portfolio';
import { caseStudies } from '../../data/case-studies';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Work', item: 'https://orangesoft.com.my/custom/work' },
  ],
};
---

<Layout
  title="Our Work | Orangesoft Custom"
  description="Explore our portfolio of custom websites, web applications, and digital platforms built for corporate clients across Malaysia and Southeast Asia."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="work" />
  <Breadcrumb items={[{ label: 'Home', href: '/custom' }, { label: 'Work' }]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Our Work</h1>
      <p class="hero-lead">
        A selection of custom websites and web applications we have built for businesses across Malaysia and Southeast Asia. Each project is engineered from scratch to meet unique business requirements.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Portfolio Grid -->
  <section class="section">
    <div class="section-inner">
      <div class="work-grid" data-animate="stagger">
        {portfolioProjects.map((project, i) => (
          <div class:list={['work-item', i === 0 ? 'work-item--full' : '']}>
            <PortfolioCard project={project} variant={i === 0 ? 'full' : 'half'} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Studies Teaser -->
  <section class="section section-alt">
    <div class="section-inner">
      <h2 class="cs-heading">Case Studies</h2>
      <p class="cs-subtitle">In-depth stories behind selected projects.</p>
      <div class="cs-grid" data-animate="stagger">
        {caseStudies.map((cs) => (
          <a href={`/custom/case-studies/${cs.slug}`} class="cs-card">
            <span class="cs-label">{cs.projectTitle}</span>
            <h3 class="cs-name">{cs.clientName}</h3>
            <p class="cs-metric">{cs.metrics[0].value}{cs.metrics[0].suffix} {cs.metrics[0].label}</p>
            <span class="cs-link">Read case study &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Have a project in mind?" buttonText="Get a Free Website Audit" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  .work-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .work-item--full { grid-column: 1 / -1; }

  .cs-heading { font-size: 2rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
  .cs-subtitle { font-size: 1rem; color: var(--color-muted); margin-bottom: 2.5rem; }

  .cs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  .cs-card {
    display: flex; flex-direction: column; padding: 1.75rem; border: 1px solid var(--color-divider);
    border-radius: 0.5rem; text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .cs-card:hover { border-color: var(--color-brand); transform: translateY(-2px); }

  .cs-label { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); margin-bottom: 0.5rem; }
  .cs-name { font-size: 1.125rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.375rem; }
  .cs-metric { font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 1rem; flex: 1; }
  .cs-link { font-size: 0.75rem; font-weight: 600; color: var(--color-brand); }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .work-grid, .cs-grid { grid-template-columns: 1fr; }
    .work-item--full { grid-column: auto; }
  }
</style>
