---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../components/MicrositeFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import Animations from '../../components/Animations.astro';
import { portfolioProjects } from '../../data/portfolio';
import { caseStudies } from '../../data/case-studies';
import { clientLogos } from '../../data/clients';

const featured = portfolioProjects.filter((p) => p.featured);
const portfolio = portfolioProjects.filter((p) => !p.featured);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Work', item: 'https://orangesoft.com.my/custom/work' },
  ],
};
---

<Layout
  title="Our Work | Orangesoft Custom"
  description="Portfolio of custom websites, web applications, and digital platforms built for corporate clients across Malaysia and Southeast Asia."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="work" />
  <Breadcrumb items={[{ label: 'Home', href: '/custom' }, { label: 'Work' }]} />

  <section class="hero">
    <div class="inner">
      <h1 class="hero-title">600+ Projects.<br />Here Are the Ones<br />We Are Proudest Of.</h1>
      <p class="hero-lead">
        From corporate website redesigns that tripled lead generation to supply chain platforms that connected 12 offices — these are the projects where our work made a measurable difference.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- ════ TIER 1: CASE STUDIES ════ -->
  <section class="section">
    <div class="inner">
      <div class="tier-header">
        <div>
          <h2 class="tier-title">Case Studies</h2>
          <p class="tier-desc">In-depth stories with the challenge, our approach, and measurable results.</p>
        </div>
        <a href="/custom/case-studies" class="tier-link">View all case studies &rarr;</a>
      </div>
      <div class="cs-grid" data-animate="stagger">
        {caseStudies.map((cs) => (
          <a href={`/custom/case-studies/${cs.slug}`} class="cs-card">
            <div class="cs-card-top">
              <span class="cs-label">Case Study</span>
              <h3 class="cs-name">{cs.clientName}</h3>
              <p class="cs-project">{cs.projectTitle}</p>
            </div>
            <div class="cs-metrics">
              {cs.metrics.slice(0, 2).map((m) => (
                <div class="cs-metric">
                  <span class="cs-metric-val">{m.value}{m.suffix}</span>
                  <span class="cs-metric-label">{m.label}</span>
                </div>
              ))}
            </div>
            <blockquote class="cs-quote">
              &ldquo;{cs.testimonial.quote.slice(0, 120)}&hellip;&rdquo;
            </blockquote>
            <span class="cs-cta">Read full story &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ TIER 2: PORTFOLIO ════ -->
  <section class="section section-alt">
    <div class="inner">
      <div class="tier-header">
        <div>
          <h2 class="tier-title">Portfolio</h2>
          <p class="tier-desc">A broader selection of projects across industries and project types.</p>
        </div>
      </div>

      <div class="portfolio-featured" data-animate="stagger">
        {featured.map((p) => (
          <a href={p.caseStudySlug ? `/custom/case-studies/${p.caseStudySlug}` : '#'} class="pf-card">
            <div class="pf-image">
              <div class="pf-placeholder"><span>{p.clientName.charAt(0)}</span></div>
            </div>
            <div class="pf-content">
              <span class="pf-type">{p.projectType} &middot; {p.year}</span>
              <h3 class="pf-name">{p.clientName}</h3>
              <p class="pf-headline">{p.headline}</p>
              <div class="pf-tags">
                {p.technologies.map((t) => <span class="pf-tag">{t}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="portfolio-grid" data-animate="stagger">
        {portfolio.map((p) => (
          <div class="pg-card">
            <span class="pg-type">{p.projectType}</span>
            <h3 class="pg-name">{p.clientName}</h3>
            <p class="pg-headline">{p.headline}</p>
            <div class="pg-tags">
              {p.technologies.slice(0, 2).map((t) => <span class="pg-tag">{t}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ TIER 3: CLIENT LOGOS ════ -->
  <section class="section">
    <div class="inner">
      <h2 class="tier-title">Brands We Have Worked With</h2>
      <p class="tier-desc">A selection of the organisations that have trusted Orangesoft with their digital projects.</p>
      <div class="logo-wall" data-animate="fade-up">
        {clientLogos.map((logo) => (
          <div class="logo-cell" title={logo.name}>
            <span class="logo-name">{logo.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Have a project in mind?" buttonText="Start a Conversation" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  .tier-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 2.5rem; gap: 1rem; flex-wrap: wrap; }
  .tier-title { font-size: 2rem; font-weight: 600; color: var(--color-foreground); letter-spacing: -0.02em; }
  .tier-desc { font-size: 1rem; color: var(--color-muted); margin-top: 0.375rem; }
  .tier-link { font-size: 0.8125rem; font-weight: 600; color: var(--color-brand); text-decoration: none; white-space: nowrap; transition: opacity 0.3s ease; }
  .tier-link:hover { opacity: 0.7; }

  /* Case Study Cards */
  .cs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .cs-card {
    display: flex; flex-direction: column; padding: 2rem; border: 1px solid var(--color-divider);
    border-radius: 0.75rem; text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .cs-card:hover { border-color: var(--color-brand); transform: translateY(-3px); }
  .cs-card-top { margin-bottom: 1.5rem; }
  .cs-label { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); display: block; margin-bottom: 0.5rem; }
  .cs-name { font-size: 1.25rem; font-weight: 600; color: var(--color-foreground); letter-spacing: -0.01em; }
  .cs-project { font-size: 0.8125rem; color: var(--color-muted); margin-top: 0.25rem; }
  .cs-metrics { display: flex; gap: 2rem; margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-divider); }
  .cs-metric-val { display: block; font-size: 1.5rem; font-weight: 700; color: var(--color-brand); letter-spacing: -0.02em; }
  .cs-metric-label { font-size: 0.625rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted); }
  .cs-quote { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); font-style: italic; flex: 1; margin-bottom: 1.25rem; }
  .cs-cta { font-size: 0.75rem; font-weight: 600; color: var(--color-brand); }

  /* Portfolio Featured */
  .portfolio-featured { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; }
  .pf-card {
    display: block; border-radius: 0.5rem; overflow: hidden; border: 1px solid var(--color-divider);
    text-decoration: none; transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .pf-card:hover { border-color: var(--color-brand); transform: translateY(-3px); }
  .pf-image { aspect-ratio: 16 / 9; overflow: hidden; }
  .pf-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--color-brand-light) 0%, #FDE8D8 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .pf-placeholder span { font-size: 3rem; font-weight: 700; color: var(--color-brand); opacity: 0.2; }
  .pf-content { padding: 1.25rem; }
  .pf-type { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); display: block; margin-bottom: 0.375rem; }
  .pf-name { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.25rem; }
  .pf-headline { font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 0.75rem; }
  .pf-tags { display: flex; gap: 0.375rem; flex-wrap: wrap; }
  .pf-tag { font-size: 0.5625rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted); background: var(--color-surface); padding: 0.2rem 0.5rem; border-radius: 0.25rem; }

  /* Portfolio Compact Grid */
  .portfolio-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .pg-card {
    padding: 1.25rem; border: 1px solid var(--color-divider); border-radius: 0.5rem;
    transition: border-color 0.3s ease;
  }
  .pg-card:hover { border-color: var(--color-brand); }
  .pg-type { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); display: block; margin-bottom: 0.375rem; }
  .pg-name { font-size: 0.9375rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.25rem; }
  .pg-headline { font-size: 0.75rem; line-height: 1.5; color: var(--color-muted); margin-bottom: 0.625rem; }
  .pg-tags { display: flex; gap: 0.25rem; }
  .pg-tag { font-size: 0.5625rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted); background: var(--color-surface); padding: 0.15rem 0.375rem; border-radius: 0.25rem; }

  /* Client Logo Wall */
  .logo-wall {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
    border: 1px solid var(--color-divider); border-radius: 0.5rem; overflow: hidden;
    margin-top: 2rem;
  }
  .logo-cell {
    display: flex; align-items: center; justify-content: center;
    padding: 1.5rem 1rem; background: white;
    transition: background-color 0.3s ease;
  }
  .logo-cell:hover { background: var(--color-brand-light); }
  .logo-name {
    font-size: 0.75rem; font-weight: 600; color: var(--color-foreground);
    opacity: 0.4; letter-spacing: 0.02em; text-align: center;
    transition: opacity 0.3s ease;
  }
  .logo-cell:hover .logo-name { opacity: 0.8; }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .cs-grid { grid-template-columns: 1fr; }
    .portfolio-featured { grid-template-columns: 1fr; }
    .portfolio-grid { grid-template-columns: 1fr 1fr; }
    .logo-wall { grid-template-columns: repeat(2, 1fr); }
    .tier-header { flex-direction: column; align-items: flex-start; }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .cs-grid { grid-template-columns: repeat(2, 1fr); }
    .portfolio-grid { grid-template-columns: repeat(3, 1fr); }
    .logo-wall { grid-template-columns: repeat(3, 1fr); }
  }
</style>
