---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../../components/MicrositeFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('insights');
const sorted = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted.find((p) => p.data.featured) || sorted[0];
const rest = sorted.filter((p) => p.id !== featured?.id);

function formatDate(date: Date): string {
  return new Intl.DateTimeFormat('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }).format(date);
}
---

<Layout
  title="Insights | Orangesoft Custom"
  description="Insights and guides on custom web development, technology choices, pricing, and digital strategy for corporate marketing teams in Malaysia."
>
  <EntranceOverlay />
  <MicrositeHeader active="insights" />
  <Breadcrumb items={[{ label: 'Home', href: '/custom' }, { label: 'Insights' }]} />

  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Insights</h1>
      <p class="hero-lead">
        Practical guides, comparisons, and thought leadership for marketing managers and decision-makers evaluating custom web development.
      </p>
    </div>
  </section>

  {featured && (
    <section class="section">
      <div class="section-inner">
        <a href={`/custom/insights/${featured.id}`} class="featured" data-animate="fade-up">
          <div class="featured-image">
            <div class="featured-placeholder">
              <span>{featured.data.title.charAt(0)}</span>
            </div>
          </div>
          <div class="featured-content">
            <span class="featured-label">Featured</span>
            <h2 class="featured-title">{featured.data.title}</h2>
            <p class="featured-desc">{featured.data.description}</p>
            <div class="featured-meta">
              <time>{formatDate(featured.data.pubDate)}</time>
              {featured.data.readingTime && <span>{featured.data.readingTime} min read</span>}
            </div>
          </div>
        </a>
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <section class="section section-alt">
      <div class="section-inner">
        <h2 class="list-heading">All Articles</h2>
        <div class="post-grid" data-animate="stagger">
          {rest.map((post) => (
            <a href={`/custom/insights/${post.id}`} class="post-card">
              <div class="post-tags">
                {post.data.tags.slice(0, 2).map((tag) => <span class="tag">{tag}</span>)}
              </div>
              <h3 class="post-title">{post.data.title}</h3>
              <p class="post-desc">{post.data.description}</p>
              <div class="post-meta">
                <time>{formatDate(post.data.pubDate)}</time>
                {post.data.readingTime && <span>{post.data.readingTime} min read</span>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaBand heading="Have a specific question?" buttonText="Ask Us Directly" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Featured */
  .featured {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2.5rem;
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .featured:hover { border-color: var(--color-brand); transform: translateY(-2px); }

  .featured-image { aspect-ratio: 4 / 3; overflow: hidden; border-radius: 0.5rem; }
  .featured-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, var(--color-brand-light) 0%, #FDE8D8 100%);
    display: flex; align-items: center; justify-content: center;
  }
  .featured-placeholder span { font-size: 6rem; font-weight: 700; color: var(--color-brand); opacity: 0.25; }

  .featured-content { display: flex; flex-direction: column; justify-content: center; }
  .featured-label { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); margin-bottom: 1rem; }
  .featured-title { font-size: 1.75rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 1rem; letter-spacing: -0.02em; line-height: 1.2; }
  .featured-desc { font-size: 0.9375rem; line-height: 1.7; color: var(--color-muted); margin-bottom: 1.5rem; }
  .featured-meta { display: flex; gap: 1rem; font-size: 0.75rem; color: var(--color-muted); }

  /* Post grid */
  .list-heading { font-size: 1.75rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 2.5rem; letter-spacing: -0.02em; }
  .post-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  .post-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    background: var(--color-surface);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }
  .post-card:hover { background: var(--color-brand-light); transform: translateY(-2px); }

  .post-tags { display: flex; gap: 0.375rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .tag { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-brand); }

  .post-title { font-size: 1.125rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; line-height: 1.3; letter-spacing: -0.01em; }
  .post-desc { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); margin-bottom: 1rem; flex: 1; }
  .post-meta { display: flex; gap: 1rem; font-size: 0.6875rem; color: var(--color-muted); }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .featured { grid-template-columns: 1fr; gap: 1.5rem; }
    .featured-title { font-size: 1.375rem; }
    .post-grid { grid-template-columns: 1fr; }
  }
</style>
