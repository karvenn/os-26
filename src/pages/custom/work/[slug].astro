---
import Layout from '../../../layouts/Layout.astro';
import MicrositeHeader from '../../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../../components/MicrositeFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import TrustStrip from '../../../components/TrustStrip.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import { portfolioProjects, type PortfolioProject } from '../../../data/portfolio';

export function getStaticPaths() {
  return portfolioProjects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
}

interface Props {
  project: PortfolioProject;
}

const { project } = Astro.props;
const otherProjects = portfolioProjects
  .filter((p) => p.slug !== project.slug && p.featured)
  .slice(0, 3);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Work', item: 'https://orangesoft.com.my/custom/work' },
    { '@type': 'ListItem', position: 3, name: project.clientName, item: `https://orangesoft.com.my/custom/work/${project.slug}` },
  ],
};
---

<Layout
  title={`${project.clientName} — ${project.projectType} | Orangesoft`}
  description={project.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <MicrositeHeader active="work" />
  <Breadcrumb items={[
    { label: 'Home', href: '/custom' },
    { label: 'Work', href: '/custom/work' },
    { label: project.clientName },
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="inner">
      <div class="hero-meta">
        <span class="hero-type">{project.projectType}</span>
        <span class="hero-sep">&middot;</span>
        <span class="hero-year">{project.year}</span>
      </div>
      <h1 class="hero-title">{project.clientName}</h1>
      <p class="hero-headline">{project.headline}</p>
      <div class="hero-tags">
        {project.technologies.map((t) => <span class="tag">{t}</span>)}
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- Metrics (featured only) -->
  {project.metrics && project.metrics.length > 0 && (
    <section class="metrics-bar">
      <div class="metrics-inner">
        {project.metrics.map((m) => (
          <div class="metric">
            <span class="metric-val" data-target={m.value} data-decimals={m.decimals || 0} data-suffix={m.suffix}>0{m.suffix}</span>
            <span class="metric-label">{m.label}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Description -->
  <section class="section">
    <div class="inner" data-animate="fade-up">
      <div class="project-body">
        <h2 class="body-heading">About This Project</h2>
        <p class="body-text">{project.description}</p>
      </div>
    </div>
  </section>

  <!-- Testimonial (featured only) -->
  {project.testimonial && (
    <section class="section section-alt">
      <div class="inner" data-animate="fade-up">
        <blockquote class="testimonial">
          <p>&ldquo;{project.testimonial.quote}&rdquo;</p>
          <footer>
            <strong>{project.testimonial.authorName}</strong>
            <span>{project.testimonial.authorTitle}, {project.testimonial.company}</span>
          </footer>
        </blockquote>
      </div>
    </section>
  )}

  <!-- Technologies -->
  <section class:list={['section', { 'section-alt': !project.testimonial }]}>
    <div class="inner" data-animate="fade-up">
      <h2 class="body-heading">Technologies Used</h2>
      <div class="tech-list">
        {project.technologies.map((t) => (
          <span class="tech-pill">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Projects -->
  {otherProjects.length > 0 && (
    <section class="section section-alt">
      <div class="inner">
        <h2 class="body-heading">More Featured Work</h2>
        <div class="related-grid" data-animate="stagger">
          {otherProjects.map((p) => (
            <a href={`/custom/work/${p.slug}`} class="related-card">
              <span class="related-type">{p.projectType}</span>
              <h3>{p.clientName}</h3>
              <p>{p.headline}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaBand heading="Want results like these for your business?" buttonText="Get Your Custom Quote" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 4rem; border-bottom: 1px solid var(--color-divider); }
  .hero-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; opacity: 0; animation: slideUp 0.6s ease 0.8s forwards; }
  .hero-type { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); }
  .hero-sep { color: var(--color-divider); }
  .hero-year { font-size: 0.6875rem; color: var(--color-muted); }
  .hero-title { font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; color: var(--color-foreground); margin-bottom: 0.75rem; opacity: 0; animation: slideUp 0.7s ease 0.9s forwards; }
  .hero-headline { font-size: 1.25rem; font-weight: 500; color: var(--color-muted); margin-bottom: 1.5rem; opacity: 0; animation: slideUp 0.7s ease 1s forwards; }
  .hero-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; opacity: 0; animation: slideUp 0.6s ease 1.1s forwards; }
  .tag { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-muted); background: var(--color-surface); border: 1px solid var(--color-divider); padding: 0.3rem 0.75rem; border-radius: 2rem; }

  /* Metrics */
  .metrics-bar { padding: 3rem 1.5rem; background: var(--color-brand-light); }
  .metrics-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; text-align: center; }
  .metric-val { display: block; font-size: 2.5rem; font-weight: 700; color: var(--color-brand); letter-spacing: -0.02em; }
  .metric-label { display: block; font-size: 0.75rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted); margin-top: 0.25rem; }

  /* Body */
  .project-body { max-width: 720px; }
  .body-heading { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-foreground); margin-bottom: 1rem; }
  .body-text { font-size: 1.0625rem; line-height: 1.8; color: var(--color-muted); }

  /* Testimonial */
  .testimonial { max-width: 720px; margin: 0 auto; text-align: center; }
  .testimonial p { font-size: 1.25rem; line-height: 1.7; color: var(--color-foreground); font-style: italic; margin-bottom: 1.25rem; }
  .testimonial footer { display: flex; flex-direction: column; align-items: center; }
  .testimonial strong { font-size: 0.9375rem; font-weight: 600; color: var(--color-foreground); font-style: normal; }
  .testimonial footer span { font-size: 0.8125rem; color: var(--color-muted); font-style: normal; }

  /* Technologies */
  .tech-list { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .tech-pill { padding: 0.625rem 1.25rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; font-size: 0.875rem; font-weight: 500; color: var(--color-foreground); }

  /* Related */
  .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .related-card { display: block; padding: 1.5rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; text-decoration: none; transition: border-color 0.3s ease, transform 0.3s ease; }
  .related-card:hover { border-color: var(--color-brand); transform: translateY(-2px); }
  .related-type { display: block; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); margin-bottom: 0.375rem; }
  .related-card h3 { font-size: 1.125rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.375rem; }
  .related-card p { font-size: 0.8125rem; color: var(--color-muted); }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-meta, .hero-title, .hero-headline, .hero-tags { animation: none !important; opacity: 1 !important; } }

  @media (min-width: 768px) { .metrics-inner { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .hero-headline { font-size: 1.0625rem; }
    .testimonial p { font-size: 1.0625rem; }
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
