---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../../components/MicrositeFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import FaqItem from '../../../components/FaqItem.astro';
import TrustStrip from '../../../components/TrustStrip.astro';
import PricingTeaser from '../../../components/PricingTeaser.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import { industries, type Industry } from '../../../data/industries';

export function getStaticPaths() {
  return industries.map((ind) => ({
    params: { slug: ind.slug },
    props: { industry: ind },
  }));
}

interface Props {
  industry: Industry;
}

const { industry } = Astro.props;

const serviceSlugMap: Record<string, string> = {
  'Discovery & Strategy': 'discovery',
  'Custom Design': 'design',
  'Custom Development': 'development',
  'Migration & Deployment': 'deployment',
  'Maintenance & Support': 'maintenance',
  'Growth & Optimisation': 'growth',
};

const solutionSlugMap: Record<string, string> = {
  'Custom Website': 'website',
  'Custom CMS': 'cms',
  'Custom CRM': 'crm',
  'Custom eCommerce': 'ecommerce',
  'Contest Management System': 'contest-management',
  'Survey & Reporting Dashboard': 'survey-dashboard',
  'Custom Booking System': 'booking-system',
  'Kiosk Sales Kit': 'kiosk-sales-kit',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://orangesoft.com.my/custom/industries' },
    { '@type': 'ListItem', position: 3, name: industry.name, item: `https://orangesoft.com.my/custom/industries/${industry.slug}` },
  ],
};

const faqSchema = industry.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: industry.faq.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;
---

<Layout
  title={`${industry.name} | Orangesoft Custom`}
  description={industry.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="work" />
  <Breadcrumb items={[
    { label: 'Home', href: '/custom' },
    { label: 'Industries', href: '/custom/industries' },
    { label: industry.name },
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <span class="hero-label">{industry.name}</span>
      <h1 class="hero-title">{industry.tagline}</h1>
      <p class="hero-desc">{industry.description}</p>
      <a href="/custom/contact" class="btn-primary">Discuss Your {industry.name} Project</a>
    </div>
  </section>

  <TrustStrip />

  <!-- Challenges -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading title="The Challenges You Face" subtitle={`Common digital pain points we solve for ${industry.name.toLowerCase()} organisations.`} />
      <div class="challenges" data-animate="stagger">
        {industry.challenges.map((c, i) => (
          <div class="challenge">
            <span class="challenge-num">{String(i + 1).padStart(2, '0')}</span>
            <p>{c}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Recommendation -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading title="Our Recommendation" />
      <div class="recommendation">
        <p>{industry.recommendation}</p>
      </div>
    </div>
  </section>

  <!-- Relevant Services -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading title="Relevant Services" subtitle="The services most commonly engaged by organisations in this industry." />
      <div class="services-list" data-animate="stagger">
        {industry.relevantServices.map((svc) => (
          <a href={`/custom/services/${serviceSlugMap[svc] || 'discovery'}`} class="svc-pill">
            {svc} &rarr;
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Relevant Solutions -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading title="Relevant Solutions" subtitle="Pre-built platforms we customise for this industry." />
      <div class="solutions-list" data-animate="stagger">
        {industry.relevantSolutions.map((sol) => (
          <a href={`/custom/solutions/${solutionSlugMap[sol] || 'website'}`} class="sol-pill">
            {sol} &rarr;
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- What We've Done -->
  {industry.projects.length > 0 && (
    <section class="section section-alt">
      <div class="section-inner">
        <SectionHeading title="What We Have Done" subtitle={`Selected projects for ${industry.name.toLowerCase()} clients.`} />
        <div class="project-list" data-animate="stagger">
          {industry.projects.map((p) => (
            <div class="project-card">
              {p.caseStudySlug ? (
                <a href={`/custom/case-studies/${p.caseStudySlug}`} class="project-link">
                  <span class="project-type">{p.type}</span>
                  <h3 class="project-name">{p.clientName}</h3>
                  <p class="project-headline">{p.headline}</p>
                  <span class="project-cta">Read case study &rarr;</span>
                </a>
              ) : (
                <div class="project-link">
                  <span class="project-type">{p.type}</span>
                  <h3 class="project-name">{p.clientName}</h3>
                  <p class="project-headline">{p.headline}</p>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <PricingTeaser />

  <!-- FAQ -->
  {industry.faq.length > 0 && (
    <section class="section">
      <div class="section-inner section-inner--narrow">
        <SectionHeading title={`${industry.name} FAQ`} />
        <div data-animate="fade-up">
          {industry.faq.map((f) => <FaqItem question={f.question} answer={f.answer} />)}
        </div>
      </div>
    </section>
  )}

  <CtaBand heading={`Ready to discuss your ${industry.name.toLowerCase()} project?`} buttonText="Get a Custom Quote" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-inner--narrow { max-width: 800px; }
  .section-alt { background: white; }

  .hero { padding: 4rem 1.5rem 3rem; }
  .hero-label { display: inline-block; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); margin-bottom: 1rem; opacity: 0; animation: slideUp 0.6s ease 1s forwards; }
  .hero-title { font-size: 2.5rem; font-weight: 700; line-height: 1.15; letter-spacing: -0.03em; color: var(--color-foreground); margin-bottom: 1.25rem; opacity: 0; animation: slideUp 0.7s ease 1.1s forwards; }
  .hero-desc { font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px; margin-bottom: 2rem; opacity: 0; animation: slideUp 0.7s ease 1.2s forwards; }
  .btn-primary { display: inline-flex; padding: 0.875rem 2rem; background: var(--color-brand); color: white; font-size: 0.875rem; font-weight: 600; text-decoration: none; border-radius: 0.375rem; transition: background-color 0.3s ease; opacity: 0; animation: slideUp 0.7s ease 1.3s forwards; }
  .btn-primary:hover { background: var(--color-brand-dark, #C45E0A); }

  /* Challenges */
  .challenges { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .challenge { display: flex; gap: 1rem; padding: 1.5rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .challenge-num { font-size: 0.6875rem; font-weight: 300; color: var(--color-brand); letter-spacing: 0.1em; flex-shrink: 0; padding-top: 0.15rem; }
  .challenge p { font-size: 0.875rem; line-height: 1.6; color: var(--color-muted); }

  /* Recommendation */
  .recommendation { max-width: 720px; padding: 2rem; border-left: 3px solid var(--color-brand); background: var(--color-brand-light); border-radius: 0 0.5rem 0.5rem 0; }
  .recommendation p { font-size: 1rem; line-height: 1.8; color: var(--color-foreground); }

  /* Services & Solutions pills */
  .services-list, .solutions-list { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .svc-pill, .sol-pill {
    display: inline-flex; padding: 0.75rem 1.25rem; border: 1px solid var(--color-divider);
    border-radius: 0.5rem; text-decoration: none; font-size: 0.875rem; font-weight: 500;
    color: var(--color-foreground); transition: border-color 0.3s ease, background-color 0.3s ease;
  }
  .svc-pill:hover, .sol-pill:hover { border-color: var(--color-brand); background: var(--color-brand-light); }

  /* Project cards */
  .project-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .project-link { display: block; padding: 1.75rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; text-decoration: none; transition: border-color 0.3s ease, transform 0.3s ease; }
  a.project-link:hover { border-color: var(--color-brand); transform: translateY(-2px); }
  .project-type { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); display: block; margin-bottom: 0.5rem; }
  .project-name { font-size: 1.125rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.375rem; }
  .project-headline { font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 0.75rem; }
  .project-cta { font-size: 0.75rem; font-weight: 600; color: var(--color-brand); }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-label, .hero-title, .hero-desc, .btn-primary { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .challenges { grid-template-columns: 1fr; }
    .project-list { grid-template-columns: 1fr; }
  }
</style>
