---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../components/MicrositeFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FaqItem from '../../components/FaqItem.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import { pricingTiers, pricingFaq } from '../../data/pricing';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: pricingFaq.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'Pricing', item: 'https://orangesoft.com.my/custom/pricing' },
  ],
};
---

<Layout
  title="Pricing & Investment | Orangesoft Custom"
  description="Transparent pricing for custom websites and web applications in Malaysia. Investment ranges from MYR 30,000 for corporate sites to MYR 250,000+ for complex applications."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="pricing" />
  <Breadcrumb items={[{ label: 'Home', href: '/custom' }, { label: 'Pricing' }]} />

  <section class="hero">
    <div class="section-inner">
      <span class="hero-label">Investment &amp; Pricing</span>
      <h1 class="hero-title">Know What to Expect<br />Before You Call</h1>
      <p class="hero-lead">
        No hidden fees, no vague estimates. Here are the real investment ranges for every type of project we deliver — based on 600+ completed engagements. Your final quote comes after a free discovery conversation, tailored to your exact requirements.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Quick Path -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <h2 class="qp-title">What type of project are you planning?</h2>
      <div class="qp-grid">
        <a href="#tier-corporate" class="qp-card">Corporate Website</a>
        <a href="#tier-content" class="qp-card">Content Platform</a>
        <a href="#tier-webapp" class="qp-card">Web Application</a>
        <a href="#tier-ecommerce" class="qp-card">E-Commerce</a>
      </div>
    </div>
  </section>

  <!-- Pricing Tiers -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Investment Ranges"
        subtitle="Based on 600+ completed projects across corporate websites, web applications, content platforms, and e-commerce."
      />
      <div class="tier-list" data-animate="fade-up">
        {pricingTiers.map((tier) => (
          <div class="tier">
            <div class="tier-header">
              <h3 class="tier-name">{tier.name}</h3>
              <div class="tier-price">
                <span class="price-from">From</span>
                <span class="price-value">MYR {tier.priceFrom}</span>
                <span class="price-to">to MYR {tier.priceTo}</span>
              </div>
            </div>
            <p class="tier-desc">{tier.description}</p>
            <div class="tier-bestfor">
              <strong>Best for:</strong> {tier.bestFor}
            </div>
            <div class="tier-meta">
              <span class="tier-timeline">Timeline: {tier.timeline}</span>
            </div>
            <ul class="tier-includes">
              {tier.includes.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Value Explanation -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <div class="value">
        <h2 class="value-title">What shapes your final quote</h2>
        <div class="value-grid">
          <div class="factor">
            <h3>Complexity</h3>
            <p>A 5-page brochure site differs fundamentally from a customer portal. Complexity drives every other cost factor.</p>
          </div>
          <div class="factor">
            <h3>Design scope</h3>
            <p>Fully custom design vs. adapting a design system. More research and revisions mean higher design investment.</p>
          </div>
          <div class="factor">
            <h3>Integrations</h3>
            <p>Each connection with a CRM, ERP, or third-party service requires planning, development, and testing.</p>
          </div>
          <div class="factor">
            <h3>Content migration</h3>
            <p>Moving from an existing site with hundreds of pages adds scope for URL mapping, redirects, and content formatting.</p>
          </div>
          <div class="factor">
            <h3>Languages</h3>
            <p>Multi-language sites require translation workflows, hreflang configuration, and content modelling for each locale.</p>
          </div>
          <div class="factor">
            <h3>Timeline pressure</h3>
            <p>Rush timelines require more resources. We are transparent about the trade-offs before committing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What's always included -->
  <section class="section section-alt">
    <div class="section-inner">
      <h2 class="included-title">What is always included</h2>
      <p class="included-lead">Regardless of project size, every engagement includes these foundations \u2014 because they are not optional for quality work.</p>
      <div class="included-grid" data-animate="stagger">
        <div class="included-item">
          <h3>Discovery &amp; Strategy</h3>
          <p>Stakeholder interviews, requirements documentation, and a written strategy document before development begins.</p>
        </div>
        <div class="included-item">
          <h3>Written Proposal</h3>
          <p>A detailed, phase-by-phase proposal with scope, timeline, and costs \u2014 before you commit to anything.</p>
        </div>
        <div class="included-item">
          <h3>Dedicated PM</h3>
          <p>A single point of contact who manages communication, timelines, and deliverables throughout the engagement.</p>
        </div>
        <div class="included-item">
          <h3>Code Ownership</h3>
          <p>You own the source code, design files, and documentation. No vendor lock-in, no recurring license fees.</p>
        </div>
        <div class="included-item">
          <h3>Testing &amp; QA</h3>
          <p>Cross-browser testing, performance audits, security review, and user acceptance testing before launch.</p>
        </div>
        <div class="included-item">
          <h3>30 Days Support</h3>
          <p>Post-launch monitoring, bug fixes, and team training during your critical first month.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <SectionHeading title="Pricing FAQ" />
      <div data-animate="fade-up">
        {pricingFaq.map((faq) => <FaqItem question={faq.question} answer={faq.answer} />)}
      </div>
    </div>
  </section>

  <CtaBand heading="Ready for a transparent quote?" buttonText="Get Your Custom Proposal" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-inner--narrow { max-width: 800px; }
  .section-alt { background: white; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-label { display: inline-block; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); margin-bottom: 1rem; opacity: 0; animation: slideUp 0.6s ease 1s forwards; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1.1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.2s forwards;
  }

  /* Quick Path */
  .qp-title { font-size: 1.5rem; font-weight: 600; color: var(--color-foreground); text-align: center; margin-bottom: 1.5rem; letter-spacing: -0.02em; }
  .qp-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .qp-card {
    display: flex; align-items: center; justify-content: center; padding: 1.25rem;
    border: 1px solid var(--color-divider); border-radius: 0.5rem; text-decoration: none;
    font-size: 0.9375rem; font-weight: 600; color: var(--color-foreground);
    transition: border-color 0.3s ease, background-color 0.3s ease;
  }
  .qp-card:hover { border-color: var(--color-brand); background: var(--color-brand-light); }

  /* Tiers */
  .tier-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .tier {
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    transition: border-color 0.3s ease;
  }
  .tier:hover { border-color: var(--color-brand); }
  .tier-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap; }
  .tier-name { font-size: 1.375rem; font-weight: 600; color: var(--color-foreground); letter-spacing: -0.01em; }
  .tier-price { text-align: right; }
  .price-from { display: block; font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); }
  .price-value { display: block; font-size: 1.25rem; font-weight: 700; color: var(--color-brand); }
  .price-to { display: block; font-size: 0.75rem; color: var(--color-muted); }
  .tier-desc { font-size: 0.9375rem; line-height: 1.7; color: var(--color-muted); margin-bottom: 1rem; }
  .tier-bestfor { font-size: 0.8125rem; color: var(--color-foreground); margin-bottom: 0.5rem; }
  .tier-bestfor strong { font-weight: 600; }
  .tier-meta { font-size: 0.75rem; color: var(--color-muted); margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--color-divider); }
  .tier-includes { list-style: none; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1.5rem; }
  .tier-includes li { position: relative; padding-left: 1.25rem; font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); }
  .tier-includes li::before { content: ''; position: absolute; left: 0; top: 0.5rem; width: 0.375rem; height: 0.375rem; border-radius: 50%; background: var(--color-brand); }

  /* Value factors */
  .value { max-width: 1000px; margin: 0 auto; }
  .value-title { font-size: 2rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 2rem; letter-spacing: -0.02em; text-align: center; }
  .value-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .factor { padding: 1.5rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .factor h3 { font-size: 1rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; }
  .factor p { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); }

  /* Always included */
  .included-title { font-size: 2rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
  .included-lead { font-size: 1rem; color: var(--color-muted); margin-bottom: 2.5rem; max-width: 640px; }
  .included-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .included-item { padding: 1.5rem; background: var(--color-surface); border-radius: 0.5rem; }
  .included-item h3 { font-size: 1rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; }
  .included-item p { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-label, .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .tier-header { flex-direction: column; }
    .tier-price { text-align: left; }
    .tier-includes { grid-template-columns: 1fr; }
    .value-grid, .included-grid { grid-template-columns: 1fr; }
  }
</style>
