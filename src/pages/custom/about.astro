---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../components/MicrositeFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
import { trustStats } from '../../data/clients';
import { differentiators, comparisons } from '../../data/differentiators';


const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'About', item: 'https://orangesoft.com.my/custom/about' },
  ],
};
---

<Layout
  title="About Us | Orangesoft Custom"
  description="Meet the team behind Orangesoft's custom web development division. 19+ years of experience building digital solutions for corporate clients in Malaysia."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="about" />
  <Breadcrumb items={[{ label: 'Home', href: '/custom' }, { label: 'About' }]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Built on 19 Years<br />of Doing This Right</h1>
      <p class="hero-lead">
        Nineteen years ago, we started building websites for businesses that knew they deserved better than templates. Today, our custom development division serves corporate clients across Southeast Asia with a simple promise: your platform will be fast, secure, yours to own, and built to last.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="stats-grid" data-animate="stagger">
        {trustStats.map((stat) => (
          <div class="stat">
            <span class="stat-value" data-target={stat.value} data-decimals={stat.decimals || 0} data-suffix={stat.suffix}>0{stat.suffix}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-title">Why Orangesoft</h2>
      <p class="section-subtitle">Six reasons corporate clients choose us for their most important digital projects.</p>
      <div class="diff-grid" data-animate="stagger">
        {differentiators.map((d) => (
          <div class="diff">
            <span class="diff-num">{d.number}</span>
            <h3 class="diff-title">{d.title}</h3>
            <p class="diff-desc">{d.description}</p>
            <p class="diff-proof">{d.proof}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="section section-alt">
    <div class="section-inner">
      <h2 class="section-title">How We Compare</h2>
      <p class="section-subtitle">An honest look at how Orangesoft stacks up against your other options.</p>
      <div class="compare-wrap" data-animate="fade-up">
        <table class="compare">
          <thead>
            <tr>
              <th></th>
              <th class="highlight">Orangesoft</th>
              <th>Templates</th>
              <th>Big Agency</th>
              <th>Freelancer</th>
            </tr>
          </thead>
          <tbody>
            {comparisons.map((row) => (
              <tr>
                <td class="row-label">{row.row}</td>
                <td class="highlight">{row.orangesoft}</td>
                <td>{row.template}</td>
                <td>{row.bigAgency}</td>
                <td>{row.freelancer}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="section">
    <div class="section-inner">
      <div class="philosophy" data-animate="fade-up">
        <h2 class="section-title">How We Think</h2>
        <div class="philosophy-grid">
          <div class="principle">
            <h3>Outcomes over outputs</h3>
            <p>We measure success by business results, not deliverables. Every design choice and line of code ties back to a measurable goal.</p>
          </div>
          <div class="principle">
            <h3>Transparent by default</h3>
            <p>Weekly demos, shared dashboards, and honest timelines. You will never wonder where your project stands.</p>
          </div>
          <div class="principle">
            <h3>Own your platform</h3>
            <p>No vendor lock-in, no recurring license fees. You own the code, the data, and the infrastructure. We make sure you can run it independently.</p>
          </div>
          <div class="principle">
            <h3>Built to last</h3>
            <p>Clean architecture, comprehensive testing, and thorough documentation. Our projects are built for the team that maintains them after us.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Custom Division Team -->
  <section class="section section-alt">
    <div class="section-inner">
      <h2 class="section-title">The Custom Division Team</h2>
      <p class="section-subtitle">The specialists who design, build, and deliver your custom project. This is who you will actually work with.</p>
      <div class="team-grid" data-animate="stagger">
        <div class="team-member">
          <div class="member-avatar"><span>SA</span></div>
          <h3 class="member-name">Solutions Architect</h3>
          <p class="member-role">Discovery & Technical Strategy</p>
          <p class="member-bio">Translates business requirements into technical architecture. Leads discovery workshops, defines system design, and ensures every project starts on solid foundations.</p>
        </div>
        <div class="team-member">
          <div class="member-avatar"><span>UX</span></div>
          <h3 class="member-name">UX/UI Designer</h3>
          <p class="member-role">Research, Wireframes & Visual Design</p>
          <p class="member-bio">Specialises in conversion-focused design for corporate audiences. Conducts user research, builds prototypes, and creates design systems that scale.</p>
        </div>
        <div class="team-member">
          <div class="member-avatar"><span>FE</span></div>
          <h3 class="member-name">Frontend Engineer</h3>
          <p class="member-role">NuxtJS & Vue.js</p>
          <p class="member-bio">Builds pixel-perfect, high-performance frontends. Expert in NuxtJS, server-side rendering, and delivering 95+ Lighthouse scores consistently.</p>
        </div>
        <div class="team-member">
          <div class="member-avatar"><span>BE</span></div>
          <h3 class="member-name">Backend Engineer</h3>
          <p class="member-role">Laravel & API Development</p>
          <p class="member-bio">Architects robust backend systems, APIs, and database schemas. Handles complex business logic, integrations, and scalable infrastructure.</p>
        </div>
        <div class="team-member">
          <div class="member-avatar"><span>CMS</span></div>
          <h3 class="member-name">CMS Specialist</h3>
          <p class="member-role">Strapi & Content Architecture</p>
          <p class="member-bio">Designs content models, configures editorial workflows, and ensures your marketing team has full control over content without developer dependency.</p>
        </div>
        <div class="team-member">
          <div class="member-avatar"><span>PM</span></div>
          <h3 class="member-name">Project Delivery Lead</h3>
          <p class="member-role">Your Single Point of Contact</p>
          <p class="member-bio">Manages timelines, budgets, and communications. Runs weekly demos, coordinates approvals, and ensures every milestone is met on schedule.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Deep Dives -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <h2 class="section-title">Go Deeper</h2>
      <p class="section-subtitle">Explore how we work in more detail.</p>
      <div class="deep-links">
        <a href="/custom/how-we-work" class="deep-link">
          <h3>How We Work</h3>
          <p>Our approach to technology, platforms, and the 7-phase process from research to post-launch marketing.</p>
        </a>
        <a href="/custom/pricing" class="deep-link">
          <h3>Pricing & Investment</h3>
          <p>Transparent investment ranges, what is included, and what shapes your final quote.</p>
        </a>
        <a href="/custom/work" class="deep-link">
          <h3>Our Work</h3>
          <p>Portfolio of recent custom development projects.</p>
        </a>
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to work together?" buttonText="Get in Touch" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1.25rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  .section-title { font-size: 2rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
  .section-subtitle { font-size: 1rem; color: var(--color-muted); margin-bottom: 2.5rem; max-width: 560px; }

  /* Stats */
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center; }
  .stat-value { display: block; font-size: 2.5rem; font-weight: 700; color: var(--color-foreground); letter-spacing: -0.02em; }
  .stat-label { display: block; font-size: 0.75rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted); margin-top: 0.25rem; }

  /* Why Us */
  .diff-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .diff { padding: 1.75rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; transition: border-color 0.3s ease; }
  .diff:hover { border-color: var(--color-brand); }
  .diff-num { font-size: 0.6875rem; font-weight: 300; color: var(--color-brand); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem; }
  .diff-title { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.625rem; }
  .diff-desc { font-size: 0.8125rem; line-height: 1.7; color: var(--color-muted); margin-bottom: 0.75rem; }
  .diff-proof { font-size: 0.75rem; line-height: 1.6; color: var(--color-brand); font-weight: 500; padding-top: 0.75rem; border-top: 1px solid var(--color-divider); font-style: italic; }

  /* Comparison table */
  .compare-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .compare { width: 100%; min-width: 800px; border-collapse: collapse; font-size: 0.8125rem; }
  .compare thead { background: var(--color-surface); }
  .compare th { text-align: left; padding: 1rem 1.25rem; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); border-bottom: 1px solid var(--color-divider); white-space: nowrap; }
  .compare th.highlight { color: var(--color-brand); }
  .compare td { padding: 1rem 1.25rem; color: var(--color-muted); border-bottom: 1px solid var(--color-divider); vertical-align: top; }
  .compare tbody tr:last-child td { border-bottom: none; }
  .compare td.row-label { font-weight: 600; color: var(--color-foreground); white-space: nowrap; }
  .compare td.highlight { color: var(--color-foreground); font-weight: 500; background: var(--color-brand-light); }

  /* Philosophy */
  .philosophy-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .principle { padding: 1.75rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .principle h3 { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; }
  .principle p { font-size: 0.875rem; line-height: 1.7; color: var(--color-muted); }

  /* Team */
  .team-member { text-align: center; }
  .member-avatar {
    width: 4rem; height: 4rem; border-radius: 50%; background: var(--color-brand-light);
    display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem;
  }
  .member-avatar span { font-size: 0.875rem; font-weight: 700; color: var(--color-brand); }
  .member-name { font-size: 1rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.25rem; }
  .member-role { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); margin-bottom: 0.75rem; }
  .member-bio { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); }

  /* Deep Links */
  .deep-links { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .deep-link { padding: 1.75rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; text-decoration: none; transition: border-color 0.3s ease, transform 0.3s ease; }
  .deep-link:hover { border-color: var(--color-brand); transform: translateY(-2px); }
  .deep-link h3 { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; }
  .deep-link p { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); }
  .process-num { font-size: 0.6875rem; font-weight: 300; color: var(--color-brand); letter-spacing: 0.1em; padding-top: 0.25rem; }
  .process-title { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.375rem; }
  .process-desc { font-size: 0.8125rem; line-height: 1.7; color: var(--color-muted); }

  /* Team grid — 6 members = 3 columns */
  .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .philosophy-grid, .diff-grid, .deep-links { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
