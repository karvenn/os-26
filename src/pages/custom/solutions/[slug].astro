---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../../components/MicrositeFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import FaqItem from '../../../components/FaqItem.astro';
import CtaBand from '../../../components/CtaBand.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Animations from '../../../components/Animations.astro';
import PricingTeaser from '../../../components/PricingTeaser.astro';
import { solutions, type Solution } from '../../../data/solutions';

export function getStaticPaths() {
  return solutions.map((s) => ({
    params: { slug: s.slug },
    props: { solution: s },
  }));
}

interface Props {
  solution: Solution;
}

const { solution } = Astro.props;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my' },
    { '@type': 'ListItem', position: 2, name: 'Custom', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 3, name: solution.name, item: `https://orangesoft.com.my/custom/solutions/${solution.slug}` },
  ],
};

const faqSchema = solution.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: solution.faq.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;
---

<Layout
  title={`${solution.name} | Orangesoft`}
  description={solution.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <EntranceOverlay />

  <MicrositeHeader active="solutions" />
  <Breadcrumb items={[
    { label: 'Home', href: '/custom' },
    { label: 'Solutions', href: '/custom/solutions' },
    { label: solution.name },
  ]} />

  <!-- ════ HERO ════ -->
  <section class="hero">
    <div class="section-inner">
      <span class="hero-label">Solution</span>
      <h1 class="hero-title">{solution.name}</h1>
      <p class="hero-tagline">{solution.tagline}</p>
      <p class="hero-desc">{solution.description}</p>
      <div class="hero-actions">
        <a href="#contact" class="btn-primary">Get a Custom Quote</a>
        <a href="#capabilities" class="btn-ghost">See Capabilities</a>
      </div>
      <div class="hero-tech">
        {solution.technologies.map((t) => <span class="tech-pill">{t}</span>)}
      </div>
    </div>
  </section>

  <!-- ════ OUTCOMES ════ -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading title="Why This Solution?" subtitle="Business outcomes our clients achieve with this platform." />
      <div class="outcomes-grid" data-animate="stagger">
        {solution.outcomes.map((outcome, i) => (
          <div class="outcome">
            <span class="outcome-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="outcome-title">{outcome.title}</h3>
            <p class="outcome-desc">{outcome.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CAPABILITIES ════ -->
  <section id="capabilities" class="section">
    <div class="section-inner">
      <SectionHeading title="Key Capabilities" />
      <div class="cap-grid" data-animate="stagger">
        {solution.capabilities.map((cap) => (
          <div class="cap">
            <h3 class="cap-title">{cap.title}</h3>
            <p class="cap-desc">{cap.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ════ CUSTOMIZATION PROCESS ════ -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading title="How We Customize It" subtitle="Our proven process for tailoring this platform to your needs." />
      <div class="steps" data-animate="fade-up">
        {solution.customizationSteps.map((step, i) => (
          <div class="cstep">
            <span class="cstep-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="cstep-title">{step.title}</h3>
            <p class="cstep-desc">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <PricingTeaser />

  <!-- ════ CTA BAND ════ -->
  <CtaBand heading="Ready to explore this solution?" buttonText="Discuss Your Requirements" buttonHref="#contact" />

  <!-- ════ FAQ ════ -->
  {solution.faq.length > 0 && (
    <section id="faq" class="section section-alt">
      <div class="section-inner section-inner--narrow">
        <SectionHeading title={`Frequently Asked Questions`} />
        <div data-animate="fade-up">
          {solution.faq.map((faq) => (
            <FaqItem question={faq.question} answer={faq.answer} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ════ CONTACT ════ -->
  <section id="contact" class="section section-dark">
    <div class="section-inner" data-animate="fade-up">
      <ContactForm />
    </div>
  </section>

  <MicrositeFooter />

  <Animations />
</Layout>

<style>
  /* ── Layout ── */

  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-inner--narrow { max-width: 800px; }
  .section-alt { background: white; }
  .section-dark { background: var(--color-surface-dark, #1C1917); }

  /* ── Hero ── */

  .hero {
    padding: 4rem 1.5rem 5rem;
  }

  .hero-label {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brand);
    margin-bottom: 1rem;
    opacity: 0;
    animation: slideUp 0.6s ease 1s forwards;
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-foreground);
    margin-bottom: 0.75rem;
    opacity: 0;
    animation: slideUp 0.7s ease 1.05s forwards;
  }

  .hero-tagline {
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: slideUp 0.7s ease 1.15s forwards;
  }

  .hero-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 640px;
    margin-bottom: 2rem;
    opacity: 0;
    animation: slideUp 0.7s ease 1.25s forwards;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    opacity: 0;
    animation: slideUp 0.7s ease 1.35s forwards;
  }

  .hero-tech {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeIn 0.6s ease 1.6s forwards;
  }

  .tech-pill {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-divider);
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
  }

  /* ── Buttons ── */

  .btn-primary {
    display: inline-flex; padding: 0.875rem 2rem; background: var(--color-brand); color: white;
    font-size: 0.875rem; font-weight: 600; text-decoration: none; border-radius: 0.375rem;
    transition: background-color 0.3s ease;
  }
  .btn-primary:hover { background: var(--color-brand-dark, #C45E0A); }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.875rem 1.5rem;
    color: var(--color-foreground); font-size: 0.875rem; font-weight: 500; text-decoration: none;
    transition: color 0.3s ease;
  }
  .btn-ghost:hover { color: var(--color-brand); }

  /* ── Outcomes Grid ── */

  .outcomes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .outcome {
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
  }

  .outcome-num {
    font-size: 0.6875rem;
    font-weight: 300;
    color: var(--color-brand);
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.75rem;
  }

  .outcome-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .outcome-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* ── Capabilities Grid ── */

  .cap-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .cap {
    padding: 1.5rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .cap:hover {
    background: var(--color-brand-light);
    border-color: transparent;
  }

  .cap-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .cap-desc {
    font-size: 0.8125rem;
    line-height: 1.65;
    color: var(--color-muted);
  }

  /* ── Customization Steps ── */

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .cstep-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-brand);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .cstep-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .cstep-desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* ── Keyframes ── */

  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  /* ── Reduced Motion ── */

  @media (prefers-reduced-motion: reduce) {
    .hero-label, .hero-title, .hero-tagline, .hero-desc, .hero-actions, .hero-tech, .page-header {
      animation: none !important;
      opacity: 1 !important;
    }
  }

  /* ── Mobile ── */

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .hero-tagline { font-size: 1.0625rem; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .btn-primary { width: 100%; justify-content: center; }
    .outcomes-grid { grid-template-columns: 1fr; }
    .cap-grid { grid-template-columns: 1fr; }
    .steps { grid-template-columns: 1fr; }
  }
</style>
