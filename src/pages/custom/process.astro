---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import MicrositeHeader from '../../components/MicrositeHeader.astro';
import MicrositeFooter from '../../components/MicrositeFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import PricingTeaser from '../../components/PricingTeaser.astro';
import { processPhases } from '../../data/process-detail';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/custom' },
    { '@type': 'ListItem', position: 2, name: 'How We Work', item: 'https://orangesoft.com.my/custom/how-we-work' },
    { '@type': 'ListItem', position: 3, name: 'Process', item: 'https://orangesoft.com.my/custom/process' },
  ],
};
---

<Layout
  title="Our Process | Orangesoft Custom"
  description="7 structured phases from research to post-launch marketing. Clear milestones, defined deliverables, and transparent communication at every step of your project."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <MicrositeHeader active="how-we-work" />
  <Breadcrumb items={[
    { label: 'Home', href: '/custom' },
    { label: 'How We Work', href: '/custom/how-we-work' },
    { label: 'Process' },
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Our Process</h1>
      <p class="hero-lead">
        Seven phases from research to results. Every project follows this proven methodology — adapted to your timeline, refined over hundreds of engagements, designed to eliminate surprises.
      </p>
      <div class="hero-phases">
        {processPhases.map((phase, i) => (
          <a href={`#phase-${phase.number}`} class="hero-phase-link">
            <span class="hero-phase-num">{String(phase.number).padStart(2, '0')}</span>
            <span class="hero-phase-name">{phase.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <TrustStrip />

  <!-- Phase Deep Dives -->
  {processPhases.map((phase, i) => (
    <section class:list={['section', { 'section-alt': i % 2 !== 0 }]} id={`phase-${phase.number}`}>
      <div class="section-inner">
        <div class="phase" data-animate="fade-up">
          <div class="phase-header">
            <span class="phase-badge">{String(phase.number).padStart(2, '0')}</span>
            <div class="phase-header-text">
              <h2 class="phase-name">{phase.name}</h2>
              <p class="phase-tagline">{phase.tagline}</p>
            </div>
            <span class="phase-duration">{phase.duration}</span>
          </div>

          <p class="phase-description">{phase.description}</p>

          <div class="phase-grid">
            <div class="phase-col">
              <h3 class="phase-col-title">Activities</h3>
              <ul class="phase-list">
                {phase.activities.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
            <div class="phase-col">
              <h3 class="phase-col-title">Deliverables</h3>
              <ul class="phase-list phase-list--deliverables">
                {phase.deliverables.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>

          <div class="phase-client">
            <h3 class="phase-client-title">Your Role</h3>
            <p class="phase-client-text">{phase.clientRole}</p>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Timeline Summary -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="timeline-summary" data-animate="fade-up">
        <h2 class="ts-title">Typical Project Timeline</h2>
        <p class="ts-intro">
          Most custom projects run 12 to 24 weeks from kickoff to launch, depending on complexity. Here is how that time typically breaks down.
        </p>
        <div class="timeline-bar">
          {processPhases.map((phase) => (
            <div class="timeline-segment" data-phase={phase.number}>
              <span class="ts-label">{phase.name}</span>
              <span class="ts-dur">{phase.duration}</span>
            </div>
          ))}
        </div>
        <p class="ts-note">
          Timelines are adapted to each project. Smaller marketing sites may complete in 8 to 10 weeks. Complex web applications with custom integrations may take 6 months or more. We define the timeline during the Planning phase and hold ourselves accountable to it.
        </p>
      </div>
    </div>
  </section>

  <!-- Why Process Matters -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <div class="process-philosophy">
        <h2 class="pp-title">Why Process Matters</h2>
        <p class="pp-text">
          A good process does not slow projects down — it eliminates the rework that slows projects down. Every phase exists because we learned, through experience, that skipping it leads to problems later. Research prevents building the wrong thing. Planning prevents scope creep. Design validation prevents expensive development pivots.
        </p>
        <p class="pp-text">
          The result is not just a better product — it is a more predictable experience. You will know what is happening, when it is happening, and what you need to do at every stage. No black boxes, no surprises, no uncomfortable silences between milestone meetings.
        </p>
      </div>
    </div>
  </section>

  <PricingTeaser />
  <CtaBand heading="Ready to start with Phase 1?" buttonText="Begin Your Project" buttonHref="/custom/contact" />
  <MicrositeFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1.25rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Hero Phase Navigation */
  .hero-phases {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-top: 2rem;
    opacity: 0; animation: slideUp 0.7s ease 1.3s forwards;
  }
  .hero-phase-link {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-divider);
    border-radius: 2rem;
    text-decoration: none;
    font-size: 0.75rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .hero-phase-link:hover {
    border-color: var(--color-brand);
    background: var(--color-brand-light);
  }
  .hero-phase-num {
    font-weight: 300; color: var(--color-brand); letter-spacing: 0.05em;
  }
  .hero-phase-name {
    font-weight: 500; color: var(--color-foreground);
  }

  /* Phase */
  .phase-header {
    display: flex; align-items: flex-start; gap: 1.25rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .phase-badge {
    display: flex; align-items: center; justify-content: center;
    width: 3.5rem; height: 3.5rem;
    border-radius: 0.5rem;
    background: var(--color-brand);
    color: white;
    font-size: 1.125rem; font-weight: 700;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .phase-header-text { flex: 1; min-width: 200px; }
  .phase-name {
    font-size: 2rem; font-weight: 700; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 0.25rem;
  }
  .phase-tagline {
    font-size: 1.0625rem; line-height: 1.5; color: var(--color-muted);
  }
  .phase-duration {
    display: inline-flex; align-items: center;
    padding: 0.375rem 1rem;
    background: var(--color-brand-light);
    color: var(--color-brand);
    font-size: 0.75rem; font-weight: 600;
    border-radius: 2rem;
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 0.375rem;
  }

  .phase-description {
    font-size: 1rem; line-height: 1.8; color: var(--color-muted);
    max-width: 720px; margin-bottom: 2.5rem;
  }

  .phase-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 2.5rem;
    margin-bottom: 2.5rem;
  }

  .phase-col-title {
    font-size: 0.875rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--color-foreground);
    margin-bottom: 1rem;
  }

  .phase-list {
    list-style: none; padding: 0; margin: 0;
  }
  .phase-list li {
    position: relative;
    padding: 0.5rem 0 0.5rem 1.25rem;
    font-size: 0.875rem; line-height: 1.6; color: var(--color-muted);
    border-bottom: 1px solid var(--color-divider);
  }
  .phase-list li:last-child { border-bottom: none; }
  .phase-list li::before {
    content: '';
    position: absolute;
    left: 0; top: 0.875rem;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-brand);
  }
  .phase-list--deliverables li::before {
    border-radius: 1px;
    width: 8px; height: 8px;
    background: none;
    border: 2px solid var(--color-brand);
    top: 0.8rem;
  }

  /* Client Role */
  .phase-client {
    padding: 1.5rem;
    background: var(--color-brand-light);
    border-radius: 0.5rem;
    border-left: 3px solid var(--color-brand);
  }
  .phase-client-title {
    font-size: 0.8125rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--color-brand);
    margin-bottom: 0.5rem;
  }
  .phase-client-text {
    font-size: 0.875rem; line-height: 1.7; color: var(--color-foreground);
  }

  /* Timeline Summary */
  .timeline-summary { max-width: 900px; margin: 0 auto; }
  .ts-title {
    font-size: 2rem; font-weight: 600; color: var(--color-foreground);
    letter-spacing: -0.02em; margin-bottom: 0.75rem;
    text-align: center;
  }
  .ts-intro {
    font-size: 1rem; line-height: 1.7; color: var(--color-muted);
    text-align: center; max-width: 560px; margin: 0 auto 2.5rem;
  }

  .timeline-bar {
    display: grid; grid-template-columns: repeat(7, 1fr); gap: 0.375rem;
    margin-bottom: 2rem;
  }
  .timeline-segment {
    padding: 1rem 0.5rem;
    background: var(--color-surface);
    border-radius: 0.375rem;
    text-align: center;
    transition: background 0.2s ease;
  }
  .timeline-segment:hover { background: var(--color-brand-light); }
  .ts-label {
    display: block;
    font-size: 0.6875rem; font-weight: 600; color: var(--color-foreground);
    margin-bottom: 0.25rem;
  }
  .ts-dur {
    display: block;
    font-size: 0.625rem; color: var(--color-brand); font-weight: 500;
  }

  .ts-note {
    font-size: 0.875rem; line-height: 1.7; color: var(--color-muted);
    text-align: center;
  }

  /* Philosophy */
  .process-philosophy { max-width: 720px; margin: 0 auto; text-align: center; }
  .pp-title {
    font-size: 1.75rem; font-weight: 600; color: var(--color-foreground);
    margin-bottom: 1.5rem; letter-spacing: -0.02em;
  }
  .pp-text {
    font-size: 1rem; line-height: 1.8; color: var(--color-muted); margin-bottom: 1.25rem;
  }
  .pp-text:last-child { margin-bottom: 0; }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead, .hero-phases { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .hero-phases { gap: 0.375rem; }
    .hero-phase-link { padding: 0.375rem 0.75rem; font-size: 0.6875rem; }
    .phase-header { flex-direction: column; gap: 0.75rem; }
    .phase-badge { width: 2.75rem; height: 2.75rem; font-size: 0.9375rem; }
    .phase-name { font-size: 1.5rem; }
    .phase-grid { grid-template-columns: 1fr; gap: 2rem; }
    .timeline-bar { grid-template-columns: 1fr; gap: 0.25rem; }
    .timeline-segment { display: flex; justify-content: space-between; align-items: center; padding: 0.75rem 1rem; }
    .ts-title { font-size: 1.5rem; }
    .pp-title { font-size: 1.5rem; }
  }
</style>
