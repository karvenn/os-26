---
import Layout from '../layouts/Layout.astro';
import EntranceOverlay from '../components/EntranceOverlay.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TrustBar from '../components/TrustBar.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import CtaBand from '../components/CtaBand.astro';
import ContactForm from '../components/ContactForm.astro';
import MicrositeHeader from '../components/MicrositeHeader.astro';
import MicrositeFooter from '../components/MicrositeFooter.astro';
import StickyBar from '../components/StickyBar.astro';
import QuickEnquiry from '../components/QuickEnquiry.astro';
import Animations from '../components/Animations.astro';

import { portfolioProjects } from '../data/portfolio';
import { solutions } from '../data/solutions';

const featuredProjects = portfolioProjects.filter((p) => p.featured).slice(0, 3);
const featuredProject = portfolioProjects.find((p) => p.featured && p.testimonial);
const highlightedSolutions = solutions.slice(0, 4);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my' },
    { '@type': 'ListItem', position: 2, name: 'Custom Websites & Applications', item: 'https://orangesoft.com.my/custom' },
  ],
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Custom Website & Web Application Development',
  description: 'Bespoke digital solutions built with NuxtJS, Laravel, and Strapi for businesses in Malaysia and Southeast Asia.',
  provider: {
    '@type': 'Organization',
    name: 'Orangesoft',
    url: 'https://orangesoft.com.my',
  },
  areaServed: { '@type': 'Country', name: 'Malaysia' },
  serviceType: 'Web Development',
};
---

<Layout
  title="Custom Websites & Web Apps | Orangesoft"
  description="Orangesoft builds custom websites and web applications with NuxtJS, Laravel, and Strapi. Secure, high-performance digital solutions for growing businesses in Malaysia."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <EntranceOverlay />

  <!-- ════ HERO ════ -->
  <section id="hero" class="hero">
    <div class="hero-inner">
      <MicrositeHeader />

      <div class="hero-content">
        <h1 class="hero-title">
          Your Website Should<br />Work as Hard<br />as Your Team Does
        </h1>
        <p class="hero-lead">
          Slow sites lose leads. Rigid templates frustrate your marketing team. Generic platforms cap your growth. We build custom websites and web applications that load fast, convert visitors, and put your team in full control — so your digital presence finally matches your ambition.
        </p>
        <div class="hero-actions">
          <a href="/custom/contact" class="btn-primary">See What We'd Build for You</a>
          <a href="/custom/work" class="btn-ghost">
            See Our Work
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ TRUST BAR ════ -->
  <TrustBar />

  <!-- ════ INTENT ROUTER ════ -->
  <section class="section section-alt">
    <div class="section-inner">
      <h2 class="router-title">What brings you here?</h2>
      <div class="router-grid" data-animate="stagger">
        <a href="/custom/solutions" class="router-card">
          <h3>I need a new website or app</h3>
          <p>Explore our 8 proven solutions — from corporate websites to custom CRMs.</p>
          <span class="router-link">Browse solutions &rarr;</span>
        </a>
        <a href="/custom/services/growth" class="router-card">
          <h3>I need to improve what I have</h3>
          <p>SEO, performance, conversion optimisation, and ongoing support for existing platforms.</p>
          <span class="router-link">See growth services &rarr;</span>
        </a>
        <a href="/custom/why-custom" class="router-card">
          <h3>I am deciding between custom and template</h3>
          <p>An honest comparison to help you decide if custom development is worth the investment.</p>
          <span class="router-link">Read the comparison &rarr;</span>
        </a>
        <a href="/custom/contact" class="router-card router-card--cta">
          <h3>I am ready to get a quote</h3>
          <p>Tell us about your project. Transparent proposal within 24 hours, no obligation.</p>
          <span class="router-link">Get your quote &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ SERVICES TEASER ════ -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Six Services. One Complete Journey."
        subtitle="From first conversation to ongoing growth — we cover every phase so you never need to coordinate between vendors."
      />
      <div class="services-teaser" data-animate="stagger">
        <a href="/custom/services/discovery" class="svc-card">
          <span class="svc-label">01</span>
          <h3 class="svc-title">Discovery & Strategy</h3>
          <p class="svc-desc">Research, audits, and strategic planning before any design or code work begins.</p>
          <span class="svc-link">Learn more &rarr;</span>
        </a>
        <a href="/custom/services/design" class="svc-card">
          <span class="svc-label">02</span>
          <h3 class="svc-title">Custom Design</h3>
          <p class="svc-desc">UX research, wireframing, visual design, design systems, and interactive prototyping.</p>
          <span class="svc-link">Learn more &rarr;</span>
        </a>
        <a href="/custom/services/development" class="svc-card">
          <span class="svc-label">03</span>
          <h3 class="svc-title">Custom Development</h3>
          <p class="svc-desc">Frontend engineering, backend systems, API development, and integrations.</p>
          <span class="svc-link">Learn more &rarr;</span>
        </a>
        <a href="/custom/services/deployment" class="svc-card">
          <span class="svc-label">04</span>
          <h3 class="svc-title">Migration & Deployment</h3>
          <p class="svc-desc">Data migration, team training, and zero-downtime launches.</p>
          <span class="svc-link">Learn more &rarr;</span>
        </a>
        <a href="/custom/services/maintenance" class="svc-card">
          <span class="svc-label">05</span>
          <h3 class="svc-title">Maintenance & Support</h3>
          <p class="svc-desc">Security updates, performance monitoring, and priority support.</p>
          <span class="svc-link">Learn more &rarr;</span>
        </a>
        <a href="/custom/services/growth" class="svc-card">
          <span class="svc-label">06</span>
          <h3 class="svc-title">Growth & Optimisation</h3>
          <p class="svc-desc">SEO, conversion optimisation, analytics, and ongoing strategic guidance.</p>
          <span class="svc-link">Learn more &rarr;</span>
        </a>
      </div>
      <div class="section-link" data-animate="fade-up">
        <a href="/custom/services" class="view-all">Explore all services &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ════ WHY CUSTOM CALLOUT ════ -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <div class="why-callout">
        <h2 class="why-callout-title">Not sure if custom is right for you?</h2>
        <p class="why-callout-desc">Templates work for some businesses. Custom development works for others. We wrote an honest comparison to help you decide — including when we think you should NOT go custom.</p>
        <a href="/custom/why-custom" class="why-callout-link">Read: Is Custom Development Right for You? &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ════ SOLUTIONS TEASER ════ -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Need a CRM? A Booking System? An E-Commerce Platform?"
        subtitle="Eight proven platforms we have already built and refined. You get 80% of the solution on day one — we customise the rest to fit your business exactly."
      />
      <div class="solutions-teaser" data-animate="stagger">
        {highlightedSolutions.map((s) => (
          <a href={`/custom/solutions/${s.slug}`} class="sol-teaser">
            <h3>{s.name}</h3>
            <p>{s.tagline}</p>
          </a>
        ))}
      </div>
      <div class="section-link" data-animate="fade-up">
        <a href="/custom/solutions" class="view-all">View all {solutions.length} solutions &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ════ PORTFOLIO HIGHLIGHTS ════ -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Results, Not Just Deliverables"
        subtitle="Every project here solved a real business problem. Here is what happened."
      />
      <div class="portfolio-grid">
        {featuredProjects.map((project, i) => (
          <div class:list={['portfolio-item', i === 0 ? 'portfolio-item--full' : '']} data-animate="fade-up">
            <PortfolioCard project={project} variant={i === 0 ? 'full' : 'half'} />
          </div>
        ))}
      </div>
      <div class="section-link" data-animate="fade-up">
        <a href="/custom/work" class="view-all">See all work &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ════ SOCIAL PROOF ════ -->
  {featuredProject && (
    <section class="section section-alt">
      <div class="section-inner" data-animate="fade-up">
        <div class="proof">
          <span class="proof-label">Client Spotlight</span>
          <h2 class="proof-name">{featuredProject.clientName}</h2>
          <p class="proof-project">{featuredProject.projectType} &middot; {featuredProject.year}</p>
          {featuredProject.metrics && (
            <div class="proof-metrics">
              {featuredProject.metrics.map((m) => (
                <div class="proof-metric">
                  <span class="proof-val" data-target={m.value} data-decimals={m.decimals || 0} data-suffix={m.suffix}>0{m.suffix}</span>
                  <span class="proof-metric-label">{m.label}</span>
                </div>
              ))}
            </div>
          )}
          {featuredProject.testimonial && (
            <>
              <blockquote class="proof-quote">
                &ldquo;{featuredProject.testimonial.quote}&rdquo;
              </blockquote>
              <p class="proof-author">
                <strong>{featuredProject.testimonial.authorName}</strong>, {featuredProject.testimonial.authorTitle}
              </p>
            </>
          )}
          <a href="/custom/work" class="view-all">See all work &rarr;</a>
        </div>
      </div>
    </section>
  )}

  <!-- ════ CTA BAND ════ -->
  <CtaBand
    heading="Ready to discuss your project?"
    buttonText="Get Your Custom Quote"
    buttonHref="/custom/contact"
  />

  <!-- ════ HOW TO START ════ -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <div class="how-start">
        <h2 class="how-start-title">How to Get Started</h2>
        <p class="how-start-sub">Three steps. No commitment until you are ready.</p>
        <div class="how-start-steps">
          <div class="how-start-step">
            <span class="how-start-num">01</span>
            <h3>Tell us your challenge</h3>
            <p>Fill in the form below — even a rough idea is enough. Takes 2 minutes.</p>
          </div>
          <div class="how-start-step">
            <span class="how-start-num">02</span>
            <h3>Get your proposal</h3>
            <p>We respond within 24 hours with a detailed scope, timeline, and transparent pricing.</p>
          </div>
          <div class="how-start-step">
            <span class="how-start-num">03</span>
            <h3>Start building</h3>
            <p>Approve the proposal and we kick off within one week. You own everything we build.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ CONTACT ════ -->
  <section id="contact" class="section section-dark">
    <div class="section-inner" data-animate="fade-up">
      <QuickEnquiry />
      <ContactForm />
    </div>
  </section>

  <StickyBar />

  <!-- ════ FOOTER ════ -->
  <MicrositeFooter />

  <Animations />
</Layout>

<style>
  /* ── Sections ── */

  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }
  .section-dark { background: var(--color-surface-dark, #1C1917); }

  .section-link { text-align: center; margin-top: 2.5rem; }
  .view-all {
    font-size: 0.8125rem; font-weight: 600; color: var(--color-brand);
    text-decoration: none; transition: opacity 0.3s ease;
  }
  .view-all:hover { opacity: 0.7; }

  /* Intent Router */
  .router-title { font-size: 1.75rem; font-weight: 600; color: var(--color-foreground); text-align: center; margin-bottom: 2rem; letter-spacing: -0.02em; }
  .router-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
  .router-card {
    padding: 1.75rem; border: 1px solid var(--color-divider); border-radius: 0.5rem;
    text-decoration: none; transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .router-card:hover { border-color: var(--color-brand); transform: translateY(-2px); }
  .router-card h3 { font-size: 1rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; }
  .router-card p { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); margin-bottom: 1rem; }
  .router-link { font-size: 0.75rem; font-weight: 600; color: var(--color-brand); }
  .router-card--cta { background: var(--color-brand-light); border-color: var(--color-brand); }

  /* Why Custom Callout */
  .why-callout { max-width: 720px; margin: 0 auto; text-align: center; padding: 2.5rem; border: 1px solid var(--color-divider); border-radius: 0.75rem; background: var(--color-surface); }
  .why-callout-title { font-size: 1.5rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
  .why-callout-desc { font-size: 0.9375rem; line-height: 1.7; color: var(--color-muted); margin-bottom: 1.25rem; }
  .why-callout-link { font-size: 0.875rem; font-weight: 600; color: var(--color-brand); text-decoration: none; }
  .why-callout-link:hover { text-decoration: underline; }

  /* How to Start */
  .how-start { max-width: 800px; margin: 0 auto; text-align: center; }
  .how-start-title { font-size: 2rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
  .how-start-sub { font-size: 1rem; color: var(--color-muted); margin-bottom: 2.5rem; }
  .how-start-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; text-align: left; }
  .how-start-step { padding: 1.5rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .how-start-num { font-size: 0.6875rem; font-weight: 300; color: var(--color-brand); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem; }
  .how-start-step h3 { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.375rem; }
  .how-start-step p { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); }

  /* ── Hero ── */

  .hero {
    min-height: 100vh; min-height: 100dvh;
    display: flex; flex-direction: column; padding: 0 1.5rem;
  }

  .hero-inner {
    max-width: 1200px; width: 100%; margin: 0 auto;
    flex: 1; display: flex; flex-direction: column;
  }

  .hero-content {
    flex: 1; display: flex; flex-direction: column; justify-content: center;
    padding: 2rem 0 4rem; max-width: 720px;
  }

  .hero-title {
    font-size: 3.5rem; font-weight: 700; line-height: 1.08; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1.5rem;
    opacity: 0; animation: slideUp 0.8s ease 1s forwards;
  }

  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted);
    margin-bottom: 2.5rem; max-width: 560px;
    opacity: 0; animation: slideUp 0.8s ease 1.15s forwards;
  }

  .hero-actions {
    display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;
    opacity: 0; animation: slideUp 0.8s ease 1.3s forwards;
  }

  /* ── Buttons ── */

  .btn-primary {
    display: inline-flex; align-items: center; padding: 0.875rem 2rem;
    background: var(--color-brand); color: white;
    font-size: 0.875rem; font-weight: 600; text-decoration: none;
    border-radius: 0.375rem; transition: background-color 0.3s ease;
  }
  .btn-primary:hover { background: var(--color-brand-dark, #C45E0A); }

  .btn-ghost {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.875rem 1.5rem; color: var(--color-foreground);
    font-size: 0.875rem; font-weight: 500; text-decoration: none;
    transition: color 0.3s ease;
  }
  .btn-ghost:hover { color: var(--color-brand); }
  .btn-ghost svg { transition: transform 0.3s ease; }
  .btn-ghost:hover svg { transform: translateX(3px); }

  /* ── Services Teaser ── */

  .services-teaser { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }

  .svc-card {
    display: flex; flex-direction: column; padding: 2rem;
    border: 1px solid var(--color-divider); border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.3s ease, background-color 0.3s ease, transform 0.3s ease;
  }
  .svc-card:hover { border-color: var(--color-brand); background: var(--color-brand-light); transform: translateY(-2px); }

  .svc-label { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); margin-bottom: 0.75rem; }
  .svc-title { font-size: 1.25rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.625rem; letter-spacing: -0.01em; }
  .svc-desc { font-size: 0.8125rem; line-height: 1.65; color: var(--color-muted); flex: 1; margin-bottom: 1.25rem; }
  .svc-link { font-size: 0.75rem; font-weight: 600; color: var(--color-brand); }

  /* ── Solutions Teaser ── */

  .solutions-teaser { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }

  .sol-teaser {
    padding: 1.5rem; border: 1px solid var(--color-divider); border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .sol-teaser:hover { border-color: var(--color-brand); transform: translateY(-2px); }
  .sol-teaser h3 { font-size: 1rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.375rem; }
  .sol-teaser p { font-size: 0.75rem; line-height: 1.5; color: var(--color-muted); }

  /* ── Portfolio Grid ── */

  .portfolio-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .portfolio-item--full { grid-column: 1 / -1; }

  /* ── Social Proof ── */

  .proof { max-width: 720px; margin: 0 auto; text-align: center; }
  .proof-label { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); display: block; margin-bottom: 0.75rem; }
  .proof-name { font-size: 2rem; font-weight: 600; color: var(--color-foreground); letter-spacing: -0.02em; }
  .proof-project { font-size: 1rem; color: var(--color-muted); margin-bottom: 2rem; }

  .proof-metrics { display: flex; justify-content: center; gap: 3rem; margin-bottom: 2.5rem; }
  .proof-metric { text-align: center; }
  .proof-val { display: block; font-size: 2rem; font-weight: 700; color: var(--color-brand); letter-spacing: -0.02em; }
  .proof-metric-label { font-size: 0.6875rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-muted); margin-top: 0.25rem; display: block; }

  .proof-quote { font-size: 1.0625rem; line-height: 1.7; color: var(--color-foreground); font-style: italic; margin-bottom: 1.25rem; max-width: 600px; margin-left: auto; margin-right: auto; }
  .proof-author { font-size: 0.875rem; color: var(--color-muted); margin-bottom: 2rem; }
  .proof-author strong { color: var(--color-foreground); font-weight: 600; }

  /* ── Keyframes ── */

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Reduced Motion ── */

  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-lead, .hero-actions {
      animation: none !important; opacity: 1 !important;
    }
  }

  /* ── Mobile ── */

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }

    .hero { min-height: auto; }
    .hero-content { padding: 3rem 0; }
    .hero-title { font-size: 2.25rem; }
    .hero-lead { font-size: 0.9375rem; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .btn-primary { width: 100%; justify-content: center; }

    .services-teaser, .portfolio-grid { grid-template-columns: 1fr; }
    .router-grid { grid-template-columns: 1fr; }
    .how-start-steps { grid-template-columns: 1fr; }
    .solutions-teaser { grid-template-columns: 1fr 1fr; }
    .portfolio-item--full { grid-column: auto; }
    .proof-metrics { flex-direction: column; gap: 1.5rem; }
  }
</style>
