---
import Layout from '../layouts/Layout.astro';
import EntranceOverlay from '../components/EntranceOverlay.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TrustBar from '../components/TrustBar.astro';
import CtaBand from '../components/CtaBand.astro';
import ContactForm from '../components/ContactForm.astro';
import QuickEnquiry from '../components/QuickEnquiry.astro';
import SupportHeader from '../components/SupportHeader.astro';
import SupportFooter from '../components/SupportFooter.astro';
import Animations from '../components/Animations.astro';
import { supportServices } from '../data/support-services';
import { supportPackages } from '../data/support-packages';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Website Support & Maintenance',
  description: 'Managed website support for any platform. Security, monitoring, content updates, and emergency support from MYR 1,500/month.',
  provider: { '@type': 'Organization', name: 'Orangesoft', url: 'https://orangesoft.com.my' },
  areaServed: { '@type': 'Country', name: 'Malaysia' },
  serviceType: 'Website Maintenance',
};
---

<Layout
  title="Website Support & Maintenance | Orangesoft"
  description="Managed website support for any platform. Security updates, performance monitoring, content management, and 24/7 emergency support. From MYR 1,500/month."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <EntranceOverlay />

  <section id="hero" class="hero">
    <div class="hero-inner">
      <SupportHeader />
      <div class="hero-content">
        <h1 class="hero-title">
          Your Website Deserves<br />Better Than "Set It<br />and Forget It"
        </h1>
        <p class="hero-lead">
          Security vulnerabilities do not wait. Performance degrades silently. Content requests pile up. We keep your website fast, secure, and up to date — so you never have to worry about what is happening behind the scenes.
        </p>
        <div class="hero-actions">
          <a href="/support/contact" class="btn-primary">Get a Maintenance Quote</a>
          <a href="/support/pricing" class="btn-ghost">See Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Services -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Six Managed Services. One Monthly Fee."
        subtitle="Everything your website needs to stay healthy, secure, and performing."
      />
      <div class="services-grid" data-animate="stagger">
        {supportServices.map((svc, i) => (
          <div class="svc-card">
            <span class="svc-label">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="svc-title">{svc.name}</h3>
            <p class="svc-desc">{svc.description}</p>
          </div>
        ))}
      </div>
      <div class="section-link" data-animate="fade-up">
        <a href="/support/services" class="view-all">See full service details &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <div class="platforms">
        <h2 class="platforms-title">We Maintain Any Platform</h2>
        <p class="platforms-desc">You do not need to be an existing Orangesoft client. If it runs on the web, we can maintain it.</p>
        <div class="platform-tags">
          <span>NuxtJS</span><span>Laravel</span><span>WordPress</span><span>Kentico</span>
          <span>Magento</span><span>Drupal</span><span>Strapi</span><span>Static Sites</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing teaser -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading title="Simple, Transparent Pricing" subtitle="Three monthly plans. No long-term contracts after the first 3 months." />
      <div class="pricing-grid" data-animate="stagger">
        {supportPackages.map((pkg) => (
          <div class="pkg-card">
            <h3 class="pkg-name">{pkg.name}</h3>
            <p class="pkg-tagline">{pkg.tagline}</p>
            <div class="pkg-price">
              <span class="pkg-from">From</span>
              <span class="pkg-amount">MYR {pkg.price}</span>
              <span class="pkg-period">/month</span>
            </div>
            <p class="pkg-response">Response: {pkg.responseTime}</p>
          </div>
        ))}
      </div>
      <div class="section-link" data-animate="fade-up">
        <a href="/support/pricing" class="view-all">Compare all packages &rarr;</a>
      </div>
    </div>
  </section>

  <!-- How to Start -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <div class="how-start">
        <h2 class="how-start-title">How to Get Started</h2>
        <div class="how-start-steps">
          <div class="how-start-step">
            <span class="how-start-num">01</span>
            <h3>Tell us about your platform</h3>
            <p>Share your website URL and hosting details. We run a free health check.</p>
          </div>
          <div class="how-start-step">
            <span class="how-start-num">02</span>
            <h3>We onboard your site</h3>
            <p>Monitoring, backups, and staging set up in 3-5 business days. Zero downtime.</p>
          </div>
          <div class="how-start-step">
            <span class="how-start-num">03</span>
            <h3>Relax — we have got it</h3>
            <p>Monthly reports, proactive updates, and a dedicated channel for requests.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to hand off your website maintenance?" buttonText="Get Your Maintenance Quote" buttonHref="/support/contact" />

  <section id="contact" class="section section-dark">
    <div class="section-inner" data-animate="fade-up">
      <QuickEnquiry />
      <ContactForm />
    </div>
  </section>

  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }
  .section-dark { background: var(--color-surface-dark, #1C1917); }
  .section-link { text-align: center; margin-top: 2.5rem; }
  .view-all { font-size: 0.8125rem; font-weight: 600; color: var(--color-brand); text-decoration: none; }
  .view-all:hover { opacity: 0.7; }

  .hero { min-height: 100vh; min-height: 100dvh; display: flex; flex-direction: column; padding: 0 1.5rem; }
  .hero-inner { max-width: 1200px; width: 100%; margin: 0 auto; flex: 1; display: flex; flex-direction: column; }
  .hero-content { flex: 1; display: flex; flex-direction: column; justify-content: center; padding: 2rem 0 4rem; max-width: 720px; }
  .hero-title { font-size: 3.5rem; font-weight: 700; line-height: 1.08; letter-spacing: -0.03em; color: var(--color-foreground); margin-bottom: 1.5rem; opacity: 0; animation: slideUp 0.8s ease 1s forwards; }
  .hero-lead { font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); margin-bottom: 2.5rem; max-width: 560px; opacity: 0; animation: slideUp 0.8s ease 1.15s forwards; }
  .hero-actions { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; opacity: 0; animation: slideUp 0.8s ease 1.3s forwards; }

  .btn-primary { display: inline-flex; padding: 0.875rem 2rem; background: var(--color-brand); color: white; font-size: 0.875rem; font-weight: 600; text-decoration: none; border-radius: 0.375rem; transition: background-color 0.3s ease; }
  .btn-primary:hover { background: var(--color-brand-dark, #C45E0A); }
  .btn-ghost { display: inline-flex; padding: 0.875rem 1.5rem; color: var(--color-foreground); font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: color 0.3s ease; }
  .btn-ghost:hover { color: var(--color-brand); }

  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .svc-card { padding: 1.75rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .svc-label { font-size: 0.6875rem; font-weight: 300; color: var(--color-brand); letter-spacing: 0.1em; margin-bottom: 0.75rem; display: block; }
  .svc-title { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.5rem; }
  .svc-desc { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); }

  .platforms { max-width: 720px; margin: 0 auto; text-align: center; }
  .platforms-title { font-size: 2rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.75rem; letter-spacing: -0.02em; }
  .platforms-desc { font-size: 1rem; line-height: 1.7; color: var(--color-muted); margin-bottom: 1.5rem; }
  .platform-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; }
  .platform-tags span { padding: 0.5rem 1rem; border: 1px solid var(--color-divider); border-radius: 2rem; font-size: 0.8125rem; font-weight: 500; color: var(--color-foreground); }

  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .pkg-card { padding: 2rem; border: 1px solid var(--color-divider); border-radius: 0.75rem; }
  .pkg-name { font-size: 1.25rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.25rem; }
  .pkg-tagline { font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 1.25rem; }
  .pkg-price { margin-bottom: 1rem; }
  .pkg-from { display: block; font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-muted); }
  .pkg-amount { font-size: 1.5rem; font-weight: 700; color: var(--color-brand); }
  .pkg-period { font-size: 0.8125rem; color: var(--color-muted); }
  .pkg-response { font-size: 0.75rem; color: var(--color-muted); }

  .how-start { max-width: 800px; margin: 0 auto; text-align: center; }
  .how-start-title { font-size: 2rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 2rem; letter-spacing: -0.02em; }
  .how-start-steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; text-align: left; }
  .how-start-step { padding: 1.5rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .how-start-num { font-size: 0.6875rem; font-weight: 300; color: var(--color-brand); letter-spacing: 0.1em; display: block; margin-bottom: 0.75rem; }
  .how-start-step h3 { font-size: 1.0625rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.375rem; }
  .how-start-step p { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead, .hero-actions { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero { min-height: auto; }
    .hero-content { padding: 3rem 0; }
    .hero-title { font-size: 2.25rem; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .btn-primary { width: 100%; justify-content: center; }
    .services-grid, .pricing-grid, .how-start-steps { grid-template-columns: 1fr; }
  }
</style>
