---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import SupportHeader from '../../../components/SupportHeader.astro';
import SupportFooter from '../../../components/SupportFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import FaqItem from '../../../components/FaqItem.astro';
import TrustStrip from '../../../components/TrustStrip.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import { industries, type Industry } from '../../../data/industries';

export function getStaticPaths() {
  return industries.map((ind) => ({
    params: { slug: ind.slug },
    props: { industry: ind },
  }));
}

interface Props {
  industry: Industry;
}

const { industry } = Astro.props;

/* ---------- Support-specific content mappings ---------- */

const supportTaglines: Record<string, string> = {
  'property': 'Keep your property listings, virtual tours, and lead capture running flawlessly around the clock.',
  'financial-services': 'Continuous security monitoring and compliance maintenance for regulated financial platforms.',
  'manufacturing': 'Reliable uptime and proactive maintenance for mission-critical operational dashboards.',
  'healthcare': 'Secure, accessible, and always-available patient portals and healthcare platforms.',
  'education': 'Uninterrupted learning platforms and enrollment systems throughout the academic year.',
  'government': 'High-availability maintenance for public-facing services that citizens depend on.',
  'retail-ecommerce': 'Peak-performance maintenance so your store never loses a sale to downtime.',
  'hospitality': 'Round-the-clock support keeping your booking engine and guest experience online.',
};

const supportDescriptions: Record<string, string> = {
  'property': 'Property websites are your 24/7 sales showroom. When listings fail to load, virtual tours break, or contact forms stop capturing leads, you lose qualified buyers. Our support packages keep your property platform fast, secure, and always available — so your marketing spend never goes to waste.',
  'financial-services': 'Financial platforms handle sensitive data under strict regulatory oversight. A security breach or unexpected downtime can damage client trust and trigger compliance issues. Our maintenance services provide continuous security monitoring, encrypted backup management, and rapid incident response tailored to PDPA and BNM requirements.',
  'manufacturing': 'Manufacturing platforms connect procurement, inventory, and vendor operations in real time. When dashboards go down or integrations break, decisions stall and costs accumulate. Our support ensures your operational systems stay synchronised, performant, and available across every shift.',
  'healthcare': 'Patient portals and appointment systems must be accessible, secure, and reliable at all times. Downtime means missed appointments, frustrated patients, and potential compliance risks. Our maintenance packages provide WCAG compliance monitoring, encrypted data handling, and priority response for healthcare-critical issues.',
  'education': 'Learning management systems, enrollment portals, and campus websites face peak demand during registration periods and exam seasons. Our support services ensure your platforms scale smoothly during high-traffic windows and stay updated, secure, and accessible throughout the academic calendar.',
  'government': 'Government platforms serve citizens who have no alternative. Accessibility failures, security vulnerabilities, or downtime erode public trust. Our maintenance services provide WCAG compliance monitoring, multi-language support, high-availability infrastructure management, and rapid response times that meet public sector SLAs.',
  'retail-ecommerce': 'Every minute of downtime during a sale event costs revenue. Slow page loads increase cart abandonment. Our e-commerce support packages include performance monitoring, traffic spike preparation, security patching, and priority emergency response — so your store stays fast and secure when it matters most.',
  'hospitality': 'Guests book at all hours from every time zone. A broken booking engine or slow-loading website sends potential guests straight to OTA competitors. Our support packages keep your direct booking platform fast, secure, and available 24/7 — protecting your margins from OTA commissions.',
};

const supportRecommendations: Record<string, string> = {
  'property': 'We recommend the Professional package for property firms — it includes monthly performance reviews to keep listing pages fast, priority content updates for new launches, security monitoring to protect lead data, and staging environments so marketing campaigns never break the live site.',
  'financial-services': 'Financial services clients typically need the Enterprise package. It includes 24/7 security monitoring, encrypted daily backups with compliance-ready retention policies, priority emergency response under 1-hour SLA, and dedicated account management to coordinate with your IT and compliance teams.',
  'manufacturing': 'For manufacturing operations, the Professional package covers proactive server monitoring, API health checks to keep ERP integrations stable, scheduled maintenance windows outside production hours, and monthly performance reports. Enterprise is recommended when multiple locations depend on the platform.',
  'healthcare': 'Healthcare organisations benefit from the Enterprise package with its enhanced security monitoring, WCAG accessibility audits, encrypted backup management, and priority emergency response. The dedicated account manager ensures maintenance activities align with clinical schedules and compliance requirements.',
  'education': 'We recommend the Professional package for educational institutions — it includes traffic scaling support during enrollment peaks, regular CMS and plugin updates timed around the academic calendar, monthly performance reviews, and content management support for programme updates and event pages.',
  'government': 'Government agencies require the Enterprise package for its 24/7 monitoring, priority emergency response under 1-hour SLA, WCAG accessibility compliance checks, multi-language content support, and dedicated account management. All maintenance activities are documented for audit and compliance purposes.',
  'retail-ecommerce': 'E-commerce businesses need the Professional or Enterprise package depending on scale. Both include uptime monitoring, security patching, and performance optimisation. Enterprise adds pre-sale traffic preparation, 24/7 emergency response, and dedicated support during campaign periods to ensure zero revenue loss from technical issues.',
  'hospitality': 'Hospitality clients benefit from the Professional package — it covers 24/7 uptime monitoring for your booking engine, regular performance optimisation to keep page speeds under 2 seconds, security updates to protect guest data, and priority support for rate and availability issues that directly impact revenue.',
};

const maintenanceChallengeFraming: Record<string, string[]> = {
  'property': [
    'Listing pages slowing down as the portfolio grows, costing qualified leads',
    'CMS updates and plugin patches breaking virtual tour integrations',
    'Contact forms failing silently — leads lost without anyone noticing',
    'No monitoring in place to catch downtime before prospects do',
  ],
  'financial-services': [
    'Security vulnerabilities in dependencies going unpatched for months',
    'No audit trail for who accessed or changed what on the platform',
    'SSL certificates and compliance configurations expiring without warning',
    'Legacy integrations breaking after upstream API changes',
  ],
  'manufacturing': [
    'Dashboard downtime during production hours disrupting procurement decisions',
    'ERP integrations silently failing, causing data synchronisation gaps',
    'No scheduled maintenance windows — updates happen ad hoc and cause issues',
    'Server performance degrading as data volume grows month over month',
  ],
  'healthcare': [
    'Patient portal accessibility regressions introduced by routine updates',
    'Backup and disaster recovery procedures untested and potentially unreliable',
    'Security patches delayed due to fear of breaking clinical workflows',
    'No monitoring for form submission failures on appointment booking systems',
  ],
  'education': [
    'Platform crashes during peak enrollment and registration periods',
    'CMS and LMS plugins falling behind on security updates',
    'No performance baseline — slowdowns go unnoticed until students complain',
    'Content updates requiring developer involvement instead of staff self-service',
  ],
  'government': [
    'Accessibility compliance drifting out of WCAG standards after content updates',
    'High-availability requirements with no proactive monitoring in place',
    'Security patching delayed by complex approval processes',
    'Multi-language content becoming out of sync across platform updates',
  ],
  'retail-ecommerce': [
    'Site slowdowns during flash sales and marketing campaigns costing revenue',
    'Payment gateway integrations breaking after uncoordinated platform updates',
    'No load testing or traffic preparation before major promotional events',
    'Security vulnerabilities in e-commerce plugins exposing customer data',
  ],
  'hospitality': [
    'Booking engine downtime outside business hours when most guests search',
    'Channel manager integrations failing and causing overbooking or rate mismatches',
    'Slow page loads on mobile driving guests to OTA competitors',
    'No proactive monitoring — issues discovered by guests, not by your team',
  ],
};

const supportServiceMap: Record<string, { label: string; slug: string }[]> = {
  'property': [
    { label: 'Uptime & Monitoring', slug: 'monitoring' },
    { label: 'Content Management', slug: 'content' },
    { label: 'Performance Optimisation', slug: 'optimisation' },
    { label: 'Security & Updates', slug: 'security' },
  ],
  'financial-services': [
    { label: 'Security & Updates', slug: 'security' },
    { label: 'Uptime & Monitoring', slug: 'monitoring' },
