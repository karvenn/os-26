    { label: 'Security & Updates', slug: 'security' },
  ],
  'hospitality': [
    { label: 'Uptime & Monitoring', slug: 'monitoring' },
    { label: 'Performance Optimisation', slug: 'optimisation' },
    { label: 'Security & Updates', slug: 'security' },
    { label: 'Content Management', slug: 'content' },
  ],
};

const packageRecommendations: Record<string, { label: string; slug: string }[]> = {
  'property': [
    { label: 'Professional', slug: 'professional' },
    { label: 'Essential', slug: 'essential' },
  ],
  'financial-services': [
    { label: 'Enterprise', slug: 'enterprise' },
    { label: 'Professional', slug: 'professional' },
  ],
  'manufacturing': [
    { label: 'Professional', slug: 'professional' },
    { label: 'Enterprise', slug: 'enterprise' },
  ],
  'healthcare': [
    { label: 'Enterprise', slug: 'enterprise' },
    { label: 'Professional', slug: 'professional' },
  ],
  'education': [
    { label: 'Professional', slug: 'professional' },
    { label: 'Essential', slug: 'essential' },
  ],
  'government': [
    { label: 'Enterprise', slug: 'enterprise' },
  ],
  'retail-ecommerce': [
    { label: 'Professional', slug: 'professional' },
    { label: 'Enterprise', slug: 'enterprise' },
  ],
  'hospitality': [
    { label: 'Professional', slug: 'professional' },
    { label: 'Essential', slug: 'essential' },
  ],
};

const supportFaq: Record<string, { question: string; answer: string }[]> = {
  'property': [
    { question: 'Can you update property listings and launch pages for us?', answer: 'Yes. Our content management service handles listing updates, new launch pages, price changes, and status updates. With the Professional package, you get priority content turnaround so new developments go live quickly.' },
    { question: 'What happens if our site goes down during a weekend open house?', answer: 'Our monitoring detects downtime within minutes. With Professional and Enterprise packages, our team responds to critical issues within the SLA window — including weekends. Emergency support ensures your site is back before visitors leave the showroom.' },
    { question: 'Do you monitor lead capture forms?', answer: 'Yes. We monitor form submissions and alert you to failures. No more silent form errors losing potential buyers. We also test forms after every platform update to ensure they continue working correctly.' },
  ],
  'financial-services': [
    { question: 'How do you handle security patching for financial platforms?', answer: 'We apply security patches within 24 hours for critical vulnerabilities. All patches are tested on staging before deployment, and every change is logged with timestamps for your compliance audit trail.' },
    { question: 'Can you provide documentation for regulatory audits?', answer: 'Yes. Enterprise clients receive detailed maintenance logs, security patch histories, backup verification reports, and access audit trails. All documentation is formatted to support PDPA and BNM compliance reviews.' },
    { question: 'What is your incident response time for financial platforms?', answer: 'Enterprise package includes a 1-hour response SLA for critical issues. We classify incidents by severity and prioritise anything affecting data security, transaction processing, or customer portal access.' },
  ],
  'manufacturing': [
    { question: 'Can maintenance be scheduled outside production hours?', answer: 'Absolutely. We schedule all updates, patches, and maintenance activities during your designated windows — typically nights or weekends. Production-hour maintenance only happens for critical security patches, and always with advance notice.' },
    { question: 'How do you monitor ERP integrations?', answer: 'We set up health checks on API endpoints that connect your web platform to your ERP. When synchronisation fails or response times degrade, our team is alerted and investigates before the issue impacts operations.' },
    { question: 'What if our platform slows down as data grows?', answer: 'Our monthly performance reviews identify degradation trends early. We proactively recommend and implement database optimisation, caching improvements, and infrastructure scaling before slowdowns affect your users.' },
  ],
  'healthcare': [
    { question: 'Do you monitor WCAG accessibility compliance?', answer: 'Yes. We run regular accessibility audits against WCAG 2.1 AA standards and fix regressions introduced by content updates or platform changes. This is included in Professional and Enterprise packages.' },
    { question: 'How are patient data backups handled?', answer: 'All backups are encrypted at rest and in transit. We verify backup integrity monthly and test restoration procedures quarterly. Enterprise clients receive backup verification reports for compliance documentation.' },
    { question: 'Can you coordinate maintenance with clinical schedules?', answer: 'Yes. Enterprise clients have a dedicated account manager who coordinates all maintenance activities around your clinical calendar, ensuring patient-facing systems are never disrupted during operating hours.' },
  ],
  'education': [
    { question: 'Can your support scale during enrollment periods?', answer: 'Yes. We proactively prepare your infrastructure before enrollment peaks — load testing, cache warming, and resource scaling. During peak periods, we increase monitoring frequency and have the team on standby for rapid response.' },
    { question: 'Do you handle CMS and LMS plugin updates?', answer: 'Yes. We manage all plugin, theme, and core updates on a regular schedule. Every update is tested on staging first, and we time updates to avoid disrupting classes or assessment periods.' },
    { question: 'Can staff update content without developers?', answer: 'If your CMS is set up for self-service, we ensure it stays that way through updates. If not, our content management service handles routine updates, and we can also train your staff on the CMS during the onboarding process.' },
  ],
  'government': [
    { question: 'Do you meet government SLA requirements?', answer: 'Our Enterprise package provides the response times and uptime guarantees that government agencies require. We document all SLA metrics monthly and provide reports formatted for government procurement and audit processes.' },
    { question: 'How do you handle multi-language content maintenance?', answer: 'We manage content updates across all language versions, ensuring translations stay synchronised. When content changes in the primary language, we flag the corresponding pages in other languages for review and update.' },
    { question: 'Can you deploy on government-approved infrastructure?', answer: 'Yes. Our hosting management service supports government-approved cloud providers and on-premises infrastructure. We manage the server environment regardless of where it is hosted, maintaining the same monitoring and security standards.' },
  ],
  'retail-ecommerce': [
    { question: 'How do you prepare for sale events and traffic spikes?', answer: 'Before major campaigns, we load-test your platform, optimise caching, pre-scale infrastructure, and set up enhanced monitoring. During the event, our team is on standby for immediate response to any performance issues.' },
    { question: 'What if a payment gateway integration breaks?', answer: 'Payment integrations are classified as critical. Our monitoring detects gateway failures in real time, and our team responds within the SLA window to restore transaction processing. We test gateway connections after every platform update.' },
    { question: 'Do you handle security for customer payment data?', answer: 'We maintain PCI-compliant configurations, apply security patches promptly, and monitor for vulnerabilities in your e-commerce stack. All customer data handling follows encryption best practices, and we provide security reports for your records.' },
  ],
  'hospitality': [
    { question: 'Is 24/7 monitoring included for booking engines?', answer: 'Yes. Professional and Enterprise packages include round-the-clock uptime monitoring. Booking engine downtime triggers immediate alerts, and our team responds within the SLA window — because guests book at all hours.' },
    { question: 'How do you handle channel manager integration issues?', answer: 'We monitor the API connections between your website and channel managers (SiteMinder, Cloudbeds, etc.). When synchronisation fails, we investigate and resolve the issue to prevent overbooking or rate discrepancies across channels.' },
    { question: 'Can you help optimise page speed for mobile guests?', answer: 'Yes. Our performance optimisation service includes image compression, caching configuration, and Core Web Vitals improvements. Most booking decisions happen on mobile, so we prioritise mobile performance in every review.' },
  ],
};

const challenges = maintenanceChallengeFraming[industry.slug] || industry.challenges;
const tagline = supportTaglines[industry.slug] || industry.tagline;
const description = supportDescriptions[industry.slug] || industry.description;
const recommendation = supportRecommendations[industry.slug] || industry.recommendation;
const services = supportServiceMap[industry.slug] || [];
const packages = packageRecommendations[industry.slug] || [];
const faq = supportFaq[industry.slug] || industry.faq;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'Industries', item: 'https://orangesoft.com.my/support/industries' },
    { '@type': 'ListItem', position: 3, name: industry.name, item: `https://orangesoft.com.my/support/industries/${industry.slug}` },
  ],
};

const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
} : null;
---

<Layout
  title={`${industry.name} Support & Maintenance | Orangesoft`}
  description={description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="industries" />
  <Breadcrumb items={[
    { label: 'Home', href: '/support' },
    { label: 'Industries', href: '/support/industries' },
    { label: industry.name },
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <span class="hero-label">{industry.name} Support</span>
      <h1 class="hero-title">{tagline}</h1>
      <p class="hero-desc">{description}</p>
      <a href="/support/contact" class="btn-primary">Discuss {industry.name} Support</a>
    </div>
  </section>

  <TrustStrip />

  <!-- Maintenance Challenges -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading title="Maintenance Challenges You Face" subtitle={`Common support pain points for ${industry.name.toLowerCase()} platforms.`} />
      <div class="challenges" data-animate="stagger">
        {challenges.map((c, i) => (
          <div class="challenge">
            <span class="challenge-num">{String(i + 1).padStart(2, '0')}</span>
            <p>{c}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Recommendation -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading title="What We Recommend" subtitle="The maintenance package and services we recommend for this industry." />
      <div class="recommendation">
        <p>{recommendation}</p>
      </div>
    </div>
  </section>

  <!-- Recommended Services -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading title="Relevant Support Services" subtitle="The maintenance services most critical for organisations in this industry." />
      <div class="services-list" data-animate="stagger">
        {services.map((svc) => (
          <a href={`/support/services/${svc.slug}`} class="svc-pill">
            {svc.label} &rarr;
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recommended Packages -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading title="Recommended Packages" subtitle="Support packages that match this industry's requirements." />
      <div class="packages-list" data-animate="stagger">
        {packages.map((pkg) => (
          <a href={`/support/packages/${pkg.slug}`} class="pkg-card">
            <span class="pkg-label">Recommended</span>
            <h3 class="pkg-name">{pkg.label}</h3>
            <p class="pkg-desc">
              {pkg.slug === 'essential' && 'Core maintenance essentials — monitoring, security updates, and monthly reporting for smaller platforms.'}
              {pkg.slug === 'professional' && 'Proactive maintenance with priority response, performance reviews, staging environments, and content support.'}
              {pkg.slug === 'enterprise' && 'Full-service support with 24/7 monitoring, 1-hour emergency SLA, dedicated account manager, and compliance documentation.'}
            </p>
            <span class="pkg-cta">View Package &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- What We Have Maintained -->
  {industry.projects.length > 0 && (
    <section class="section section-alt">
      <div class="section-inner">
        <SectionHeading title="What We Have Maintained" subtitle={`Selected projects for ${industry.name.toLowerCase()} clients.`} />
        <div class="project-list" data-animate="stagger">
          {industry.projects.map((p) => (
            <div class="project-card">
              <div class="project-link">
                <span class="project-type">{p.type}</span>
                <h3 class="project-name">{p.clientName}</h3>
                <p class="project-headline">{p.headline}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  {faq.length > 0 && (
    <section class="section">
      <div class="section-inner section-inner--narrow">
        <SectionHeading title={`${industry.name} Support FAQ`} />
        <div data-animate="fade-up">
          {faq.map((f) => <FaqItem question={f.question} answer={f.answer} />)}
        </div>
      </div>
    </section>
  )}

  <CtaBand heading={`Ready to discuss ${industry.name.toLowerCase()} support?`} buttonText="Get a Support Quote" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-inner--narrow { max-width: 800px; }
  .section-alt { background: white; }

  .hero { padding: 4rem 1.5rem 3rem; }
  .hero-label { display: inline-block; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-brand); margin-bottom: 1rem; opacity: 0; animation: slideUp 0.6s ease 1s forwards; }
  .hero-title { font-size: 2.5rem; font-weight: 700; line-height: 1.15; letter-spacing: -0.03em; color: var(--color-foreground); margin-bottom: 1.25rem; opacity: 0; animation: slideUp 0.7s ease 1.1s forwards; }
  .hero-desc { font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px; margin-bottom: 2rem; opacity: 0; animation: slideUp 0.7s ease 1.2s forwards; }
  .btn-primary { display: inline-flex; padding: 0.875rem 2rem; background: var(--color-brand); color: white; font-size: 0.875rem; font-weight: 600; text-decoration: none; border-radius: 0.375rem; transition: background-color 0.3s ease; opacity: 0; animation: slideUp 0.7s ease 1.3s forwards; }
  .btn-primary:hover { background: var(--color-brand-dark, #C45E0A); }

  /* Challenges */
  .challenges { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .challenge { display: flex; gap: 1rem; padding: 1.5rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; }
  .challenge-num { font-size: 0.6875rem; font-weight: 300; color: var(--color-brand); letter-spacing: 0.1em; flex-shrink: 0; padding-top: 0.15rem; }
  .challenge p { font-size: 0.875rem; line-height: 1.6; color: var(--color-muted); }

  /* Recommendation */
  .recommendation { max-width: 720px; padding: 2rem; border-left: 3px solid var(--color-brand); background: var(--color-brand-light); border-radius: 0 0.5rem 0.5rem 0; }
  .recommendation p { font-size: 1rem; line-height: 1.8; color: var(--color-foreground); }

  /* Services pills */
  .services-list { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .svc-pill {
    display: inline-flex; padding: 0.75rem 1.25rem; border: 1px solid var(--color-divider);
    border-radius: 0.5rem; text-decoration: none; font-size: 0.875rem; font-weight: 500;
    color: var(--color-foreground); transition: border-color 0.3s ease, background-color 0.3s ease;
  }
  .svc-pill:hover { border-color: var(--color-brand); background: var(--color-brand-light); }

  /* Package cards */
  .packages-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; }
  .pkg-card {
    display: flex; flex-direction: column; padding: 2rem; border: 1px solid var(--color-divider);
    border-radius: 0.75rem; text-decoration: none;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .pkg-card:hover { border-color: var(--color-brand); transform: translateY(-2px); }
  .pkg-label { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); margin-bottom: 0.5rem; }
  .pkg-name { font-size: 1.25rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.75rem; letter-spacing: -0.01em; }
  .pkg-desc { font-size: 0.8125rem; line-height: 1.6; color: var(--color-muted); margin-bottom: 1.25rem; flex: 1; }
  .pkg-cta { font-size: 0.75rem; font-weight: 600; color: var(--color-brand); }

  /* Project cards */
  .project-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .project-link { display: block; padding: 1.75rem; border: 1px solid var(--color-divider); border-radius: 0.5rem; text-decoration: none; transition: border-color 0.3s ease, transform 0.3s ease; }
  .project-type { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-brand); display: block; margin-bottom: 0.5rem; }
