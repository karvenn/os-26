---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import SupportHeader from '../../components/SupportHeader.astro';
import SupportFooter from '../../components/SupportFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FaqItem from '../../components/FaqItem.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
import { supportServices } from '../../data/support-services';
import { supportPackages } from '../../data/support-packages';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: 'https://orangesoft.com.my/support/faq' },
  ],
};

const generalFaqs = [
  {
    question: 'What platforms do you support?',
    answer: 'We manage websites built on any platform: WordPress, Kentico, Shopify, custom-built applications (Laravel, Next.js, Astro, etc.), headless CMS setups, and more. If it runs on the web, we can maintain it.',
  },
  {
    question: 'Do I need to move my hosting to you?',
    answer: 'No. We manage your website on your existing hosting infrastructure. We work with AWS, Google Cloud, DigitalOcean, Cloudways, Vercel, Netlify, and most shared hosting providers. If you would like to migrate, we handle that too.',
  },
  {
    question: 'How does onboarding work?',
    answer: 'We start with a comprehensive audit of your platform, documenting the tech stack, hosting setup, integrations, and any existing issues. We then set up monitoring, backups, and communication channels. The full onboarding takes 1 to 2 weeks.',
  },
  {
    question: 'What is the minimum contract length?',
    answer: 'We recommend a 6-month initial commitment so we can properly onboard your platform and demonstrate measurable value. After that, contracts renew month-to-month with 30 days notice to cancel.',
  },
  {
    question: 'Can I upgrade or downgrade my package?',
    answer: 'Yes. Upgrades can be applied at any time on a pro-rata basis. Downgrades take effect at the start of the next billing cycle with 30 days notice.',
  },
  {
    question: 'How do you communicate with our team?',
    answer: 'Essential: email support during business hours. Professional: email plus a dedicated Slack channel. Enterprise: email, Slack, phone, and WhatsApp. All packages include a monthly health report.',
  },
  {
    question: 'What happens if our site goes down at night?',
    answer: 'Our monitoring detects downtime within 60 seconds. Essential packages receive business-hours response. Professional packages have extended hours until 10pm. Enterprise packages receive 24/7 response including weekends and holidays.',
  },
  {
    question: 'Do you handle content updates?',
    answer: 'Yes. Content updates are included in every package: 2 hours (Essential), 5 hours (Professional), or 10 hours (Enterprise) per month. Additional hours are available at MYR 250/hour.',
  },
  {
    question: 'What does a monthly health report include?',
    answer: 'Uptime statistics, performance metrics (load time, Core Web Vitals), security scan results, a summary of all changes made during the month, and recommendations for improvement.',
  },
  {
    question: 'Can you maintain a site built by another agency?',
    answer: 'Absolutely. A significant proportion of our clients come from other agencies. We audit the existing codebase, document it, and take over maintenance. If there are underlying issues, we will flag them and recommend a plan to address them.',
  },
];

const allServiceFaqs = supportServices.flatMap((s) =>
  s.faq.map((f) => ({ ...f, category: s.name }))
);

const allPackageFaqs = supportPackages.flatMap((p) =>
  p.faq.map((f) => ({ ...f, category: `${p.name} Package` }))
);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [...generalFaqs, ...allServiceFaqs, ...allPackageFaqs].map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<Layout
  title="FAQ | Orangesoft Support"
  description="Frequently asked questions about Orangesoft managed website support: platforms, pricing, onboarding, SLAs, and everything else you need to know."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="services" />
  <Breadcrumb items={[{ label: 'Home', href: '/support' }, { label: 'FAQ' }]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Frequently Asked<br />Questions</h1>
      <p class="hero-lead">
        Everything you need to know about our managed support service, from onboarding to day-to-day operations. Can not find your answer? <a href="/support/contact" class="hero-link">Get in touch</a>.
      </p>
    </div>
  </section>

  <!-- General FAQ -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="General Questions"
        subtitle="The most common questions about our managed support service."
      />
      <div class="faq-list">
        {generalFaqs.map((item) => (
          <FaqItem question={item.question} answer={item.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- Service FAQ -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Service-Specific Questions"
        subtitle="Questions about individual managed services."
      />
      <div class="faq-groups">
        {supportServices.map((service) => (
          <div class="faq-group">
            <h3 class="faq-group-title">
              <a href={`/support/services/${service.slug}`}>{service.name}</a>
            </h3>
            <div class="faq-list">
              {service.faq.map((item) => (
                <FaqItem question={item.question} answer={item.answer} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Package FAQ -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Package Questions"
        subtitle="Questions about specific support tiers."
      />
      <div class="faq-groups">
        {supportPackages.map((pkg) => (
          <div class="faq-group">
            <h3 class="faq-group-title">
              <a href={`/support/packages/${pkg.slug}`}>{pkg.name} Package</a>
            </h3>
            <div class="faq-list">
              {pkg.faq.map((item) => (
                <FaqItem question={item.question} answer={item.answer} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Still Have Questions -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <div class="still-block">
        <h2 class="still-title">Still Have Questions?</h2>
        <p class="still-text">
          We are happy to answer any questions that are not covered here. Every enquiry receives a personal response from our support team within 24 hours.
        </p>
        <a href="/support/contact" class="still-btn">Contact Our Team</a>
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to hand off your website maintenance?" buttonText="Get a Support Quote" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 560px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }
  .hero-link { color: var(--color-brand); text-decoration: none; font-weight: 600; }
  .hero-link:hover { text-decoration: underline; }

  /* FAQ Lists */
  .faq-list {
    max-width: 720px;
    border-top: 1px solid var(--color-divider);
  }

  /* FAQ Groups */
  .faq-groups {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .faq-group-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .faq-group-title a {
    color: var(--color-foreground);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .faq-group-title a:hover { color: var(--color-brand); }

  /* Still Block */
  .still-block {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .still-title {
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .still-text {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .still-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: var(--color-foreground);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background-color 0.3s ease;
  }

  .still-btn:hover { background: var(--color-brand); }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
  }
</style>
