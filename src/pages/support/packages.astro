---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import SupportHeader from '../../components/SupportHeader.astro';
import SupportFooter from '../../components/SupportFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FaqItem from '../../components/FaqItem.astro';
import CtaBand from '../../components/CtaBand.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import Animations from '../../components/Animations.astro';
import { supportPackages } from '../../data/support-packages';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'Packages', item: 'https://orangesoft.com.my/support/packages' },
  ],
};
---

<Layout
  title="Support Packages | Orangesoft Support"
  description="Three managed support tiers — Essential, Professional, and Enterprise — covering security, monitoring, content updates, and emergency response for any website platform."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="packages" />
  <Breadcrumb items={[{ label: 'Home', href: '/support' }, { label: 'Packages' }]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Three Tiers.<br />One Standard of Care.</h1>
      <p class="hero-lead">
        Every package includes proactive monitoring, security patches, and backups. Choose the level of response time, content hours, and optimisation that fits your business.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Package Cards -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="packages-grid" data-animate="stagger">
        {supportPackages.map((pkg, i) => (
          <a href={`/support/packages/${pkg.slug}`} class:list={['package-card', { 'package-card--featured': i === 1 }]}>
            {i === 1 && <span class="package-badge">Most Popular</span>}
            <h2 class="package-name">{pkg.name}</h2>
            <p class="package-tagline">{pkg.tagline}</p>
            <div class="package-price">
              <span class="price-currency">MYR</span>
              <span class="price-amount">{pkg.price}</span>
              <span class="price-period">/month</span>
            </div>
            <p class="package-desc">{pkg.description}</p>

            <div class="package-highlights">
              <div class="highlight">
                <span class="highlight-label">Response Time</span>
                <span class="highlight-value">{pkg.responseTime}</span>
              </div>
              <div class="highlight">
                <span class="highlight-label">Content Updates</span>
                <span class="highlight-value">{pkg.contentHours}</span>
              </div>
              <div class="highlight">
                <span class="highlight-label">Monitoring</span>
                <span class="highlight-value">{pkg.monitoring}</span>
              </div>
            </div>

            <span class="package-link">
              View full details
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Quick View -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Quick Comparison"
        subtitle="Key differences between our three support tiers."
        align="center"
      />
      <div class="compare-table-wrapper">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Feature</th>
              {supportPackages.map((pkg) => (
                <th>{pkg.name}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Monthly Price</td>
              {supportPackages.map((pkg) => (
                <td>MYR {pkg.price}</td>
              ))}
            </tr>
            <tr>
              <td>Emergency Response</td>
              {supportPackages.map((pkg) => (
                <td>{pkg.responseTime}</td>
              ))}
            </tr>
            <tr>
              <td>Content Hours</td>
              {supportPackages.map((pkg) => (
                <td>{pkg.contentHours}</td>
              ))}
            </tr>
            <tr>
              <td>Monitoring</td>
              {supportPackages.map((pkg) => (
                <td>{pkg.monitoring}</td>
              ))}
            </tr>
          </tbody>
        </table>
      </div>
      <p class="compare-cta">
        <a href="/support/pricing">View full pricing comparison &rarr;</a>
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Package FAQ"
        subtitle="Common questions about choosing the right support tier."
      />
      <div class="faq-list">
        <FaqItem
          question="Can I switch between packages?"
          answer="Yes. You can upgrade or downgrade at the start of any billing cycle with 30 days notice. Upgrades can also be applied mid-cycle on a pro-rata basis."
        />
        <FaqItem
          question="Is there a minimum contract length?"
          answer="We recommend a 6-month commitment so we can properly onboard your platform and demonstrate value. After that, contracts renew month-to-month with 30 days notice to cancel."
        />
        <FaqItem
          question="What platforms do you support?"
          answer="Any web platform: WordPress, Kentico, Shopify, custom-built applications, headless CMS setups, and more. If it runs on the web, we can maintain it."
        />
      </div>
    </div>
  </section>

  <CtaBand heading="Not sure which package fits?" buttonText="Talk to Our Team" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Package Cards */
  .packages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .package-card {
    display: flex;
    flex-direction: column;
    padding: 2.5rem 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
  }

  .package-card:hover {
    border-color: var(--color-brand);
    box-shadow: 0 8px 32px rgba(232, 114, 12, 0.08);
  }

  .package-card--featured {
    border-color: var(--color-brand);
    box-shadow: 0 8px 32px rgba(232, 114, 12, 0.1);
  }

  .package-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.375rem 1rem;
    background: var(--color-brand);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 2rem;
    white-space: nowrap;
  }

  .package-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .package-tagline {
    font-size: 0.8125rem;
    font-style: italic;
    color: var(--color-brand);
    margin-bottom: 1.5rem;
  }

  .package-price {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    margin-bottom: 1.25rem;
  }

  .price-currency {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-muted);
  }

  .price-amount {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .price-period {
    font-size: 0.8125rem;
    color: var(--color-muted);
  }

  .package-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .package-highlights {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    background: white;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .highlight {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .highlight-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .highlight-value {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-foreground);
    text-align: right;
  }

  .package-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand);
    margin-top: auto;
    transition: gap 0.3s ease;
  }

  .package-card:hover .package-link { gap: 0.75rem; }
  .package-link svg { width: 0.875rem; height: 0.875rem; }

  /* Compare Table */
  .compare-table-wrapper {
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .compare-table th,
  .compare-table td {
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--color-divider);
  }

  .compare-table th {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    background: var(--color-surface);
  }

  .compare-table td:first-child {
    font-weight: 500;
    color: var(--color-foreground);
  }

  .compare-table td {
    color: var(--color-muted);
  }

  .compare-cta {
    text-align: center;
    margin-top: 1rem;
  }

  .compare-cta a {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand);
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .compare-cta a:hover { opacity: 0.7; }

  /* FAQ */
  .faq-list {
    max-width: 720px;
    border-top: 1px solid var(--color-divider);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 1024px) {
    .packages-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .compare-table { font-size: 0.8125rem; }
    .compare-table th, .compare-table td { padding: 0.75rem; }
  }
</style>
