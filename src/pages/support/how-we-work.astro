---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import SupportHeader from '../../components/SupportHeader.astro';
import SupportFooter from '../../components/SupportFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import CtaBand from '../../components/CtaBand.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import Animations from '../../components/Animations.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'How We Work', item: 'https://orangesoft.com.my/support/how-we-work' },
  ],
};

const monitoringTools = [
  {
    name: 'Uptime Monitoring',
    description: '1-minute check intervals across all endpoints. Instant alerts to both our team and yours when downtime is detected.',
  },
  {
    name: 'Performance Tracking',
    description: 'Continuous Core Web Vitals monitoring, load time benchmarks, and server response time tracking with historical trend data.',
  },
  {
    name: 'Security Scanning',
    description: 'Automated vulnerability scanning, malware detection, SSL certificate monitoring, and dependency audit reports.',
  },
  {
    name: 'Backup Verification',
    description: 'Daily automated backups with integrity checks. We verify that every backup is restorable, not just that it exists.',
  },
];

const slaFramework = [
  {
    tier: 'Essential',
    response: '4 hours',
    hours: 'Business hours (9am-6pm, Mon-Fri)',
    channels: 'Email',
    sla: 'Best effort',
  },
  {
    tier: 'Professional',
    response: '2 hours',
    hours: 'Extended hours (8am-10pm, Mon-Fri)',
    channels: 'Email + Slack',
    sla: 'Response time guarantee',
  },
  {
    tier: 'Enterprise',
    response: '1 hour',
    hours: '24/7 including weekends',
    channels: 'Email + Slack + Phone',
    sla: '99.9% uptime with credits',
  },
];

const channels = [
  {
    name: 'Monthly Health Reports',
    description: 'Detailed PDF report covering uptime, performance metrics, security scan results, changes made, and recommendations. Delivered on the first business day of each month.',
  },
  {
    name: 'Dedicated Slack Channel',
    description: 'Real-time communication with your support team. Available in Professional and Enterprise packages. Post a request and get a response within your SLA window.',
  },
  {
    name: 'Quarterly Strategic Reviews',
    description: 'A 1-hour meeting with your account manager to review platform health, discuss upcoming changes, and plan improvements. Available in Professional and Enterprise packages.',
  },
  {
    name: 'Emergency Hotline',
    description: 'Direct phone access to a support engineer for critical issues. Available to Enterprise clients 24/7 including weekends and public holidays.',
  },
];
---

<Layout
  title="How We Work | Orangesoft Support"
  description="Our approach to managed website support: monitoring tools, SLA framework, communication channels, and the operational standards behind our service."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="how-we-work" />
  <Breadcrumb items={[{ label: 'Home', href: '/support' }, { label: 'How We Work' }]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">How We Keep<br />Your Platform Healthy</h1>
      <p class="hero-lead">
        Managed support is not just a promise to fix things when they break. It is a systematic approach to monitoring, maintenance, and communication that keeps your website reliable, secure, and performant.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Monitoring Tools -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="Monitoring & Detection"
        subtitle="The tools and systems we use to watch your platform around the clock."
      />
      <div class="tools-grid" data-animate="stagger">
        {monitoringTools.map((tool) => (
          <div class="tool-card">
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-desc">{tool.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SLA Framework -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="SLA Framework"
        subtitle="Clear response time commitments for every support tier."
        align="center"
      />
      <div class="sla-table-wrapper">
        <table class="sla-table">
          <thead>
            <tr>
              <th>Package</th>
              <th>Emergency Response</th>
              <th>Availability</th>
              <th>Channels</th>
              <th>SLA Type</th>
            </tr>
          </thead>
          <tbody>
            {slaFramework.map((tier) => (
              <tr>
                <td class="tier-name">{tier.tier}</td>
                <td>{tier.response}</td>
                <td>{tier.hours}</td>
                <td>{tier.channels}</td>
                <td>{tier.sla}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="sla-note" data-animate="fade-up">
        <p><strong>Emergency</strong> = site down, security breach, or revenue-impacting failure.</p>
        <p><strong>Standard requests</strong> (content updates, non-critical bugs) follow next-business-day response for all tiers.</p>
      </div>
    </div>
  </section>

  <!-- Communication Channels -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="Communication Channels"
        subtitle="How we keep you informed and how you reach us."
      />
      <div class="channels-grid" data-animate="stagger">
        {channels.map((channel) => (
          <div class="channel-card">
            <h3 class="channel-name">{channel.name}</h3>
            <p class="channel-desc">{channel.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Links to Sub-Pages -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Explore Further"
        subtitle="Dive deeper into our technology support and onboarding process."
        align="center"
      />
      <div class="explore-grid">
        <a href="/support/technologies" class="explore-card">
          <h3 class="explore-title">Platforms We Support</h3>
          <p class="explore-desc">WordPress, Kentico, Shopify, custom builds, and every major web platform.</p>
          <span class="explore-link">
            View platforms
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
        <a href="/support/process" class="explore-card">
          <h3 class="explore-title">Onboarding Process</h3>
          <p class="explore-desc">Four steps from initial audit to ongoing managed support in 1 to 2 weeks.</p>
          <span class="explore-link">
            View process
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <CtaBand heading="Want to see our process in action?" buttonText="Get in Touch" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Tools Grid */
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .tool-card {
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  .tool-name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .tool-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* SLA Table */
  .sla-table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .sla-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .sla-table th,
  .sla-table td {
    padding: 1rem 1.25rem;
    text-align: left;
    border-bottom: 1px solid var(--color-divider);
  }

  .sla-table th {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
    background: var(--color-surface);
  }

  .sla-table td { color: var(--color-muted); }
  .tier-name { font-weight: 600; color: var(--color-foreground) !important; }
  .sla-table tr:last-child td { border-bottom: none; }

  .sla-note {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    padding: 1.25rem;
    background: var(--color-surface);
    border-radius: 0.5rem;
    border: 1px solid var(--color-divider);
  }

  .sla-note p {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-bottom: 0.375rem;
  }

  .sla-note p:last-child { margin-bottom: 0; }
  .sla-note strong { color: var(--color-foreground); font-weight: 600; }

  /* Channels Grid */
  .channels-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .channel-card {
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  .channel-name {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .channel-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* Explore Grid */
  .explore-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .explore-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .explore-card:hover {
    border-color: var(--color-brand);
    box-shadow: 0 8px 32px rgba(232, 114, 12, 0.08);
  }

  .explore-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .explore-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1.25rem;
  }

  .explore-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand);
    margin-top: auto;
    transition: gap 0.3s ease;
  }

  .explore-card:hover .explore-link { gap: 0.75rem; }
  .explore-link svg { width: 0.875rem; height: 0.875rem; }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .tools-grid { grid-template-columns: 1fr; }
    .channels-grid { grid-template-columns: 1fr; }
    .explore-grid { grid-template-columns: 1fr; }
    .sla-table { font-size: 0.8125rem; }
    .sla-table th, .sla-table td { padding: 0.75rem; }
  }
</style>
