---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import SupportHeader from '../../components/SupportHeader.astro';
import SupportFooter from '../../components/SupportFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import FaqItem from '../../components/FaqItem.astro';
import CtaBand from '../../components/CtaBand.astro';
import Animations from '../../components/Animations.astro';
import { supportServices } from '../../data/support-services';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://orangesoft.com.my/support/services' },
  ],
};
---

<Layout
  title="Managed Services | Orangesoft Support"
  description="Six managed website services: monitoring, security, content management, hosting, emergency support, and performance optimisation. One monthly fee."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="services" />
  <Breadcrumb items={[{ label: 'Home', href: '/support' }, { label: 'Services' }]} />

  <section class="hero">
    <div class="inner">
      <h1 class="hero-title">Everything Your Website Needs.<br />Nothing It Does Not.</h1>
      <p class="hero-lead">
        Six managed services covering monitoring, security, content, hosting, emergencies, and performance. Pick a package or let us recommend based on your platform.
      </p>
    </div>
  </section>

  <TrustStrip />

  {supportServices.map((svc, i) => (
    <section class:list={['section', { 'section-alt': i % 2 === 0 }]} id={svc.slug}>
      <div class="inner" data-animate="fade-up">
        <div class="svc-header">
          <span class="svc-num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h2 class="svc-name">{svc.name}</h2>
            <p class="svc-tagline">{svc.tagline}</p>
          </div>
        </div>
        <p class="svc-desc">{svc.description}</p>
        <div class="svc-includes">
          <h3 class="inc-title">What is included</h3>
          <ul class="inc-list">
            {svc.includes.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        {svc.faq.length > 0 && (
          <div class="svc-faq">
            {svc.faq.map((f) => <FaqItem question={f.question} answer={f.answer} />)}
          </div>
        )}
      </div>
    </section>
  ))}

  <section class="section">
    <div class="inner" data-animate="fade-up">
      <div class="platforms">
        <h2 class="plat-title">Platforms We Support</h2>
        <div class="plat-tags">
          <span>NuxtJS</span><span>Laravel</span><span>WordPress</span><span>Kentico</span>
          <span>Magento</span><span>Drupal</span><span>Strapi</span><span>Static Sites</span>
        </div>
        <p class="plat-note">Do not see your platform? <a href="/support/contact">Ask us</a> — we likely support it.</p>
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to hand off your website maintenance?" buttonText="Get Your Maintenance Quote" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .inner { max-width: 900px; margin: 0 auto; }
  .section-alt { background: white; }

  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title { font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; color: var(--color-foreground); margin-bottom: 1rem; opacity: 0; animation: slideUp 0.7s ease 1s forwards; }
  .hero-lead { font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px; opacity: 0; animation: slideUp 0.7s ease 1.15s forwards; }

  .svc-header { display: flex; gap: 1.25rem; align-items: flex-start; margin-bottom: 1.25rem; }
  .svc-num { font-size: 0.6875rem; font-weight: 300; color: var(--color-brand); letter-spacing: 0.1em; padding-top: 0.375rem; }
  .svc-name { font-size: 1.5rem; font-weight: 600; color: var(--color-foreground); letter-spacing: -0.02em; }
  .svc-tagline { font-size: 0.875rem; color: var(--color-brand); margin-top: 0.25rem; }
  .svc-desc { font-size: 1rem; line-height: 1.8; color: var(--color-muted); margin-bottom: 2rem; }

  .inc-title { font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-foreground); margin-bottom: 0.75rem; }
  .inc-list { list-style: none; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1.5rem; margin-bottom: 2rem; }
  .inc-list li { position: relative; padding-left: 1.25rem; font-size: 0.875rem; line-height: 1.6; color: var(--color-muted); }
  .inc-list li::before { content: ''; position: absolute; left: 0; top: 0.5rem; width: 0.375rem; height: 0.375rem; border-radius: 50%; background: var(--color-brand); }

  .svc-faq { max-width: 700px; }

  .platforms { text-align: center; max-width: 640px; margin: 0 auto; }
  .plat-title { font-size: 1.5rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .plat-tags { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; margin-bottom: 1rem; }
  .plat-tags span { padding: 0.5rem 1rem; border: 1px solid var(--color-divider); border-radius: 2rem; font-size: 0.8125rem; font-weight: 500; color: var(--color-foreground); }
  .plat-note { font-size: 0.875rem; color: var(--color-muted); }
  .plat-note a { color: var(--color-brand); text-decoration: none; font-weight: 500; }

  @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @media (prefers-reduced-motion: reduce) { .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; } }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .inc-list { grid-template-columns: 1fr; }
  }
</style>
