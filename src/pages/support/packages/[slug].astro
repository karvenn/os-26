---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import SupportHeader from '../../../components/SupportHeader.astro';
import SupportFooter from '../../../components/SupportFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import FaqItem from '../../../components/FaqItem.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import { supportPackages } from '../../../data/support-packages';
import type { SupportPackage } from '../../../data/support-packages';

export function getStaticPaths() {
  return supportPackages.map((pkg) => ({
    params: { slug: pkg.slug },
    props: { pkg },
  }));
}

interface Props {
  pkg: SupportPackage;
}

const { pkg } = Astro.props;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'Packages', item: 'https://orangesoft.com.my/support/packages' },
    { '@type': 'ListItem', position: 3, name: pkg.name, item: `https://orangesoft.com.my/support/packages/${pkg.slug}` },
  ],
};

const otherPackages = supportPackages.filter((p) => p.slug !== pkg.slug);
---

<Layout
  title={`${pkg.name} Package | Orangesoft Support`}
  description={pkg.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="packages" />
  <Breadcrumb items={[
    { label: 'Home', href: '/support' },
    { label: 'Packages', href: '/support/packages' },
    { label: pkg.name },
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <p class="hero-eyebrow">Support Package</p>
      <h1 class="hero-title">{pkg.name}</h1>
      <p class="hero-tagline">{pkg.tagline}</p>
      <div class="hero-price">
        <span class="price-currency">MYR</span>
        <span class="price-amount">{pkg.price}</span>
        <span class="price-period">/month</span>
      </div>
      <p class="hero-lead">{pkg.description}</p>
    </div>
  </section>

  <!-- Key Metrics -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="metrics-grid" data-animate="stagger">
        <div class="metric-card">
          <span class="metric-label">Emergency Response</span>
          <span class="metric-value">{pkg.responseTime}</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Content Updates</span>
          <span class="metric-value">{pkg.contentHours}</span>
        </div>
        <div class="metric-card">
          <span class="metric-label">Monitoring</span>
          <span class="metric-value">{pkg.monitoring}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Full Includes -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Everything Included"
        subtitle={`Full list of what the ${pkg.name} package covers every month.`}
      />
      <div class="includes-list">
        {pkg.includes.map((item) => (
          <div class="includes-item">
            <svg class="includes-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Best For -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <div class="best-for">
        <SectionHeading
          title="Best For"
          subtitle="Who this package is designed for."
          align="center"
        />
        <p class="best-for-text">{pkg.bestFor}</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Frequently Asked Questions"
        subtitle={`Common questions about the ${pkg.name} package.`}
      />
      <div class="faq-list">
        {pkg.faq.map((item) => (
          <FaqItem question={item.question} answer={item.answer} />
        ))}
        <FaqItem
          question="Can I upgrade or downgrade later?"
          answer="Yes. You can change your package at the start of any billing cycle with 30 days notice. Upgrades can also be applied mid-cycle on a pro-rata basis."
        />
        <FaqItem
          question="Is there a setup fee?"
          answer="There is a one-time onboarding fee that covers the initial audit, documentation, and setup of monitoring tools. This is quoted separately based on the complexity of your platform."
        />
      </div>
    </div>
  </section>

  <!-- Other Packages -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="Compare Other Packages"
        subtitle="See how our other tiers compare."
      />
      <div class="other-grid" data-animate="stagger">
        {otherPackages.map((p) => (
          <a href={`/support/packages/${p.slug}`} class="other-card">
            <h3 class="other-name">{p.name}</h3>
            <p class="other-tagline">{p.tagline}</p>
            <div class="other-price">
              <span class="other-currency">MYR</span>
              <span class="other-amount">{p.price}</span>
              <span class="other-period">/mo</span>
            </div>
            <span class="other-link">
              View details
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading={`Ready to get started with ${pkg.name}?`} buttonText="Get a Quote" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-eyebrow {
    font-size: 0.6875rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--color-brand); margin-bottom: 0.75rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 0.5rem;
    opacity: 0; animation: slideUp 0.7s ease 1.05s forwards;
  }
  .hero-tagline {
    font-size: 1.125rem; font-style: italic; color: var(--color-brand); margin-bottom: 1.25rem;
    opacity: 0; animation: slideUp 0.7s ease 1.1s forwards;
  }
  .hero-price {
    display: flex; align-items: baseline; gap: 0.25rem; margin-bottom: 1.25rem;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }
  .price-currency { font-size: 1rem; font-weight: 500; color: var(--color-muted); }
  .price-amount { font-size: 3rem; font-weight: 700; color: var(--color-foreground); letter-spacing: -0.03em; line-height: 1; }
  .price-period { font-size: 0.875rem; color: var(--color-muted); }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.2s forwards;
  }

  /* Metrics */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .metric-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
    text-align: center;
  }

  .metric-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }

  .metric-value {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-foreground);
    line-height: 1.4;
  }

  /* Includes List */
  .includes-list {
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .includes-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-divider);
    font-size: 0.9375rem;
    color: var(--color-foreground);
    line-height: 1.5;
  }

  .includes-item:last-child { border-bottom: none; }

  .includes-check {
    width: 1.125rem;
    height: 1.125rem;
    flex-shrink: 0;
    color: var(--color-brand);
    margin-top: 0.125rem;
  }

  /* Best For */
  .best-for {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .best-for-text {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-muted);
    padding: 1.5rem;
    background: var(--color-brand-light);
    border-radius: 0.5rem;
    border-left: 3px solid var(--color-brand);
    text-align: left;
  }

  /* FAQ */
  .faq-list {
    max-width: 720px;
    border-top: 1px solid var(--color-divider);
  }

  /* Other Packages */
  .other-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 640px;
  }

  .other-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .other-card:hover {
    border-color: var(--color-brand);
    box-shadow: 0 4px 16px rgba(232, 114, 12, 0.06);
  }

  .other-name { font-size: 1.25rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.25rem; }
  .other-tagline { font-size: 0.8125rem; color: var(--color-muted); margin-bottom: 1rem; }
  .other-price { display: flex; align-items: baseline; gap: 0.25rem; margin-bottom: 1rem; }
  .other-currency { font-size: 0.75rem; color: var(--color-muted); }
  .other-amount { font-size: 1.5rem; font-weight: 700; color: var(--color-foreground); letter-spacing: -0.02em; }
  .other-period { font-size: 0.75rem; color: var(--color-muted); }

  .other-link {
    display: inline-flex; align-items: center; gap: 0.375rem;
    font-size: 0.8125rem; font-weight: 600; color: var(--color-brand);
    margin-top: auto; transition: gap 0.3s ease;
  }

  .other-card:hover .other-link { gap: 0.625rem; }
  .other-link svg { width: 0.75rem; height: 0.75rem; }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-title, .hero-tagline, .hero-price, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .price-amount { font-size: 2.25rem; }
    .metrics-grid { grid-template-columns: 1fr; }
    .other-grid { grid-template-columns: 1fr; }
  }
</style>
