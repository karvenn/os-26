---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import SupportHeader from '../../components/SupportHeader.astro';
import SupportFooter from '../../components/SupportFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FaqItem from '../../components/FaqItem.astro';
import CtaBand from '../../components/CtaBand.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import Animations from '../../components/Animations.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'How We Work', item: 'https://orangesoft.com.my/support/how-we-work' },
    { '@type': 'ListItem', position: 3, name: 'Onboarding', item: 'https://orangesoft.com.my/support/process' },
  ],
};

const steps = [
  {
    number: '01',
    name: 'Platform Audit',
    duration: '2-3 days',
    description: 'We conduct a thorough audit of your entire platform: codebase, hosting infrastructure, security posture, performance metrics, integrations, and content management workflows.',
    deliverables: [
      'Comprehensive platform documentation',
      'Security vulnerability assessment',
      'Performance baseline report (Core Web Vitals, load times, TTFB)',
      'Infrastructure and hosting review',
      'Integration and dependency inventory',
      'Risk assessment with prioritised recommendations',
    ],
  },
  {
    number: '02',
    name: 'Monitoring Setup',
    duration: '1-2 days',
    description: 'We configure all monitoring, alerting, and backup systems tailored to your platform. Every tool is tested to ensure alerts fire correctly and backups are restorable.',
    deliverables: [
      'Uptime monitoring with 1-minute check intervals',
      'Performance tracking dashboards',
      'Security scanning and vulnerability alerts',
      'Automated daily backup configuration',
      'Backup restoration test (verified restorable)',
      'Alert routing to both teams (email, Slack, phone)',
    ],
  },
  {
    number: '03',
    name: 'Handover & Access',
    duration: '1-2 days',
    description: 'We coordinate access to all necessary systems, establish communication channels, and introduce you to your dedicated support team. Everything is documented and shared.',
    deliverables: [
      'Secure credential exchange and access setup',
      'Communication channel configuration (email, Slack, phone)',
      'Team introduction and point-of-contact assignment',
      'Emergency escalation procedures documented',
      'Staging environment setup (Professional and Enterprise)',
      'First monthly health report template shared',
    ],
  },
  {
    number: '04',
    name: 'Ongoing Support',
    duration: 'Continuous',
    description: 'Managed support begins. Your team handles scheduled maintenance, monitors alerts, responds to issues, and delivers regular reports. Your website is in safe hands.',
    deliverables: [
      'Weekly security patches and dependency updates',
      '24/7 uptime and performance monitoring',
      'Content updates within agreed SLA windows',
      'Monthly health reports with trend analysis',
      'Quarterly strategic reviews (Professional and Enterprise)',
      'Emergency response per your package SLA',
    ],
  },
];
---

<Layout
  title="Onboarding Process | Orangesoft Support"
  description="Our four-step onboarding process: platform audit, monitoring setup, handover, and ongoing managed support. Fully operational within 1 to 2 weeks."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="how-we-work" />
  <Breadcrumb items={[
    { label: 'Home', href: '/support' },
    { label: 'How We Work', href: '/support/how-we-work' },
    { label: 'Onboarding' },
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">From Handshake to<br />Managed Support in Days</h1>
      <p class="hero-lead">
        Our onboarding process is designed to be thorough without being slow. Within 1 to 2 weeks, your platform is fully documented, monitored, and under the care of a dedicated support team.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Steps -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="Four Steps to Peace of Mind"
        subtitle="A structured onboarding process that leaves nothing to chance."
      />
      <div class="steps-list" data-animate="stagger">
        {steps.map((step) => (
          <div class="step-block">
            <div class="step-header">
              <span class="step-number">{step.number}</span>
              <div class="step-meta">
                <h2 class="step-name">{step.name}</h2>
                <span class="step-duration">{step.duration}</span>
              </div>
            </div>
            <p class="step-desc">{step.description}</p>
            <div class="step-deliverables">
              <h3 class="deliverables-heading">Deliverables</h3>
              <ul class="deliverables-list">
                {step.deliverables.map((item) => (
                  <li>
                    <svg class="del-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Typical Timeline"
        subtitle="Most onboardings complete within 1 to 2 weeks."
        align="center"
      />
      <div class="timeline-visual">
        {steps.map((step, i) => (
          <div class="timeline-step">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="timeline-label">{step.name}</span>
              <span class="timeline-dur">{step.duration}</span>
            </div>
            {i < steps.length - 1 && <div class="timeline-line"></div>}
          </div>
        ))}
      </div>
      <div class="timeline-note">
        <p><strong>Simple corporate website:</strong> 5-7 business days</p>
        <p><strong>Complex web application:</strong> 10-14 business days</p>
        <p><strong>Enterprise multi-site:</strong> 14-21 business days</p>
      </div>
    </div>
  </section>

  <!-- What We Need From You -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="What We Need From You"
        subtitle="A short checklist to ensure a smooth onboarding."
      />
      <div class="needs-grid">
        <div class="need-card">
          <h3 class="need-title">Access Credentials</h3>
          <p class="need-desc">CMS admin, hosting panel, DNS provider, and any third-party service logins. We use a secure credential-sharing tool.</p>
        </div>
        <div class="need-card">
          <h3 class="need-title">Key Contacts</h3>
          <p class="need-desc">Names and roles of people on your team who will be our points of contact for content approvals and technical queries.</p>
        </div>
        <div class="need-card">
          <h3 class="need-title">Existing Documentation</h3>
          <p class="need-desc">Any existing technical documentation, deployment guides, or integration specifications. If none exist, we create them during audit.</p>
        </div>
        <div class="need-card">
          <h3 class="need-title">Priority Areas</h3>
          <p class="need-desc">Known issues, upcoming deadlines, or areas of concern that should be addressed first during the audit phase.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Onboarding FAQ"
        subtitle="Common questions about the onboarding process."
      />
      <div class="faq-list">
        <FaqItem
          question="Is there an onboarding fee?"
          answer="Yes. The onboarding fee covers the platform audit, documentation, monitoring setup, and handover process. It is quoted separately based on platform complexity, typically between MYR 2,000 and MYR 8,000."
        />
        <FaqItem
          question="What if our site was built by another agency?"
          answer="Not a problem. A significant proportion of our clients come from other agencies. Our audit phase is specifically designed to understand and document codebases we did not build."
        />
        <FaqItem
          question="Can we start support before the audit is complete?"
          answer="Emergency monitoring can be activated within hours of signing. Full managed support begins once the audit and setup phases are complete."
        />
        <FaqItem
          question="What if you find critical issues during the audit?"
          answer="We flag them immediately and provide a prioritised remediation plan. Critical security issues are addressed as a priority, even during the onboarding phase."
        />
        <FaqItem
          question="Do you provide a staging environment?"
          answer="Professional and Enterprise packages include a staging environment. For Essential packages, staging can be added as an optional extra."
        />
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to onboard your platform?" buttonText="Start the Conversation" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Steps */
  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .step-block {
    padding: 2.5rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  .step-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-brand);
    color: white;
    font-size: 1rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .step-meta { flex: 1; }

  .step-name {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 0.125rem;
  }

  .step-duration {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-brand);
  }

  .step-desc {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    max-width: 720px;
  }

  .step-deliverables {
    padding: 1.5rem;
    background: white;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
  }

  .deliverables-heading {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .deliverables-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.625rem;
  }

  .deliverables-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-foreground);
    line-height: 1.5;
  }

  .del-check {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    color: var(--color-brand);
    margin-top: 0.125rem;
  }

  /* Timeline */
  .timeline-visual {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    margin-bottom: 2.5rem;
    padding: 0 1rem;
  }

  .timeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    flex: 1;
    max-width: 200px;
  }

  .timeline-dot {
    width: 1rem;
    height: 1rem;
    border-radius: 50%;
    background: var(--color-brand);
    margin-bottom: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .timeline-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.125rem;
  }

  .timeline-label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  .timeline-dur {
    font-size: 0.6875rem;
    color: var(--color-brand);
    font-weight: 500;
  }

  .timeline-line {
    position: absolute;
    top: 0.5rem;
    left: calc(50% + 0.5rem);
    right: calc(-50% + 0.5rem);
    height: 2px;
    background: var(--color-divider);
    z-index: 0;
  }

  .timeline-note {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 0.5rem;
    border: 1px solid var(--color-divider);
  }

  .timeline-note p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-bottom: 0.375rem;
  }

  .timeline-note p:last-child { margin-bottom: 0; }
  .timeline-note strong { color: var(--color-foreground); font-weight: 600; }

  /* Needs Grid */
  .needs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .need-card {
    padding: 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
  }

  .need-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .need-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
  }

  /* FAQ */
  .faq-list {
    max-width: 720px;
    border-top: 1px solid var(--color-divider);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .step-block { padding: 1.75rem; }
    .step-header { flex-direction: column; gap: 0.75rem; }
    .deliverables-list { grid-template-columns: 1fr; }
    .needs-grid { grid-template-columns: 1fr; }
    .timeline-visual { flex-direction: column; align-items: center; gap: 1.5rem; }
    .timeline-step { flex-direction: row; gap: 1rem; max-width: none; width: 100%; max-width: 280px; }
    .timeline-dot { margin-bottom: 0; }
    .timeline-content { align-items: flex-start; text-align: left; }
    .timeline-line { display: none; }
  }
</style>
