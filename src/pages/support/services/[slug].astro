---
import Layout from '../../../layouts/Layout.astro';
import EntranceOverlay from '../../../components/EntranceOverlay.astro';
import SupportHeader from '../../../components/SupportHeader.astro';
import SupportFooter from '../../../components/SupportFooter.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import FaqItem from '../../../components/FaqItem.astro';
import CtaBand from '../../../components/CtaBand.astro';
import Animations from '../../../components/Animations.astro';
import { supportServices } from '../../../data/support-services';
import type { SupportService } from '../../../data/support-services';

export function getStaticPaths() {
  return supportServices.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: SupportService;
}

const { service } = Astro.props;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://orangesoft.com.my/support/services' },
    { '@type': 'ListItem', position: 3, name: service.name, item: `https://orangesoft.com.my/support/services/${service.slug}` },
  ],
};

const otherServices = supportServices.filter((s) => s.slug !== service.slug);
---

<Layout
  title={`${service.name} | Orangesoft Support`}
  description={service.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="services" />
  <Breadcrumb items={[
    { label: 'Home', href: '/support' },
    { label: 'Services', href: '/support/services' },
    { label: service.name },
  ]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <p class="hero-eyebrow">Managed Service</p>
      <h1 class="hero-title">{service.name}</h1>
      <p class="hero-tagline">{service.tagline}</p>
      <p class="hero-lead">{service.description}</p>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section section-alt">
    <div class="section-inner">
      <SectionHeading
        title="What's Included"
        subtitle="Everything covered under this service, included in your monthly retainer."
      />
      <div class="includes-grid" data-animate="stagger">
        {service.includes.map((item, i) => (
          <div class="include-card">
            <span class="include-number">{String(i + 1).padStart(2, '0')}</span>
            <p class="include-text">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why This Matters -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <div class="why-block">
        <SectionHeading
          title="Why This Matters"
          subtitle="The cost of neglecting this area of your website."
          align="center"
        />
        <p class="why-text">
          Websites that lack proper {service.name.toLowerCase()} degrade over time. What starts as a minor oversight becomes a compounding problem: slower load times, security vulnerabilities, outdated content, and eventually a platform that actively harms your business reputation.
        </p>
        <p class="why-text">
          Our managed approach means these issues never reach that point. We handle the work proactively, on a schedule, with documented processes and clear reporting. Your team stays focused on strategy and growth while we handle the infrastructure.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Frequently Asked Questions"
        subtitle={`Common questions about our ${service.name.toLowerCase()} service.`}
      />
      <div class="faq-list">
        {service.faq.map((item) => (
          <FaqItem question={item.question} answer={item.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- Other Services -->
  <section class="section">
    <div class="section-inner">
      <SectionHeading
        title="Other Managed Services"
        subtitle="Explore our full range of support services."
      />
      <div class="other-grid" data-animate="stagger">
        {otherServices.map((s) => (
          <a href={`/support/services/${s.slug}`} class="other-card">
            <h3 class="other-title">{s.name}</h3>
            <p class="other-tagline">{s.tagline}</p>
            <span class="other-link">
              Learn more
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Need reliable website maintenance?" buttonText="Get a Support Quote" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-eyebrow {
    font-size: 0.6875rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--color-brand); margin-bottom: 0.75rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 0.5rem;
    opacity: 0; animation: slideUp 0.7s ease 1.05s forwards;
  }
  .hero-tagline {
    font-size: 1.125rem; font-style: italic; color: var(--color-brand); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1.1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Includes Grid */
  .includes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .include-card {
    padding: 1.75rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
  }

  .include-number {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--color-brand);
    margin-bottom: 0.75rem;
  }

  .include-text {
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-foreground);
    font-weight: 500;
  }

  /* Why Block */
  .why-block {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .why-text {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  /* FAQ */
  .faq-list {
    max-width: 720px;
    border-top: 1px solid var(--color-divider);
  }

  /* Other Services */
  .other-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  .other-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .other-card:hover {
    border-color: var(--color-brand);
    box-shadow: 0 4px 16px rgba(232, 114, 12, 0.06);
  }

  .other-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.25rem;
  }

  .other-tagline {
    font-size: 0.75rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .other-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-brand);
    margin-top: auto;
    transition: gap 0.3s ease;
  }

  .other-card:hover .other-link { gap: 0.625rem; }
  .other-link svg { width: 0.75rem; height: 0.75rem; }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .hero-title, .hero-tagline, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 1024px) {
    .includes-grid { grid-template-columns: repeat(2, 1fr); }
    .other-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .includes-grid { grid-template-columns: 1fr; }
    .other-grid { grid-template-columns: 1fr; }
  }
</style>
