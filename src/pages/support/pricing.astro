---
import Layout from '../../layouts/Layout.astro';
import EntranceOverlay from '../../components/EntranceOverlay.astro';
import SupportHeader from '../../components/SupportHeader.astro';
import SupportFooter from '../../components/SupportFooter.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import FaqItem from '../../components/FaqItem.astro';
import CtaBand from '../../components/CtaBand.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import Animations from '../../components/Animations.astro';
import { supportPackages } from '../../data/support-packages';
import { supportServices } from '../../data/support-services';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://orangesoft.com.my/support' },
    { '@type': 'ListItem', position: 2, name: 'Pricing', item: 'https://orangesoft.com.my/support/pricing' },
  ],
};

const comparisonRows = [
  { feature: 'Monthly retainer', values: ['MYR 1,500', 'MYR 3,500', 'MYR 8,000'] },
  { feature: 'Security patches & updates', values: ['Weekly', 'Weekly', 'Weekly + priority'] },
  { feature: '24/7 uptime monitoring', values: ['Yes', 'Yes', 'Yes'] },
  { feature: 'Daily automated backups', values: ['30-day retention', '30-day retention', '30-day retention'] },
  { feature: 'Content update hours', values: ['2 hrs/month', '5 hrs/month', '10 hrs/month'] },
  { feature: 'Emergency response time', values: ['4 hrs (business)', '2 hrs (extended)', '1 hr (24/7)'] },
  { feature: 'Performance optimisation', values: ['Basic monitoring', 'Quarterly audits', 'Monthly sprints'] },
  { feature: 'Staging environment', values: ['Not included', 'Included', 'Included'] },
  { feature: 'Communication channel', values: ['Email', 'Email + Slack', 'Email + Slack + Phone'] },
  { feature: 'Strategic reviews', values: ['Not included', 'Quarterly', 'Monthly'] },
  { feature: 'Dedicated account manager', values: ['Not included', 'Not included', 'Included'] },
  { feature: 'SLA with service credits', values: ['Not included', 'Not included', '99.9% uptime'] },
  { feature: 'Penetration testing', values: ['Not included', 'Not included', 'Annual'] },
  { feature: 'Disaster recovery planning', values: ['Not included', 'Not included', 'Included'] },
];
---

<Layout
  title="Pricing | Orangesoft Support"
  description="Transparent pricing for managed website support. Compare Essential, Professional, and Enterprise packages side by side. No hidden fees."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <EntranceOverlay />
  <SupportHeader active="packages" />
  <Breadcrumb items={[{ label: 'Home', href: '/support' }, { label: 'Pricing' }]} />

  <!-- Hero -->
  <section class="hero">
    <div class="section-inner">
      <h1 class="hero-title">Transparent Pricing.<br />No Hidden Fees.</h1>
      <p class="hero-lead">
        Every package is a fixed monthly retainer. You know exactly what you pay, exactly what you get, and exactly how to reach us when you need help.
      </p>
    </div>
  </section>

  <TrustStrip />

  <!-- Package Summary Cards -->
  <section class="section section-alt">
    <div class="section-inner">
      <div class="pkg-cards" data-animate="stagger">
        {supportPackages.map((pkg, i) => (
          <div class:list={['pkg-card', { 'pkg-card--featured': i === 1 }]}>
            {i === 1 && <span class="pkg-badge">Most Popular</span>}
            <h2 class="pkg-name">{pkg.name}</h2>
            <p class="pkg-tagline">{pkg.tagline}</p>
            <div class="pkg-price">
              <span class="pkg-currency">MYR</span>
              <span class="pkg-amount">{pkg.price}</span>
              <span class="pkg-period">/month</span>
            </div>
            <div class="pkg-meta">
              <span>{pkg.responseTime} response</span>
              <span>{pkg.contentHours} content</span>
            </div>
            <a href={`/support/packages/${pkg.slug}`} class="pkg-btn">View Package Details</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Full Comparison Table -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Full Feature Comparison"
        subtitle="A complete breakdown of what is included in each support tier."
        align="center"
      />
      <div class="table-wrapper">
        <table class="comparison-table">
          <thead>
            <tr>
              <th class="feature-col">Feature</th>
              <th>Essential</th>
              <th class="featured-col">Professional</th>
              <th>Enterprise</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <td class="feature-cell">{row.feature}</td>
                {row.values.map((val, i) => (
                  <td class:list={[{ 'featured-cell': i === 1 }]}>
                    {val === 'Yes' ? (
                      <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    ) : val === 'Not included' ? (
                      <span class="not-included">&mdash;</span>
                    ) : (
                      val
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Services Included -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Services Across All Packages"
        subtitle="Every package draws on our six core managed services."
        align="center"
      />
      <div class="services-strip">
        {supportServices.map((service) => (
          <a href={`/support/services/${service.slug}`} class="service-chip">
            <span class="chip-name">{service.name}</span>
            <span class="chip-tagline">{service.tagline}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Add-ons -->
  <section class="section">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Add-on Rates"
        subtitle="Need more than your package includes? Additional work is available at these rates."
        align="center"
      />
      <div class="addons-grid">
        <div class="addon-card">
          <span class="addon-label">Additional Content Hours</span>
          <span class="addon-value">MYR 250 / hour</span>
        </div>
        <div class="addon-card">
          <span class="addon-label">Development Work</span>
          <span class="addon-value">MYR 350 / hour</span>
        </div>
        <div class="addon-card">
          <span class="addon-label">Emergency Out-of-Hours</span>
          <span class="addon-value">MYR 500 / hour</span>
        </div>
        <div class="addon-card">
          <span class="addon-label">Additional Penetration Test</span>
          <span class="addon-value">From MYR 5,000</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-alt">
    <div class="section-inner" data-animate="fade-up">
      <SectionHeading
        title="Pricing FAQ"
        subtitle="Common questions about our pricing and billing."
      />
      <div class="faq-list">
        <FaqItem
          question="Are there any setup fees?"
          answer="There is a one-time onboarding fee that covers the initial platform audit, documentation, monitoring setup, and handover process. This is quoted separately based on the complexity of your platform, typically between MYR 2,000 and MYR 8,000."
        />
        <FaqItem
          question="What is the minimum contract length?"
          answer="We recommend a 6-month initial commitment so we can properly onboard your platform and demonstrate measurable value. After that, contracts renew month-to-month with 30 days notice to cancel."
        />
        <FaqItem
          question="Can I change my package mid-contract?"
          answer="Upgrades can be applied at any time on a pro-rata basis. Downgrades take effect at the start of the next billing cycle with 30 days notice."
        />
        <FaqItem
          question="Do prices include GST?"
          answer="All prices shown are exclusive of applicable taxes. GST or SST will be added to invoices as required by Malaysian tax regulations."
        />
        <FaqItem
          question="What payment methods do you accept?"
          answer="Bank transfer, credit card, and FPX. We invoice monthly at the start of each billing cycle with 14-day payment terms."
        />
        <FaqItem
          question="What if my site is on a platform you have not worked with?"
          answer="We support any web platform. If your site is built on a technology we have not managed before, we will conduct a discovery phase (included in the onboarding fee) to ensure full competence before taking over."
        />
      </div>
    </div>
  </section>

  <CtaBand heading="Ready to get a quote for your platform?" buttonText="Contact Our Team" buttonHref="/support/contact" />
  <SupportFooter />
  <Animations />
</Layout>

<style>
  .section { padding: 5rem 1.5rem; }
  .section-inner { max-width: 1200px; margin: 0 auto; }
  .section-alt { background: white; }

  /* Hero */
  .hero { padding: 3rem 1.5rem 2rem; }
  .hero-title {
    font-size: 3rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.03em;
    color: var(--color-foreground); margin-bottom: 1rem;
    opacity: 0; animation: slideUp 0.7s ease 1s forwards;
  }
  .hero-lead {
    font-size: 1.0625rem; line-height: 1.7; color: var(--color-muted); max-width: 640px;
    opacity: 0; animation: slideUp 0.7s ease 1.15s forwards;
  }

  /* Package Summary Cards */
  .pkg-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .pkg-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2.5rem 2rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
    background: var(--color-surface);
    position: relative;
  }

  .pkg-card--featured {
    border-color: var(--color-brand);
    box-shadow: 0 8px 32px rgba(232, 114, 12, 0.1);
  }

  .pkg-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    padding: 0.375rem 1rem;
    background: var(--color-brand);
    color: white;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 2rem;
    white-space: nowrap;
  }

  .pkg-name { font-size: 1.5rem; font-weight: 600; color: var(--color-foreground); margin-bottom: 0.25rem; }
  .pkg-tagline { font-size: 0.8125rem; font-style: italic; color: var(--color-brand); margin-bottom: 1.25rem; }

  .pkg-price { display: flex; align-items: baseline; gap: 0.25rem; margin-bottom: 1rem; }
  .pkg-currency { font-size: 0.875rem; font-weight: 500; color: var(--color-muted); }
  .pkg-amount { font-size: 2.5rem; font-weight: 700; color: var(--color-foreground); letter-spacing: -0.03em; line-height: 1; }
  .pkg-period { font-size: 0.8125rem; color: var(--color-muted); }

  .pkg-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .pkg-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    background: var(--color-foreground);
    color: white;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.375rem;
    transition: background-color 0.3s ease;
  }

  .pkg-btn:hover { background: var(--color-brand); }
  .pkg-card--featured .pkg-btn { background: var(--color-brand); }
  .pkg-card--featured .pkg-btn:hover { background: var(--color-brand-dark, #C45E0A); }

  /* Comparison Table */
  .table-wrapper {
    overflow-x: auto;
    border: 1px solid var(--color-divider);
    border-radius: 0.75rem;
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .comparison-table th,
  .comparison-table td {
    padding: 1rem 1.25rem;
    text-align: center;
    border-bottom: 1px solid var(--color-divider);
  }

  .comparison-table th {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-foreground);
    background: var(--color-surface);
    padding: 1.25rem;
  }

  .feature-col { text-align: left; }
  .feature-cell { text-align: left; font-weight: 500; color: var(--color-foreground); }
  .featured-col { background: var(--color-brand-light); }
  .featured-cell { background: rgba(232, 114, 12, 0.03); }

  .comparison-table td { color: var(--color-muted); }
  .comparison-table tr:last-child td { border-bottom: none; }

  .check-icon { width: 1.125rem; height: 1.125rem; color: var(--color-brand); display: inline-block; }
  .not-included { color: var(--color-divider); font-size: 1.25rem; }

  /* Services Strip */
  .services-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .service-chip {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1.25rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.3s ease;
  }

  .service-chip:hover { border-color: var(--color-brand); }
  .chip-name { font-size: 0.875rem; font-weight: 600; color: var(--color-foreground); }
  .chip-tagline { font-size: 0.75rem; color: var(--color-muted); }

  /* Add-ons */
  .addons-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .addon-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
    text-align: center;
  }

  .addon-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
  }

  .addon-value {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-foreground);
  }

  /* FAQ */
  .faq-list {
    max-width: 720px;
    border-top: 1px solid var(--color-divider);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title, .hero-lead { animation: none !important; opacity: 1 !important; }
  }

  @media (max-width: 1024px) {
    .pkg-cards { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
    .services-strip { grid-template-columns: repeat(2, 1fr); }
    .addons-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .section { padding: 3rem 1.5rem; }
    .hero-title { font-size: 2rem; }
    .comparison-table { font-size: 0.8125rem; }
    .comparison-table th, .comparison-table td { padding: 0.75rem 0.625rem; }
    .services-strip { grid-template-columns: 1fr; }
    .addons-grid { grid-template-columns: 1fr; }
  }
</style>
