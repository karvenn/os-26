---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    number: '01',
    title: 'Custom Websites & Applications',
    tagline: 'Crafted from scratch',
    description:
      'Bespoke digital solutions engineered to your exact vision\u2014where performance meets elegance.',
    href: '/custom',
  },
  {
    number: '02',
    title: 'WordPress Websites',
    tagline: 'Flexible by design',
    description:
      'Professional WordPress experiences that balance creative ambition with scalable architecture.',
    href: '/wordpress',
  },
  {
    number: '03',
    title: 'Kentico Websites',
    tagline: 'Enterprise-grade',
    description:
      'Sophisticated CMS solutions built for organizations that demand scale, security, and seamless workflows.',
    href: '/kentico',
  },
  {
    number: '04',
    title: 'Support & Maintenance',
    tagline: 'Always performing',
    description:
      'Proactive care and continuous optimization\u2014so your digital presence never misses a beat.',
    href: '/support',
  },
  {
    number: '05',
    title: 'SEO',
    tagline: 'Visibility, amplified',
    description:
      'Strategic search optimization that positions your brand where it matters most.',
    href: '/seo',
  },
];
---

<Layout
  title="Orangesoft — Web Design & Development Agency Malaysia | Since 2007"
  description="Malaysian digital agency with 19+ years experience. Custom web development, WordPress, Kentico, website maintenance, and SEO for corporate clients across Southeast Asia. 600+ projects delivered."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Orangesoft',
      url: 'https://orangesoft.com.my',
      description: 'Malaysian digital agency specialising in web design, development, and digital marketing since 2007.',
      foundingDate: '2007',
      areaServed: { '@type': 'Country', name: 'Malaysia' },
      numberOfEmployees: { '@type': 'QuantitativeValue', minValue: 10, maxValue: 50 },
      knowsAbout: ['Web Design', 'Web Development', 'NuxtJS', 'Laravel', 'WordPress', 'Kentico', 'SEO'],
    })} />
  </Fragment>

  <div class="page">
    <header class="site-header">
      <a href="/" class="logo">
        Orangesoft<span class="logo-dot">.</span>
      </a>
      <nav class="site-nav">
        <a href="/about" class="site-nav-link">About</a>
        <a href="/careers" class="site-nav-link">Careers</a>
        <a href="/contact" class="site-nav-link">Contact</a>
      </nav>
    </header>

    <main class="panels">
      {services.map((service) => (
        <a class="panel" href={service.href} data-href={service.href}>
          <span class="panel-number">{service.number}</span>

          <div class="panel-vertical">
            <span class="vertical-text">{service.title}</span>
          </div>

          <div class="panel-content">
            <h2 class="panel-title">{service.title}</h2>
            <p class="panel-tagline">{service.tagline}</p>
            <p class="panel-desc">{service.description}</p>
            <span class="panel-cta">
              Explore
              <svg class="cta-arrow" viewBox="0 0 20 20" fill="none">
                <path d="M4 10h12m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </main>

    <!-- ════ SEO CONTENT (below fold) ════ -->
    <section class="seo-content">
      <div class="seo-inner">
        <h1 class="seo-h1">Orangesoft — Web Design &amp; Development Agency in Malaysia</h1>

        <div class="seo-intro">
          <p>
            Orangesoft is a Malaysian digital agency with over 19 years of experience building websites, web applications, and digital marketing solutions for corporate clients across Southeast Asia. Since 2007, we have delivered more than 600 projects for organisations including IOI Properties, Cagamas, CIMB, Telekom Malaysia, and Petronas Chemicals.
          </p>
          <p>
            Our five specialised divisions allow us to offer focused expertise in custom web development, WordPress, Kentico, ongoing website support, and search engine optimisation. Whether you need a high-performance custom application built with NuxtJS and Laravel, a well-maintained WordPress site, or a comprehensive SEO strategy, there is an Orangesoft team dedicated to exactly that.
          </p>
          <p>
            Based in Kuala Lumpur, we serve clients across Malaysia, Singapore, Thailand, Indonesia, and the wider Southeast Asian region. Every project is built on a foundation of transparent communication, proven methodology, and the belief that you should own everything we create — no vendor lock-in, no recurring license fees.
          </p>
        </div>

        <div class="seo-divisions">
          <h2 class="seo-h2">Our Divisions</h2>
          <div class="seo-grid">
            <div class="seo-division">
              <h3><a href="/custom">Custom Websites &amp; Applications</a></h3>
              <p>Bespoke digital solutions built with NuxtJS, Laravel, and Strapi. From corporate websites to complex web applications, CRMs, e-commerce platforms, and campaign management systems.</p>
              <ul>
                <li><a href="/custom/services">Services</a> — Discovery, design, development, deployment, maintenance, growth</li>
                <li><a href="/custom/solutions">Solutions</a> — 8 pre-built platforms we customise for your business</li>
                <li><a href="/custom/work">Portfolio</a> — 600+ projects across 8 industries</li>
                <li><a href="/custom/pricing">Pricing</a> — Transparent investment ranges from MYR 30,000</li>
                <li><a href="/custom/insights">Insights</a> — Guides on custom development, technology choices, and costs</li>
              </ul>
            </div>
            <div class="seo-division">
              <h3><a href="/wordpress">WordPress Websites</a></h3>
              <p>Professional WordPress design and development for businesses that need flexible, cost-effective websites with extensive plugin ecosystems and familiar content management.</p>
            </div>
            <div class="seo-division">
              <h3><a href="/kentico">Kentico Websites</a></h3>
              <p>Enterprise-grade Kentico CMS implementations for organisations that require advanced digital experience platforms with built-in marketing automation and personalisation.</p>
            </div>
            <div class="seo-division">
              <h3><a href="/support">Website Support &amp; Maintenance</a></h3>
              <p>Proactive website care including security updates, performance monitoring, content changes, and priority support to keep your digital presence performing at its best.</p>
            </div>
            <div class="seo-division">
              <h3><a href="/seo">Search Engine Optimisation</a></h3>
              <p>Strategic SEO that improves your organic visibility through technical optimisation, content strategy, link building, and ongoing performance monitoring.</p>
            </div>
          </div>
        </div>

        <div class="seo-stats">
          <div class="seo-stat"><strong>600+</strong> projects delivered</div>
          <div class="seo-stat"><strong>19+</strong> years in business</div>
          <div class="seo-stat"><strong>5</strong> specialised divisions</div>
          <div class="seo-stat"><strong>4.9/5</strong> client satisfaction</div>
        </div>

        <div class="seo-cta">
          <p>Ready to discuss your project? <a href="/contact">Get in touch</a> — we respond within 24 hours.</p>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <nav class="footer-links">
        <a href="/about">About</a>
        <a href="/careers">Careers</a>
        <a href="/contact">Contact</a>
      </nav>
      <p class="footer-text">&copy; 2026 Orangesoft. All rights reserved.</p>
    </footer>
  </div>
</Layout>

<style>
  /* ── Page structure ── */

  .page {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  /* ── Header & Logo ── */

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 20;
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-nav {
    display: flex;
    gap: 1.5rem;
    opacity: 0;
    animation: fadeIn 0.8s ease 0.6s forwards;
  }

  .site-nav-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .site-nav-link:hover {
    color: var(--color-foreground);
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-foreground);
    text-decoration: none;
    letter-spacing: -0.02em;
    opacity: 0;
    animation: fadeIn 0.8s ease 0.6s forwards;
  }

  .logo-dot {
    color: var(--color-brand);
  }

  /* ── Panels container ── */

  .panels {
    display: flex;
    flex: 1;
    min-height: 100vh;
    min-height: 100dvh;
  }

  /* ── Individual panel ── */

  .panel {
    flex: 1 1 0%;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    border-right: 1px solid var(--color-divider);
    display: flex;
    flex-direction: column;
    padding: 6rem 1.5rem 3rem;
    transition:
      flex 0.7s cubic-bezier(0.4, 0, 0.2, 1),
      background-color 0.5s ease;
    opacity: 0;
    animation: panelReveal 0.9s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
  }

  .panel:last-child {
    border-right: none;
  }

  /* Staggered entrance */
  .panel:nth-child(1) { animation-delay: 0.1s; }
  .panel:nth-child(2) { animation-delay: 0.2s; }
  .panel:nth-child(3) { animation-delay: 0.3s; }
  .panel:nth-child(4) { animation-delay: 0.4s; }
  .panel:nth-child(5) { animation-delay: 0.5s; }

  /* ── Panel hover behaviour ── */

  .panels:hover .panel {
    flex: 0.7 1 0%;
  }

  .panels:hover .panel:hover {
    flex: 2.5 1 0%;
    background-color: var(--color-brand-light);
  }

  /* ── Panel number ── */

  .panel-number {
    font-size: 0.6875rem;
    font-weight: 300;
    color: var(--color-muted);
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    transition: opacity 0.4s ease;
  }

  .panels:hover .panel:not(:hover) .panel-number {
    opacity: 0.35;
  }

  /* ── Vertical title (collapsed state) ── */

  .panel-vertical {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .vertical-text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-foreground);
    white-space: nowrap;
    transition: opacity 0.4s ease;
  }

  .panels:hover .panel:hover .panel-vertical {
    opacity: 0;
  }

  .panels:hover .panel:not(:hover) .vertical-text {
    opacity: 0.35;
  }

  /* ── Expanded content (hover state) ── */

  .panel-content {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
    margin-top: auto;
    pointer-events: none;
  }

  .panels:hover .panel:hover .panel-content {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.12s;
    pointer-events: auto;
  }

  .panel-title {
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.25;
    color: var(--color-foreground);
    margin-bottom: 0.875rem;
    letter-spacing: -0.02em;
  }

  .panel-tagline {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brand);
    margin-bottom: 1rem;
  }

  .panel-desc {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 2rem;
    max-width: 280px;
  }

  .panel-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand);
    letter-spacing: 0.02em;
  }

  .cta-arrow {
    width: 1.125rem;
    height: 1.125rem;
    transition: transform 0.3s ease;
  }

  .panel:hover .cta-arrow {
    transform: translateX(4px);
  }

  /* ── Footer ── */

  .site-footer {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 2.5rem;
    text-align: center;
    z-index: 10;
    pointer-events: none;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 0.5rem;
    pointer-events: auto;
  }

  .footer-links a {
    font-size: 0.6875rem;
    color: var(--color-muted);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .footer-links a:hover {
    opacity: 1;
  }

  .footer-text {
    font-size: 0.6875rem;
    color: var(--color-muted);
    letter-spacing: 0.05em;
    opacity: 0.5;
  }

  /* ── SEO Content Section ── */

  .seo-content {
    padding: 5rem 1.5rem;
    background: white;
    border-top: 1px solid var(--color-divider);
  }

  .seo-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .seo-h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
  }

  .seo-intro {
    max-width: 800px;
    margin-bottom: 3rem;
  }

  .seo-intro p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .seo-h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .seo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .seo-division {
    padding: 1.5rem;
    border: 1px solid var(--color-divider);
    border-radius: 0.5rem;
  }

  .seo-division h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-foreground);
    margin-bottom: 0.5rem;
  }

  .seo-division h3 a {
    color: var(--color-foreground);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .seo-division h3 a:hover {
    color: var(--color-brand);
  }

  .seo-division p {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .seo-division ul {
    list-style: none;
    padding: 0;
  }

  .seo-division li {
    font-size: 0.75rem;
    line-height: 1.8;
    color: var(--color-muted);
  }

  .seo-division li a {
    color: var(--color-brand);
    text-decoration: none;
    font-weight: 600;
  }

  .seo-division li a:hover {
    text-decoration: underline;
  }

  .seo-stats {
    display: flex;
    gap: 3rem;
    margin-bottom: 2rem;
    padding: 2rem 0;
    border-top: 1px solid var(--color-divider);
    border-bottom: 1px solid var(--color-divider);
  }

  .seo-stat {
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .seo-stat strong {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-foreground);
    display: block;
    margin-bottom: 0.125rem;
  }

  .seo-cta {
    margin-top: 2rem;
  }

  .seo-cta p {
    font-size: 1rem;
    color: var(--color-muted);
  }

  .seo-cta a {
    color: var(--color-brand);
    font-weight: 600;
    text-decoration: none;
  }

  .seo-cta a:hover {
    text-decoration: underline;
  }

  /* Panel link reset (panels are now <a> tags) */
  .panel {
    text-decoration: none;
    color: inherit;
  }

  /* ── Keyframes ── */

  @keyframes panelReveal {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ── Mobile ── */

  @media (max-width: 768px) {
    .site-header {
      position: relative;
      padding: 2rem 1.5rem 1rem;
    }

    .logo {
      animation-delay: 0s;
    }

    .site-nav {
      display: none;
    }

    .panels {
      flex-direction: column;
      min-height: auto;
    }

    .panel {
      flex: none !important;
      border-right: none;
      border-bottom: 1px solid var(--color-divider);
      padding: 1.75rem 1.5rem;
      animation: panelRevealMobile 0.6s ease forwards;
      background-color: transparent !important;
    }

    .panel:nth-child(1) { animation-delay: 0.05s; }
    .panel:nth-child(2) { animation-delay: 0.1s; }
    .panel:nth-child(3) { animation-delay: 0.15s; }
    .panel:nth-child(4) { animation-delay: 0.2s; }
    .panel:nth-child(5) { animation-delay: 0.25s; }

    .panel:last-child {
      border-bottom: none;
    }

    .panel-vertical {
      display: none;
    }

    .panel-content {
      opacity: 1;
      transform: none;
      transition: none;
      pointer-events: auto;
    }

    .panel-number {
      margin-bottom: 0.5rem;
      opacity: 1 !important;
    }

    .panel-title {
      font-size: 1.25rem;
      margin-bottom: 0.5rem;
    }

    .panel-desc {
      display: none;
    }

    .panel-tagline {
      margin-bottom: 0.75rem;
    }

    .site-footer {
      position: relative;
      padding: 2rem 1.5rem;
    }

    .footer-text {
      opacity: 0.7;
    }

    .seo-content { padding: 3rem 1.5rem; }
    .seo-h1 { font-size: 1.5rem; }
    .seo-grid { grid-template-columns: 1fr; }
    .seo-stats { flex-direction: column; gap: 1rem; }

    @keyframes panelRevealMobile {
      from {
        opacity: 0;
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
  }
</style>

<script>
  const panels = document.querySelectorAll<HTMLElement>('[data-href]');

  panels.forEach((panel) => {
    panel.addEventListener('click', (e) => {
      e.preventDefault();
      const rect = panel.getBoundingClientRect();
      const href = panel.dataset.href;
      if (!href) return;

      // Create expanding overlay
      const overlay = document.createElement('div');
      overlay.style.position = 'fixed';
      overlay.style.top = `${rect.top}px`;
      overlay.style.left = `${rect.left}px`;
      overlay.style.width = `${rect.width}px`;
      overlay.style.height = `${rect.height}px`;
      overlay.style.backgroundColor = getComputedStyle(document.documentElement)
        .getPropertyValue('--color-brand')
        .trim() || '#E8720C';
      overlay.style.zIndex = '9999';
      overlay.style.pointerEvents = 'none';
      document.body.appendChild(overlay);

      // Force reflow then animate to fullscreen
      overlay.offsetHeight;
      overlay.style.transition = 'all 0.85s cubic-bezier(0.76, 0, 0.24, 1)';
      overlay.style.top = '0';
      overlay.style.left = '0';
      overlay.style.width = '100vw';
      overlay.style.height = '100vh';

      // Fade out page content
      const page = document.querySelector<HTMLElement>('.page');
      if (page) {
        page.style.transition = 'opacity 0.4s ease 0.1s';
        page.style.opacity = '0';
      }

      // Navigate after animation completes
      setTimeout(() => {
        window.location.href = href;
      }, 950);
    });
  });
</script>
